@{
    ViewData["Title"] = "EcoClean AI – Trợ lý Dinh dưỡng Cá nhân hóa";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var isLoggedIn = Context.Request.Cookies.ContainsKey("ecoclean_token");
}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">

<style>
    :root {
        --paper: #EDF3E6;
        --paper-warm: #DEE9D4;
        --ink: #22301E;
        --ink-soft: rgba(34,48,30,.62);
        --ink-faint: rgba(34,48,30,.38);
        --herb: #4B7A4E;
        --herb-deep: #33552F;
        --herb-light: #7CA05E;
        --herb-tint: #E7EEE0;
        --line: rgba(34,48,30,.14);
        --serif: 'Fraunces',Georgia,serif;
        --sans: 'Inter',system-ui,sans-serif;
        --mono: 'JetBrains Mono',monospace;
    }

    .ecai {
        font-family: var(--sans);
        color: var(--ink);
        background: var(--paper)
    }

        .ecai h1, .ecai h2, .ecai h3 {
            font-family: var(--serif)
        }

    @@keyframes fadeUp {
        from {
            opacity: 0;
            transform: translateY(24px)
        }

        to {
            opacity: 1;
            transform: translateY(0)
        }
    }

    @@keyframes scanLine {
        0% {
            top: 8%
        }

        100% {
            top: 88%
        }
    }

    @@keyframes tilt {
        0%, 100% {
            transform: rotate(-3deg)
        }

        50% {
            transform: rotate(-1.2deg)
        }
    }

    @@keyframes tearFloat {
        0%, 100% {
            transform: translateY(0) rotate(3deg)
        }

        50% {
            transform: translateY(-8px) rotate(3.6deg)
        }
    }

    .anim-1 {
        animation: fadeUp .7s ease both
    }

    .anim-2 {
        animation: fadeUp .7s .1s ease both
    }

    .anim-3 {
        animation: fadeUp .7s .2s ease both
    }

    .anim-4 {
        animation: fadeUp .7s .3s ease both
    }

    @@media (prefers-reduced-motion:reduce) {
        .anim-1, .anim-2, .anim-3, .anim-4 {
            animation: none
        }
    }

    .eyebrow {
        display: inline-flex;
        align-items: center;
        gap: .5rem;
        font-family: var(--mono);
        font-size: .72rem;
        letter-spacing: .12em;
        text-transform: uppercase;
        font-weight: 600
    }

    .rule {
        height: 1px;
        background: var(--line);
        border: none
    }

    /* ---- Receipt / ticket signature element ---- */
    .receipt {
        position: relative;
        background: #fff;
        width: 290px;
        padding: 26px 24px 20px;
        box-shadow: 0 26px 60px rgba(34,48,30,.22),0 2px 0 rgba(34,48,30,.05);
        font-family: var(--mono);
        color: var(--ink);
        animation: tilt 7s ease-in-out infinite;
        clip-path: polygon(0% 1.5%,3% 0%,6% 1.5%,9% 0%,12% 1.5%,15% 0%,18% 1.5%,21% 0%,24% 1.5%,27% 0%,30% 1.5%,33% 0%,36% 1.5%,39% 0%,42% 1.5%,45% 0%,48% 1.5%,51% 0%,54% 1.5%,57% 0%,60% 1.5%,63% 0%,66% 1.5%,69% 0%,72% 1.5%,75% 0%,78% 1.5%,81% 0%,84% 1.5%,87% 0%,90% 1.5%,93% 0%,96% 1.5%,100% 0%,100% 100%,0% 100%);
    }

    .receipt-scan {
        position: relative;
        overflow: hidden;
        border: 1.5px dashed rgba(75,122,78,.5);
        border-radius: 4px;
        background: var(--herb-tint)
    }

        .receipt-scan .beam {
            position: absolute;
            left: 0;
            width: 100%;
            height: 2px;
            background: linear-gradient(90deg,transparent,var(--herb),transparent);
            animation: scanLine 2.4s ease-in-out infinite alternate
        }

    .receipt-row {
        display: flex;
        justify-content: space-between;
        font-size: .78rem;
        padding: 3px 0
    }

        .receipt-row .dots {
            flex: 1;
            border-bottom: 1px dotted rgba(34,48,30,.3);
            margin: 0 6px 4px
        }

    .receipt-total {
        border-top: 1.5px dashed var(--line);
        margin-top: 8px;
        padding-top: 8px
    }

    .barcode {
        height: 26px;
        margin-top: 14px;
        background: repeating-linear-gradient(90deg,var(--ink) 0 2px,transparent 2px 4px,var(--ink) 4px 5px,transparent 5px 9px)
    }

    .tear-badge {
        position: absolute;
        background: var(--herb-tint);
        border: 1px solid rgba(75,122,78,.5);
        padding: 8px 12px;
        border-radius: 8px;
        font-family: var(--mono);
        font-size: .68rem;
        box-shadow: 0 10px 24px rgba(34,48,30,.14);
        animation: tearFloat 5s ease-in-out infinite
    }

    /* ---- cards ---- */
    .stub {
        background: #fff;
        border: 1px solid var(--line);
        border-radius: 2px;
        transition: transform .2s ease,box-shadow .2s ease
    }

        .stub:hover {
            transform: translateY(-4px);
            box-shadow: 0 18px 40px rgba(34,48,30,.1)
        }

    .stub-num {
        font-family: var(--serif);
        font-weight: 600;
        font-size: 1.5rem;
        color: var(--herb)
    }

    .chip {
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        font-family: var(--mono);
        font-size: .72rem;
        letter-spacing: .03em;
        padding: .4rem .8rem;
        border-radius: 100px;
        border: 1px solid var(--line)
    }

    .btn-herb {
        background: var(--herb);
        color: #fff;
        border: none
    }

        .btn-herb:hover {
            background: var(--herb-deep);
            color: #fff
        }

    .btn-outline-ink {
        border: 1.5px solid var(--ink);
        color: var(--ink);
        background: transparent
    }

        .btn-outline-ink:hover {
            background: var(--ink);
            color: var(--paper)
        }

    .pricing-card {
        background: #fff;
        border: 1px solid var(--line);
        border-radius: 4px
    }

        .pricing-card.featured {
            border-color: var(--herb);
            box-shadow: 0 20px 50px rgba(75,122,78,.14)
        }
</style>

<div class="ecai">

    <!-- ═══════════════════════════════════════════ HERO ═══════════════════════════════════════════ -->
    <section class="position-relative overflow-hidden" style="padding:5.5rem 0 4rem;background:var(--paper)">
        <div class="container position-relative">
            <div class="row align-items-center g-5">
                <div class="col-lg-6">
                    <div class="eyebrow mb-4 anim-1" style="color:var(--herb-deep)">
                        <span style="width:6px;height:6px;border-radius:50%;background:var(--herb);display:inline-block"></span>
                        Quét ảnh · Biết calo · Không cần tra bảng
                    </div>
                    <h1 class="fw-normal mb-4 anim-2" style="font-size:clamp(2.1rem,4.6vw,3.5rem);line-height:1.08;letter-spacing:-0.01em">
                        Chụp đĩa cơm.<br>
                        <span style="font-style:italic;color:var(--herb-deep)">Nhận phiếu dinh dưỡng</span><br>
                        trong 3 giây.
                    </h1>
                    <p class="mb-4 anim-3" style="color:var(--ink-soft);font-size:1.12rem;line-height:1.75;max-width:460px">
                        EcoClean AI nhận diện món Việt từ ảnh chụp, tách calo và macro ngay lập tức, rồi tự soạn thực đơn Eat Clean cả tuần dành riêng cho bạn.
                    </p>
                    <div class="d-flex flex-wrap gap-3 mb-5 anim-3">
                        <a asp-controller="Premium" asp-action="Scan"
                           class="btn btn-lg btn-herb fw-semibold px-4 py-3 rounded-1 d-inline-flex align-items-center gap-2">
                            <i class="bi bi-camera-fill"></i>Quét ảnh ngay — miễn phí
                        </a>
                        @if (!isLoggedIn)
                        {
                            <a asp-controller="Account" asp-action="Register"
                               class="btn btn-lg btn-outline-ink fw-semibold px-4 py-3 rounded-1">
                                Đăng ký miễn phí
                            </a>
                        }
                    </div>
                    <div class="d-flex flex-wrap gap-4 anim-4 pt-2" style="border-top:1px solid var(--line)">
                        @foreach (var (num, lbl) in new[]{
                                                ("3s", "để phân tích một món ăn"),
                                                ("10", "lượt AI dùng thử, không cần thẻ"),
                                                ("1000+", "món Việt & quốc tế nhận diện được"),
                                                })
                        {
                            <div class="pt-3" style="min-width:110px">
                                <div class="fw-normal" style="font-family:var(--serif);font-size:1.5rem;color:var(--ink)">@num</div>
                                <div style="color:var(--ink-faint);font-size:.75rem;line-height:1.4">@lbl</div>
                            </div>
                        }
                    </div>
                </div>

                <!-- RIGHT: receipt signature element -->
                <div class="col-lg-6 d-none d-lg-flex justify-content-center position-relative" style="min-height:460px">
                    <div class="receipt anim-2">
                        <div class="text-center mb-1" style="font-size:.68rem;letter-spacing:.14em">PHIẾU QUÉT MÓN ĂN</div>
                        <div class="text-center mb-3" style="font-size:.68rem;color:var(--ink-faint)">EcoClean AI · Gemini Vision</div>
                        <div class="receipt-scan d-flex align-items-center justify-content-center mb-3" style="height:120px">
                            <div class="beam"></div>
                            <i class="bi bi-camera-fill" style="font-size:2.1rem;color:var(--herb)"></i>
                        </div>
                        <div class="fw-semibold mb-2" style="font-size:.88rem">Cơm tấm sườn nướng</div>
                        @foreach (var (l, v) in new[] { ("Calo", "650 kcal"), ("Đạm (P)", "35 g"), ("Tinh bột (C)", "80 g"), ("Chất béo (F)", "22 g") })
                        {
                            <div class="receipt-row"><span>@l</span><span class="dots"></span><span>@v</span></div>
                        }
                        <div class="receipt-row receipt-total fw-semibold"><span>Độ chính xác</span><span class="dots"></span><span>94%</span></div>
                        <div class="barcode"></div>
                        <div class="text-center mt-2" style="font-size:.62rem;color:var(--ink-faint)">Đã thêm · Thứ 3 · Bữa trưa</div>
                    </div>
                    <div class="tear-badge" style="top:8%;right:6%">
                        <div class="fw-semibold" style="color:var(--herb-deep)">● đang phân tích...</div>
                    </div>
                    <div class="tear-badge" style="bottom:12%;left:2%">
                        <div class="fw-semibold" style="color:var(--herb-deep)">✓ đã lưu vào lịch ăn</div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <hr class="rule my-0">

    <!-- ═══════════════════════════════════════════ HOW IT WORKS ═══════════════════════════════════════════ -->
    <section style="padding:5rem 0;background:var(--paper-warm)">
        <div class="container">
            <div class="text-center mb-5">
                <span class="eyebrow mb-3" style="color:var(--herb-deep)">Cách hoạt động</span>
                <h2 class="fw-normal mb-2" style="font-size:2rem;letter-spacing:-0.01em">Ba bước, một tấm ảnh</h2>
                <p style="color:var(--ink-soft);max-width:480px;margin:0 auto">Không nhập tay, không tra bảng calo — AI làm hết phần việc lặp lại.</p>
            </div>
            <div class="row g-4">
                @foreach (var (step, icon, title, desc) in new[]{
                                ("01","bi-camera-fill",       "Chụp ảnh hoặc tải lên",  "Chụp đĩa ăn bằng điện thoại hoặc tải ảnh có sẵn. Hỗ trợ JPG, PNG, WEBP tối đa 5MB."),
                                ("02","bi-cpu-fill",          "AI nhận diện tức thì",   "Gemini Vision AI nhận diện món Việt như cơm sườn, phở, bún chả... và bóc tách calo, protein, carb, fat trong khoảng 3 giây."),
                                ("03","bi-calendar-check-fill","Thêm vào lịch — 1 chạm","Kết quả được thêm thẳng vào lịch ăn hàng ngày và tự so sánh với mục tiêu calo của bạn."),
                                })
                {
                    <div class="col-md-4">
                        <div class="stub p-4 h-100">
                            <div class="d-flex align-items-start justify-content-between mb-4">
                                <span class="stub-num">@step</span>
                                <i class="bi @icon" style="font-size:1.35rem;color:var(--herb)"></i>
                            </div>
                            <h5 class="fw-semibold mb-2" style="font-family:var(--sans)">@title</h5>
                            <p class="mb-0" style="color:var(--ink-soft);font-size:.92rem;line-height:1.7">@desc</p>
                        </div>
                    </div>
                }
            </div>
            <div class="text-center mt-5">
                <a asp-controller="Premium" asp-action="Scan" class="btn btn-lg btn-herb fw-semibold px-5 py-3 rounded-1">
                    Thử ngay miễn phí — 10 lượt đầu
                </a>
            </div>
        </div>
    </section>

    <!-- ═══════════════════════════════════════════ CORE FEATURES ═══════════════════════════════════════════ -->
    <section style="padding:5.5rem 0;background:var(--paper)">
        <div class="container">
            <div class="text-center mb-5">
                <span class="eyebrow mb-3" style="color:var(--herb-deep)">Tính năng cốt lõi</span>
                <h2 class="fw-normal mb-2" style="font-size:2rem;letter-spacing:-0.01em">Sản phẩm làm được gì</h2>
            </div>

            <!-- Feature 1 -->
            <div class="row g-5 align-items-center" style="margin-bottom:5rem">
                <div class="col-md-6">
                    <div class="p-4" style="background:var(--herb-tint);border-radius:4px;min-height:280px;display:flex;flex-direction:column;justify-content:center;gap:16px">
                        <div class="d-flex flex-wrap gap-2 justify-content-center">
                            @foreach (var (food, cal) in new[] { ("Phở bò", "520 cal"), ("Cơm sườn", "650 cal"), ("Bún chả", "480 cal"), ("Bánh mì", "410 cal") })
                            {
                                <span class="chip" style="background:#fff;border-color:rgba(75,122,78,.4);color:var(--ink)">@food · @cal</span>
                            }
                        </div>
                        <div class="text-center" style="font-family:var(--mono);font-size:.72rem;color:var(--ink-faint)">nhận diện món Việt · 3 giây / ảnh</div>
                    </div>
                </div>
                <div class="col-md-6">
                    <span class="chip mb-3" style="border-color:rgba(75,122,78,.5);color:var(--herb-deep)">Quét ảnh thông minh</span>
                    <h3 class="fw-normal mb-3" style="font-size:1.7rem">Chụp một lần — biết ngay calo</h3>
                    <p class="mb-4" style="color:var(--ink-soft);line-height:1.8">
                        AI nhận diện <strong>món Việt</strong> như cơm sườn, phở, bún chả, bánh mì... và tách đầy đủ <strong>calo, protein, carbohydrate, chất béo</strong> chỉ sau 3 giây.
                    </p>
                    <ul class="list-unstyled">
                        @foreach (var item in new[] { "Nhận diện 1000+ món Việt & quốc tế", "Phân tích đầy đủ 4 macro dinh dưỡng", "Thêm vào lịch ăn chỉ 1 chạm", "Độ chính xác cao nhờ Gemini Vision AI" })
                        {
                            <li class="d-flex align-items-start gap-2 mb-2">
                                <i class="bi bi-check2" style="color:var(--herb);margin-top:3px"></i>
                                <span style="font-size:.92rem">@item</span>
                            </li>
                        }
                    </ul>
                </div>
            </div>

            <!-- Feature 2 -->
            <div class="row g-5 align-items-center" style="margin-bottom:5rem">
                <div class="col-md-6 order-md-2">
                    <div class="p-4" style="background:var(--herb-tint);border-radius:4px;min-height:280px">
                        <div class="fw-semibold mb-3" style="font-family:var(--mono);font-size:.72rem;letter-spacing:.06em;color:var(--herb-deep)">THỰC ĐƠN TUẦN — AI TẠO</div>
                        @foreach (var (day, meal, cal) in new[]{
                                                ("T2","Cơm gạo lứt cá hồi + salad","450"),
                                                ("T3","Phở gà ít béo + trái cây","380"),
                                                ("T4","Ức gà nướng + rau hấp","320"),
                                                ("T5","Yến mạch overnight + smoothie","290"),
                                                })
                        {
                            <div class="d-flex align-items-center gap-3 mb-2 p-2" style="background:#fff;border-radius:3px">
                                <span class="fw-semibold" style="font-family:var(--mono);color:var(--herb-deep);font-size:.72rem;min-width:28px">@day</span>
                                <span class="flex-grow-1" style="font-size:.85rem">@meal</span>
                                <span class="chip" style="font-size:.65rem;border-color:rgba(75,122,78,.3)">@cal kcal</span>
                            </div>
                        }
                        <div class="text-center mt-3" style="font-size:.78rem;color:var(--ink-faint)">+ 3 ngày nữa được AI lên kế hoạch...</div>
                    </div>
                </div>
                <div class="col-md-6 order-md-1">
                    <span class="chip mb-3" style="border-color:rgba(75,122,78,.5);color:var(--herb-deep)">Lên thực đơn tuần tự động</span>
                    <h3 class="fw-normal mb-3" style="font-size:1.7rem">Thực đơn cả tuần — thiết kế riêng cho bạn</h3>
                    <p class="mb-4" style="color:var(--ink-soft);line-height:1.8">
                        Dựa trên <strong>chỉ số BMI, TDEE</strong> và mục tiêu của bạn, AI thiết kế menu Eat Clean 7 ngày với món dễ nấu, hợp khẩu vị Việt.
                    </p>
                    <ul class="list-unstyled">
                        @foreach (var item in new[] { "Cá nhân hóa theo BMI & TDEE của bạn", "Tự động cân bằng macro mỗi ngày", "Ưu tiên món Việt dễ nấu, dễ tìm nguyên liệu", "Điều chỉnh theo mục tiêu: giảm mỡ, tăng cơ, giữ dáng" })
                        {
                            <li class="d-flex align-items-start gap-2 mb-2">
                                <i class="bi bi-check2" style="color:var(--herb);margin-top:3px"></i>
                                <span style="font-size:.92rem">@item</span>
                            </li>
                        }
                    </ul>
                </div>
            </div>

            <!-- Feature 3 -->
            <div class="row g-5 align-items-center">
                <div class="col-md-6">
                    <div class="p-4" style="background:var(--paper-warm);border-radius:4px;min-height:280px">
                        <div class="fw-semibold mb-3" style="font-family:var(--mono);font-size:.72rem;letter-spacing:.06em;color:var(--herb-deep)">TIẾN ĐỘ 7 NGÀY QUA</div>
                        <div class="d-flex align-items-end gap-2 mb-3" style="height:100px">
                            @foreach (var (h, c, day) in new[] { ("60%", "var(--herb)", "T2"), ("80%", "var(--herb)", "T3"), ("45%", "var(--herb-light)", "T4"), ("90%", "var(--herb)", "T5"), ("70%", "var(--herb)", "T6"), ("55%", "var(--herb-light)", "T7"), ("85%", "var(--herb)", "CN") })
                            {
                                <div class="d-flex flex-column align-items-center gap-1 flex-grow-1">
                                    <div class="w-100" style="height:@h;background:@c;min-height:8px;border-radius:2px"></div>
                                    <span style="font-family:var(--mono);font-size:.62rem;color:var(--ink-faint)">@day</span>
                                </div>
                            }
                        </div>
                        <div class="d-flex justify-content-between" style="border-top:1px dashed var(--line);padding-top:12px">
                            @foreach (var (v, l, c) in new[] { ("1,820", "avg kcal/ngày", "var(--herb-deep)"), ("-1.2kg", "cân nặng tuần này", "var(--herb-deep)"), ("86%", "đạt mục tiêu", "var(--herb-deep)") })
                            {
                                <div class="text-center">
                                    <div class="fw-semibold" style="font-family:var(--serif);color:@c;font-size:1.25rem">@v</div>
                                    <div style="font-size:.68rem;color:var(--ink-faint)">@l</div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <span class="chip mb-3" style="border-color:rgba(75,122,78,.4);color:var(--herb-deep)">Theo dõi tiến độ</span>
                    <h3 class="fw-normal mb-3" style="font-size:1.7rem">Nhìn thấy kết quả — không bỏ cuộc</h3>
                    <p class="mb-4" style="color:var(--ink-soft);line-height:1.8">
                        Biểu đồ trực quan cho thấy rõ <strong>lượng calo nạp vào và tiêu hao</strong> mỗi ngày, giúp bạn duy trì thói quen ăn sạch lâu dài.
                    </p>
                    <ul class="list-unstyled">
                        @foreach (var item in new[] { "Biểu đồ calo theo ngày/tuần/tháng", "Theo dõi cân nặng & xu hướng thay đổi", "So sánh lượng ăn thực tế với mục tiêu", "Cảnh báo khi vượt hoặc thiếu calo" })
                        {
                            <li class="d-flex align-items-start gap-2 mb-2">
                                <i class="bi bi-check2" style="color:var(--herb);margin-top:3px"></i>
                                <span style="font-size:.92rem">@item</span>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </div>
    </section>

    <!-- ═══════════════════════════════════════════ BENEFITS ═══════════════════════════════════════════ -->
    <section style="padding:5.5rem 0;background:var(--paper-warm)">
        <div class="container">
            <div class="text-center mb-5">
                <span class="eyebrow mb-3" style="color:var(--herb-deep)">Lợi ích</span>
                <h2 class="fw-normal mb-2" style="font-size:2rem;letter-spacing:-0.01em">Tại sao chọn EcoClean AI</h2>
                <p style="color:var(--ink-soft);max-width:480px;margin:0 auto">Thiết kế cho người Việt bận rộn muốn sống lành mạnh.</p>
            </div>
            <div class="row g-4">
                @foreach (var (icon, color, title, desc) in new[]{
                                ("bi-lightning-charge-fill","var(--herb-light)",
                                "Tiết kiệm thời gian tối đa",
                                "Không còn ngồi gõ từng quả trứng, thìa cơm. Chụp một lần — AI làm hết trong 3 giây."),
                                ("bi-person-check-fill","var(--herb)",
                                "Cá nhân hóa 100%",
                                "Thực đơn của bạn là duy nhất, dựa trên chỉ số cơ thể, lịch sống và mục tiêu riêng."),
                                ("bi-heart-fill","var(--herb)",
                                "Dễ duy trì thành thói quen",
                                "Đơn giản hóa mọi bước phức tạp, giúp việc ăn sạch nhẹ nhàng và bền lâu."),
                                ("bi-shield-check-fill","var(--herb)",
                                "Dữ liệu chính xác",
                                "Powered by Google Gemini Vision — huấn luyện trên hàng triệu ảnh món ăn."),
                                ("bi-clock-fill","var(--herb-light)",
                                "Không cần cài đặt phức tạp",
                                "Truy cập qua trình duyệt, bắt đầu quét ảnh sau 30 giây đăng ký."),
                                ("bi-graph-up-arrow","var(--herb)",
                                "Theo dõi tiến trình rõ ràng",
                                "Biểu đồ trực quan giúp bạn thấy kết quả mỗi ngày và giữ động lực."),
                                })
                {
                    <div class="col-md-6 col-lg-4">
                        <div class="stub p-4 h-100">
                            <i class="bi @icon mb-3 d-block" style="color:@color;font-size:1.5rem"></i>
                            <h6 class="fw-semibold mb-1">@title</h6>
                            <p class="mb-0" style="color:var(--ink-soft);font-size:.88rem;line-height:1.7">@desc</p>
                        </div>
                    </div>
                }
            </div>
        </div>
    </section>

    <!-- ═══════════════════════════════════════════ PRICING ═══════════════════════════════════════════ -->
    <section style="padding:5.5rem 0;background:var(--paper)">
        <div class="container">
            <div class="text-center mb-5">
                <span class="eyebrow mb-3" style="color:var(--herb-deep)">Gói sử dụng</span>
                <h2 class="fw-normal mb-2" style="font-size:2rem;letter-spacing:-0.01em">Bắt đầu miễn phí, nâng cấp khi cần</h2>
                <p style="color:var(--ink-soft)">10 lượt AI miễn phí — không cần thẻ tín dụng</p>
            </div>
            <div class="row g-4 justify-content-center">
                <!-- Free -->
                <div class="col-md-4">
                    <div class="pricing-card p-4 h-100 d-flex flex-column">
                        <div class="mb-4">
                            <div class="eyebrow mb-2" style="color:var(--ink-faint)">Miễn phí</div>
                            <div class="d-flex align-items-end gap-1">
                                <span class="fw-normal" style="font-family:var(--serif);font-size:2.4rem">0đ</span>
                                <span style="color:var(--ink-faint)" class="mb-2 small">/mãi mãi</span>
                            </div>
                        </div>
                        <ul class="list-unstyled mb-4 flex-grow-1">
                            @foreach (var (t, h) in new[] { ("Tính BMI & TDEE", false), ("500+ công thức Eat Clean", false), ("Lịch ăn hàng ngày", false), ("Theo dõi cân nặng", false), ("10 lượt thử tính năng AI", true) })
                            {
                                <li class="d-flex align-items-center gap-2 py-2" style="border-bottom:1px solid var(--line)">
                                    <i class="bi bi-check2" style="color:var(--herb)"></i>
                                    <span style="font-size:.9rem">@t</span>
                                    @if (h)
                                    {
                                        <span class="chip ms-auto" style="font-size:.6rem;border-color:rgba(75,122,78,.3);color:var(--herb-deep)">Mới</span>
                                    }
                                </li>
                            }
                        </ul>
                        <a asp-controller="Account" asp-action="Register" class="btn btn-outline-ink w-100 rounded-1 fw-semibold py-2">Đăng ký miễn phí</a>
                    </div>
                </div>
                <!-- Premium tháng -->
                <div class="col-md-4">
                    <div class="pricing-card featured p-4 h-100 d-flex flex-column position-relative">
                        <div class="position-absolute top-0 end-0 px-3 py-1 fw-semibold" style="background:var(--herb);color:#fff;font-size:.65rem;letter-spacing:.05em;border-radius:0 4px 0 4px">PHỔ BIẾN</div>
                        <div class="mb-4">
                            <div class="eyebrow mb-2" style="color:var(--herb-deep)">Premium Tháng</div>
                            <div class="d-flex align-items-end gap-1">
                                <span class="fw-normal" style="font-family:var(--serif);font-size:2.4rem;color:var(--herb-deep)">49.000đ</span>
                                <span style="color:var(--ink-faint)" class="mb-2 small">/tháng</span>
                            </div>
                        </div>
                        <ul class="list-unstyled mb-4 flex-grow-1">
                            @foreach (var (t, ai) in new[] { ("Tất cả tính năng miễn phí", false), ("Quét ảnh AI không giới hạn", true), ("Chatbot dinh dưỡng 24/7", true), ("Thực đơn AI 7-14 ngày", true) })
                            {
                                <li class="d-flex align-items-center gap-2 py-2" style="border-bottom:1px solid rgba(75,122,78,.12)">
                                    <i class="bi bi-check2" style="color:var(--herb)"></i>
                                    <span style="font-size:.9rem">@t</span>
                                    @if (ai)
                                    {
                                        <span class="chip ms-auto" style="font-size:.6rem;border-color:rgba(75,122,78,.3);color:var(--herb-deep)">AI</span>
                                    }
                                </li>
                            }
                        </ul>
                        <a asp-controller="Premium" asp-action="Payment" class="btn btn-herb w-100 rounded-1 fw-semibold py-2">Nâng cấp ngay</a>
                    </div>
                </div>
                <!-- Premium năm -->
                <div class="col-md-4">
                    <div class="pricing-card p-4 h-100 d-flex flex-column position-relative">
                        <div class="position-absolute top-0 end-0 px-3 py-1 fw-semibold" style="background:var(--herb-deep);color:#fff;font-size:.65rem;letter-spacing:.05em;border-radius:0 4px 0 4px">TIẾT KIỆM 15%</div>
                        <div class="mb-4">
                            <div class="eyebrow mb-2" style="color:var(--herb-deep)">Premium Năm</div>
                            <div class="d-flex align-items-end gap-1">
                                <span class="fw-normal" style="font-family:var(--serif);font-size:2.4rem;color:var(--herb-deep)">499.000đ</span>
                                <span style="color:var(--ink-faint)" class="mb-2 small">/năm</span>
                            </div>
                            <div style="color:var(--ink-faint);font-size:.82rem">~41.600đ/tháng</div>
                        </div>
                        <ul class="list-unstyled mb-4 flex-grow-1">
                            @foreach (var t in new[] { "Tất cả tính năng Premium", "Ưu tiên hỗ trợ 24/7", "Tiết kiệm hơn gói tháng", "Truy cập tính năng mới sớm nhất" })
                            {
                                <li class="d-flex align-items-center gap-2 py-2" style="border-bottom:1px solid var(--line)">
                                    <i class="bi bi-check2" style="color:var(--herb-deep)"></i>
                                    <span style="font-size:.9rem">@t</span>
                                </li>
                            }
                        </ul>
                        <a asp-controller="Premium" asp-action="Payment" class="btn btn-herb w-100 rounded-1 fw-semibold py-2">Đăng ký gói năm</a>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- ═══════════════════════════════════════════ CTA FINAL ═══════════════════════════════════════════ -->
    <section style="padding:5.5rem 0;background:var(--ink)">
        <div class="container text-center">
            <div class="eyebrow mb-4 justify-content-center" style="color:var(--herb-light)">
                <span style="width:6px;height:6px;border-radius:50%;background:var(--herb);display:inline-block"></span>
                AI food scan · made for Vietnam
            </div>
            <h2 class="fw-normal mb-3" style="font-size:2.1rem;color:var(--paper);letter-spacing:-0.01em">
                Bắt đầu hành trình Eat Clean<br>ngay hôm nay
            </h2>
            <p class="mb-5" style="color:rgba(237,243,230,.6);font-size:1.05rem;max-width:440px;margin-left:auto;margin-right:auto">
                10 lượt miễn phí · Không cần thẻ tín dụng · Kết quả trong 3 giây
            </p>
            <div class="d-flex justify-content-center gap-3 flex-wrap">
                <a asp-controller="Premium" asp-action="Scan"
                   class="btn btn-lg btn-herb fw-semibold px-5 py-3 rounded-1 d-inline-flex align-items-center gap-2">
                    <i class="bi bi-camera-fill"></i>Quét ảnh miễn phí
                </a>
                @if (!isLoggedIn)
                {
                    <a asp-controller="Account" asp-action="Register"
                       class="btn btn-lg fw-semibold px-5 py-3 rounded-1"
                       style="background:transparent;color:var(--paper);border:1.5px solid rgba(237,243,230,.3)">
                        Tạo tài khoản
                    </a>
                }
            </div>
            <div class="d-flex justify-content-center gap-5 mt-5 flex-wrap">
                @foreach (var (num, lbl) in new[] { ("10+", "lượt dùng thử miễn phí"), ("3s", "thời gian phân tích"), ("100%", "cá nhân hóa") })
                {
                    <div class="text-center">
                        <div class="fw-normal" style="font-family:var(--serif);font-size:1.6rem;color:var(--paper)">@num</div>
                        <div style="color:rgba(237,243,230,.42);font-size:.75rem">@lbl</div>
                    </div>
                }
            </div>
        </div>
    </section>

</div>
