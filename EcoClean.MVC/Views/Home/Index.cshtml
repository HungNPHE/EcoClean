@{
    ViewData["Title"] = "EcoClean – Healthy Eat Clean";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- Hero -->
<section class="hero-section py-5" style="background: linear-gradient(135deg, #1a6b2e 0%, #2d9e4e 100%);">
    <div class="container text-white text-center py-5">
        <i class="bi bi-leaf-fill display-2 mb-3"></i>
        <h1 class="display-4 fw-bold">EcoClean</h1>
        <p class="lead mb-4">Hệ thống quản lý chế độ ăn Eat Clean thông minh<br>Cá nhân hóa bởi AI, theo dõi sức khỏe mỗi ngày</p>
        <a asp-controller="Account" asp-action="Register" class="btn btn-warning btn-lg me-3 fw-bold">
            <i class="bi bi-rocket-takeoff me-2"></i>Bắt đầu miễn phí
        </a>
        <a asp-controller="Recipe" asp-action="Index" class="btn btn-outline-light btn-lg">
            <i class="bi bi-book me-2"></i>Xem công thức
        </a>
    </div>
</section>

<!-- Features -->
<section class="py-5 bg-light">
    <div class="container">
        <h2 class="text-center fw-bold mb-5">Tính năng nổi bật</h2>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm text-center p-4">
                    <i class="bi bi-calculator display-4 text-success mb-3"></i>
                    <h5 class="fw-bold">Tính BMI & TDEE</h5>
                    <p class="text-muted">Tự động tính chỉ số cơ thể và lượng calo cần thiết mỗi ngày theo mục tiêu của bạn.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm text-center p-4">
                    <i class="bi bi-calendar-check display-4 text-primary mb-3"></i>
                    <h5 class="fw-bold">Lịch ăn uống</h5>
                    <p class="text-muted">Lên kế hoạch bữa ăn hàng ngày, theo dõi calories tiêu thụ và đảm bảo dinh dưỡng cân bằng.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm text-center p-4">
                    <i class="bi bi-graph-up display-4 text-info mb-3"></i>
                    <h5 class="fw-bold">Theo dõi cân nặng</h5>
                    <p class="text-muted">Ghi lại và theo dõi sự thay đổi cân nặng theo thời gian với biểu đồ trực quan.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm text-center p-4 position-relative">
                    <span class="badge bg-warning text-dark position-absolute top-0 end-0 m-2">Premium</span>
                    <i class="bi bi-camera display-4 text-warning mb-3"></i>
                    <h5 class="fw-bold">Quét ảnh thực phẩm</h5>
                    <p class="text-muted">AI nhận diện món ăn từ ảnh và ước tính calories, protein, carb, fat tự động.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm text-center p-4 position-relative">
                    <span class="badge bg-warning text-dark position-absolute top-0 end-0 m-2">Premium</span>
                    <i class="bi bi-chat-dots display-4 text-warning mb-3"></i>
                    <h5 class="fw-bold">Chatbot dinh dưỡng 24/7</h5>
                    <p class="text-muted">Tư vấn dinh dưỡng, gợi ý món ăn và giải đáp mọi câu hỏi về Eat Clean bất cứ lúc nào.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm text-center p-4 position-relative">
                    <span class="badge bg-warning text-dark position-absolute top-0 end-0 m-2">Premium</span>
                    <i class="bi bi-robot display-4 text-warning mb-3"></i>
                    <h5 class="fw-bold">Thực đơn AI cá nhân hóa</h5>
                    <p class="text-muted">AI tạo thực đơn 7 ngày phù hợp với BMI, TDEE và mục tiêu sức khỏe của bạn.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Pricing -->
<section class="py-5">
    <div class="container">
        <h2 class="text-center fw-bold mb-5">Gói sử dụng</h2>
        <div class="row g-4 justify-content-center">
            <div class="col-md-4">
                <div class="card border-0 shadow-sm h-100 text-center p-4">
                    <h4 class="fw-bold">Miễn phí</h4>
                    <p class="display-5 fw-bold text-success">0đ</p>
                    <ul class="list-unstyled text-start mb-4">
                        <li class="py-1"><i class="bi bi-check-circle text-success me-2"></i>Tính BMI & TDEE</li>
                        <li class="py-1"><i class="bi bi-check-circle text-success me-2"></i>Thư viện công thức Eat Clean</li>
                        <li class="py-1"><i class="bi bi-check-circle text-success me-2"></i>Lịch ăn uống cơ bản</li>
                        <li class="py-1"><i class="bi bi-check-circle text-success me-2"></i>Theo dõi cân nặng</li>
                    </ul>
                    <a asp-controller="Account" asp-action="Register" class="btn btn-outline-success w-100">Đăng ký ngay</a>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card border-2 border-warning shadow h-100 text-center p-4 position-relative">
                    <span class="badge bg-warning text-dark position-absolute top-0 start-50 translate-middle">Phổ biến nhất</span>
                    <h4 class="fw-bold mt-2">Premium</h4>
                    <p class="display-5 fw-bold text-warning">99.000đ<small class="fs-6 fw-normal text-muted">/tháng</small></p>
                    <ul class="list-unstyled text-start mb-4">
                        <li class="py-1"><i class="bi bi-check-circle text-success me-2"></i>Tất cả tính năng miễn phí</li>
                        <li class="py-1"><i class="bi bi-check-circle text-warning me-2"></i>Quét ảnh phân tích dinh dưỡng</li>
                        <li class="py-1"><i class="bi bi-check-circle text-warning me-2"></i>Chatbot chuyên gia 24/7</li>
                        <li class="py-1"><i class="bi bi-check-circle text-warning me-2"></i>Thực đơn AI cá nhân hóa</li>
                    </ul>
                    <a asp-controller="Premium" asp-action="Payment" class="btn btn-warning w-100 fw-bold">Nâng cấp ngay</a>
                </div>
            </div>
        </div>
    </div>
</section>
