@using System.Text.Json
@{
    ViewData["Title"] = "Theo dõi cân nặng";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var logs = ViewBag.Logs is JsonElement le && le.ValueKind == JsonValueKind.Array
               ? le.EnumerateArray().ToList() : new();
    var latest  = logs.Any() && logs.Last().TryGetProperty("weight",  out var lw) ? lw.GetDouble() : (double?)null;
    var first   = logs.Any() && logs.First().TryGetProperty("weight", out var fw) ? fw.GetDouble() : (double?)null;
    var change  = latest.HasValue && first.HasValue ? latest.Value - first.Value : (double?)null;
    var minW    = logs.Any() ? logs.Min(l => l.TryGetProperty("weight", out var w) ? w.GetDouble() : 999) : 0;
    var maxW    = logs.Any() ? logs.Max(l => l.TryGetProperty("weight", out var w) ? w.GetDouble() : 0)   : 0;
}

<div class="container py-4">
    <div class="d-flex align-items-center mb-4">
        <i class="bi bi-graph-up-arrow text-success fs-2 me-3"></i>
        <div>
            <h2 class="fw-bold mb-0">Theo dõi cân nặng</h2>
            <p class="text-muted mb-0">@logs.Count lần ghi chép</p>
        </div>
    </div>

    <!-- Stats -->
    <div class="row g-3 mb-4">
        <div class="col-6 col-md-3">
            <div class="card border-0 shadow-sm rounded-4 p-3 text-center">
                <small class="text-muted">Hiện tại</small>
                <div class="fs-2 fw-bold text-success">@(latest.HasValue ? latest.Value.ToString("0.0") : "--")<small class="fs-6"> kg</small></div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card border-0 shadow-sm rounded-4 p-3 text-center">
                <small class="text-muted">Thay đổi (90 ngày)</small>
                @if (change.HasValue)
                {
                    var cls = change.Value > 0 ? "danger" : change.Value < 0 ? "success" : "secondary";
                    var ico = change.Value > 0 ? "bi-arrow-up" : change.Value < 0 ? "bi-arrow-down" : "bi-dash";
                    <div class="fs-2 fw-bold text-@cls"><i class="bi @ico"></i>@Math.Abs(change.Value).ToString("0.0")<small class="fs-6"> kg</small></div>
                }
                else { <div class="fs-2 fw-bold text-muted">--</div> }
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card border-0 shadow-sm rounded-4 p-3 text-center">
                <small class="text-muted">Thấp nhất</small>
                <div class="fs-2 fw-bold text-info">@(logs.Any() ? minW.ToString("0.0") : "--")<small class="fs-6"> kg</small></div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card border-0 shadow-sm rounded-4 p-3 text-center">
                <small class="text-muted">Cao nhất</small>
                <div class="fs-2 fw-bold text-warning">@(logs.Any() ? maxW.ToString("0.0") : "--")<small class="fs-6"> kg</small></div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <!-- Chart -->
        <div class="col-md-8">
            <div class="card border-0 shadow-sm rounded-4 p-4">
                <h5 class="fw-bold mb-3"><i class="bi bi-bar-chart-line text-info me-2"></i>Biểu đồ cân nặng</h5>
                @if (logs.Any())
                {
                    <canvas id="weightChart" height="200"></canvas>
                }
                else
                {
                    <div class="text-center py-5">
                        <i class="bi bi-clipboard-data display-4 text-muted d-block mb-3"></i>
                        <p class="text-muted">Chưa có dữ liệu. Hãy ghi lại cân nặng đầu tiên!</p>
                    </div>
                }
            </div>
        </div>

        <!-- Log Form + History -->
        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4 p-4 mb-3">
                <h6 class="fw-bold mb-3"><i class="bi bi-plus-circle text-success me-2"></i>Ghi cân nặng</h6>
                <form method="post" asp-action="Log">
                    <div class="mb-2">
                        <label class="form-label small fw-semibold">Cân nặng (kg)</label>
                        <div class="input-group">
                            <input type="number" name="weight" class="form-control rounded-start-3"
                                   placeholder="65.0" step="0.1" min="20" max="300" required />
                            <span class="input-group-text">kg</span>
                        </div>
                    </div>
                    <div class="mb-2">
                        <label class="form-label small fw-semibold">Ngày</label>
                        <input type="date" name="logDate" class="form-control rounded-3"
                               value="@DateTime.Today.ToString("yyyy-MM-dd")" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Ghi chú</label>
                        <input type="text" name="notes" class="form-control rounded-3"
                               placeholder="Cảm giác hôm nay..." />
                    </div>
                    <button type="submit" class="btn btn-success btn-sm w-100 rounded-3">
                        <i class="bi bi-save me-1"></i>Lưu
                    </button>
                </form>
            </div>

            <!-- Recent logs -->
            <div class="card border-0 shadow-sm rounded-4 p-3">
                <h6 class="fw-bold mb-3">Gần đây</h6>
                <div style="max-height:260px;overflow-y:auto">
                    @foreach (var log in logs.AsEnumerable().Reverse().Take(15))
                    {
                        var w    = log.TryGetProperty("weight",  out var wv) ? wv.GetDouble() : 0;
                        var ld   = log.TryGetProperty("logDate", out var dv) ? dv.GetString() : "";
                        var note = log.TryGetProperty("notes",   out var nv) && nv.ValueKind != JsonValueKind.Null ? nv.GetString() : null;
                        var lid  = log.TryGetProperty("id",      out var idv) ? idv.GetInt32() : 0;
                        <div class="d-flex justify-content-between align-items-center border-bottom py-2">
                            <div>
                                <span class="fw-bold">@w.ToString("0.0") kg</span>
                                <small class="text-muted d-block">@ld</small>
                                @if (!string.IsNullOrEmpty(note))
                                { <small class="text-muted fst-italic">@note</small> }
                            </div>
                            <form method="post" asp-action="Delete" class="mb-0">
                                <input type="hidden" name="id" value="@lid" />
                                <button type="submit" class="btn btn-sm btn-outline-danger rounded-circle p-1 lh-1"
                                        onclick="return confirm('Xoá?')">
                                    <i class="bi bi-trash3" style="font-size:.75rem"></i>
                                </button>
                            </form>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
const wLogs = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(logs.Select(l => new {
    date   = l.TryGetProperty("logDate",out var d) ? d.GetString() : "",
    weight = l.TryGetProperty("weight", out var w) ? w.GetDouble() : 0
})));

if (wLogs.length > 0 && document.getElementById('weightChart')) {
    const weights = wLogs.map(l => l.weight);
    const avgW    = weights.reduce((a,b)=>a+b,0)/weights.length;
    new Chart(document.getElementById('weightChart'), {
        type: 'line',
        data: {
            labels: wLogs.map(l => l.date),
            datasets: [
                {
                    label: 'Cân nặng (kg)',
                    data: weights,
                    borderColor: '#22c55e', backgroundColor: 'rgba(34,197,94,0.1)',
                    fill: true, tension: 0.4, pointRadius: 4,
                    pointBackgroundColor: '#22c55e'
                },
                {
                    label: 'Trung bình',
                    data: Array(weights.length).fill(Math.round(avgW * 10)/10),
                    borderColor: '#f59e0b', borderDash: [6,4],
                    pointRadius: 0, fill: false
                }
            ]
        },
        options: {
            responsive: true,
            plugins: {
                legend: { display: true, position: 'bottom' },
                tooltip: { callbacks: { label: ctx => ` ${ctx.parsed.y} kg` } }
            },
            scales: {
                y: { grid: { color: 'rgba(0,0,0,0.05)' },
                     ticks: { callback: v => v + ' kg' } },
                x: { grid: { display: false }, ticks: { maxTicksLimit: 8 } }
            }
        }
    });
}
</script>
}
