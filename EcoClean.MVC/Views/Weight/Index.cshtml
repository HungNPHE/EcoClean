@using System.Text.Json
@{
    ViewData["Title"] = "Theo dõi cân nặng";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var logs = ViewBag.Logs is JsonElement le && le.ValueKind == JsonValueKind.Array
               ? le.EnumerateArray().ToList() : new();
    var latest  = logs.Any() && logs.Last().TryGetProperty("weight",  out var lw) ? lw.GetDouble() : (double?)null;
    var first   = logs.Any() && logs.First().TryGetProperty("weight", out var fw) ? fw.GetDouble() : (double?)null;
    var change  = latest.HasValue && first.HasValue ? latest.Value - first.Value : (double?)null;
    var minW    = logs.Any() ? logs.Min(l => l.TryGetProperty("weight", out var w) ? w.GetDouble() : 999) : 0;
    var maxW    = logs.Any() ? logs.Max(l => l.TryGetProperty("weight", out var w) ? w.GetDouble() : 0)   : 0;
}

<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,600;9..144,700&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet">
<style>
:root{--paper:#EDF3E6;--paper-warm:#DEE9D4;--ink:#22301E;--ink-soft:rgba(34,48,30,.62);--ink-faint:rgba(34,48,30,.38);--herb:#4B7A4E;--herb-deep:#33552F;--herb-tint:#E7EEE0;--line:rgba(34,48,30,.14);--serif:'Fraunces',Georgia,serif;--mono:'JetBrains Mono',monospace}
.btn-herb{background:var(--herb);color:#fff;border:none}.btn-herb:hover{background:var(--herb-deep);color:#fff}
</style>

<div class="container py-4" style="font-family:'Inter',system-ui,sans-serif;color:var(--ink)">
    <!-- Header -->
    <div class="d-flex align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1" style="font-family:var(--serif);letter-spacing:-.02em">Theo dõi cân nặng</h2>
            <p class="text-muted mb-0">@logs.Count lần ghi chép trong 90 ngày qua</p>
        </div>
    </div>

    <!-- Stats -->
    <div class="row g-3 mb-4">
        @{
            var changeColor = change.HasValue ? (change.Value > 0 ? "#ef4444" : change.Value < 0 ? "#22c55e" : "#64748b") : "#64748b";
            var changeIcon  = change.HasValue ? (change.Value > 0 ? "bi-arrow-up" : change.Value < 0 ? "bi-arrow-down" : "bi-dash") : "bi-dash";
        }
        @foreach (var (title, val, unit, color, bg) in new[] {
            ("Hiện tại",          latest.HasValue ? latest.Value.ToString("0.0") : "--", "kg",  "#16a34a", "rgba(22,163,74,.08)"),
            ("Thay đổi (90 ngày)", change.HasValue ? Math.Abs(change.Value).ToString("0.0") : "--", "kg", changeColor, $"rgba(0,0,0,.04)"),
            ("Thấp nhất",         logs.Any() ? minW.ToString("0.0") : "--", "kg", "#0ea5e9", "rgba(14,165,233,.08)"),
            ("Cao nhất",          logs.Any() ? maxW.ToString("0.0") : "--", "kg", "#f59e0b", "rgba(245,158,11,.08)"),
        })
        {
            <div class="col-6 col-md-3">
                <div class="card border-0 p-3 text-center" style="background:@bg;border-radius:16px !important">
                    <small class="text-muted d-block mb-1">@title</small>
                    <div class="fw-bold" style="font-size:1.75rem;letter-spacing:-0.03em;color:@color">
                        @if (title == "Thay đổi (90 ngày)" && change.HasValue)
                        {
                            <i class="bi @changeIcon" style="font-size:1.2rem"></i>
                        }
                        @val
                    </div>
                    <small class="text-muted">@unit</small>
                </div>
            </div>
        }
    </div>

    <div class="row g-4">
        <!-- Chart -->
        <div class="col-md-8">
            <div class="card border-0 p-4" style="border-radius:16px !important">
                <div class="d-flex align-items-center gap-2 mb-3">
                    <div class="rounded-2 d-flex align-items-center justify-content-center"
                         style="width:34px;height:34px;background:rgba(22,163,74,.1);color:#16a34a">
                        <i class="bi bi-bar-chart-line"></i>
                    </div>
                    <h5 class="fw-bold mb-0">Biểu đồ cân nặng</h5>
                </div>
                @if (logs.Any())
                {
                    <canvas id="weightChart" height="200"></canvas>
                }
                else
                {
                    <div class="text-center py-5">
                        <i class="bi bi-clipboard-data display-4 text-muted d-block mb-3 opacity-25"></i>
                        <p class="text-muted">Chưa có dữ liệu. Hãy ghi lại cân nặng đầu tiên!</p>
                    </div>
                }
            </div>
        </div>

        <!-- Log Form + History -->
        <div class="col-md-4">
            <div class="card border-0 p-4 mb-3" style="border-radius:16px !important">
                <div class="d-flex align-items-center gap-2 mb-3">
                    <div class="rounded-2 d-flex align-items-center justify-content-center"
                         style="width:32px;height:32px;background:rgba(22,163,74,.1);color:#16a34a">
                        <i class="bi bi-plus-lg"></i>
                    </div>
                    <h6 class="fw-bold mb-0">Ghi cân nặng</h6>
                </div>
                <form method="post" asp-action="Log">
                    <div class="mb-2">
                        <label class="form-label">Cân nặng (kg)</label>
                        <div class="input-group">
                            <input type="number" name="weight" class="form-control"
                                   placeholder="65.0" step="0.1" min="20" max="300" required />
                            <span class="input-group-text">kg</span>
                        </div>
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Ngày</label>
                        <input type="date" name="logDate" class="form-control"
                               value="@DateTime.Today.ToString("yyyy-MM-dd")" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Ghi chú</label>
                        <input type="text" name="notes" class="form-control"
                               placeholder="Cảm giác hôm nay..." />
                    </div>
                    <button type="submit" class="btn btn-herb btn-sm w-100 rounded-1 fw-semibold">
                        <i class="bi bi-save me-1"></i>Lưu
                    </button>
                </form>
            </div>

            <!-- Recent logs -->
            <div class="card border-0 p-3" style="border-radius:16px !important">
                <h6 class="fw-bold mb-3">Gần đây</h6>
                <div style="max-height:280px;overflow-y:auto">
                    @foreach (var log in logs.AsEnumerable().Reverse().Take(15))
                    {
                        var w    = log.TryGetProperty("weight",  out var wv) ? wv.GetDouble() : 0;
                        var ld   = log.TryGetProperty("logDate", out var dv) ? dv.GetString() : "";
                        var note = log.TryGetProperty("notes",   out var nv) && nv.ValueKind != JsonValueKind.Null ? nv.GetString() : null;
                        var lid  = log.TryGetProperty("id",      out var idv) ? idv.GetInt32() : 0;
                        <div class="d-flex justify-content-between align-items-center py-2"
                             style="border-bottom:1px solid rgba(226,232,240,.5)">
                            <div>
                                <span class="fw-bold small">@w.ToString("0.0") kg</span>
                                <small class="text-muted d-block" style="font-size:.78rem">@ld</small>
                                @if (!string.IsNullOrEmpty(note))
                                {
                                    <small class="text-muted fst-italic" style="font-size:.78rem">@note</small>
                                }
                            </div>
                            <form method="post" asp-action="Delete" class="mb-0">
                                <input type="hidden" name="id" value="@lid" />
                                <button type="submit"
                                        class="btn btn-sm rounded-circle d-flex align-items-center justify-content-center"
                                        style="width:28px;height:28px;padding:0;background:rgba(239,68,68,.08);color:#ef4444;border:none"
                                        onclick="return confirm('Xoá?')">
                                    <i class="bi bi-trash3" style="font-size:.7rem"></i>
                                </button>
                            </form>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
const wLogs = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(logs.Select(l => new {
    date   = l.TryGetProperty("logDate",out var d) ? d.GetString() : "",
    weight = l.TryGetProperty("weight", out var w) ? w.GetDouble() : 0
})));

if (wLogs.length > 0 && document.getElementById('weightChart')) {
    const weights = wLogs.map(l => l.weight);
    const avgW    = weights.reduce((a,b)=>a+b,0)/weights.length;
    new Chart(document.getElementById('weightChart'), {
        type: 'line',
        data: {
            labels: wLogs.map(l => l.date),
            datasets: [
                {
                    label: 'Cân nặng (kg)',
                    data: weights,
                    borderColor: '#22c55e',
                    backgroundColor: 'rgba(34,197,94,0.08)',
                    fill: true, tension: 0.4,
                    pointRadius: 4, pointHoverRadius: 6,
                    pointBackgroundColor: '#22c55e',
                    borderWidth: 2
                },
                {
                    label: 'Trung bình',
                    data: Array(weights.length).fill(Math.round(avgW * 10)/10),
                    borderColor: '#f59e0b',
                    borderDash: [6,4],
                    pointRadius: 0, fill: false,
                    borderWidth: 1.5
                }
            ]
        },
        options: {
            responsive: true,
            plugins: {
                legend: { display: true, position: 'bottom', labels: { font: { size: 12 }, usePointStyle: true } },
                tooltip: { callbacks: { label: ctx => ` ${ctx.parsed.y} kg` } }
            },
            scales: {
                y: { grid: { color: 'rgba(0,0,0,0.04)' }, ticks: { callback: v => v + ' kg', font: { size: 11 } } },
                x: { grid: { display: false }, ticks: { maxTicksLimit: 8, font: { size: 11 } } }
            }
        }
    });
}
</script>
}
