@{
    ViewData["Title"] = "Quét ảnh món ăn";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-4">
    <div class="d-flex align-items-center mb-4">
        <div class="rounded-3 d-flex align-items-center justify-content-center me-3"
             style="width:44px;height:44px;background:linear-gradient(135deg,#f59e0b,#d97706);color:white;font-size:1.2rem">
            <i class="bi bi-camera-fill"></i>
        </div>
        <div>
            <h2 class="fw-bold mb-0" style="letter-spacing:-0.02em">
                Quét ảnh món ăn
                <span class="badge ms-2 align-middle" style="background:linear-gradient(135deg,#f59e0b,#d97706);color:white;font-size:.65rem">Premium</span>
            </h2>
            <p class="text-muted mb-0 small">AI tự động nhận diện và phân tích dinh dưỡng</p>
        </div>
    </div>

    <div class="row g-4">
        <!-- Upload -->
        <div class="col-md-5">
            <div class="card border-0 p-4" style="border-radius:20px !important">
                <div id="dropZone" class="drop-zone p-5 text-center mb-3"
                     ondragover="event.preventDefault();this.classList.add('drag-over')"
                     ondragleave="this.classList.remove('drag-over')"
                     ondrop="handleDrop(event)">
                    <div class="rounded-3 d-inline-flex align-items-center justify-content-center mb-3"
                         style="width:56px;height:56px;background:rgba(22,163,74,.1)">
                        <i class="bi bi-cloud-upload-fill text-success fs-3"></i>
                    </div>
                    <p class="fw-semibold mb-1">Kéo thả ảnh vào đây</p>
                    <p class="text-muted small mb-3">hoặc</p>
                    <label class="btn btn-eco-outline rounded-pill px-4 fw-semibold">
                        <i class="bi bi-folder2-open me-2"></i>Chọn ảnh
                        <input type="file" id="fileInput" accept="image/*" class="d-none" onchange="handleFile(this)" />
                    </label>
                    <p class="text-muted small mt-3 mb-0">JPG, PNG, WEBP — tối đa 5MB</p>
                </div>

                <img id="preview" class="img-fluid rounded-3 d-none mb-3"
                     style="max-height:240px;width:100%;object-fit:cover" />

                <button id="analyzeBtn" class="btn btn-premium w-100 py-2 fw-bold rounded-pill d-none"
                        onclick="analyzeImage()">
                    <i class="bi bi-stars me-2"></i>Phân tích với AI
                </button>
            </div>
        </div>

        <!-- Results -->
        <div class="col-md-7">
            <!-- Loading -->
            <div id="loadingCard" class="card border-0 p-5 text-center d-none" style="border-radius:20px !important">
                <div class="d-inline-flex align-items-center justify-content-center rounded-circle mb-3 mx-auto"
                     style="width:64px;height:64px;background:rgba(245,158,11,.1)">
                    <div class="spinner-border text-warning" style="width:2rem;height:2rem"></div>
                </div>
                <h5 class="fw-bold">AI đang phân tích...</h5>
                <p class="text-muted small">Nhận diện món ăn và tính toán dinh dưỡng</p>
            </div>

            <!-- Result card -->
            <div id="resultCard" class="d-none">
                <div class="card border-0 p-4 mb-3" style="border-radius:20px !important;background:linear-gradient(135deg,#fffbeb,#fef9c3)">
                    <div class="d-flex align-items-center gap-3 mb-3">
                        <div class="rounded-3 d-flex align-items-center justify-content-center"
                             style="width:44px;height:44px;background:rgba(22,163,74,.15)">
                            <i class="bi bi-check-circle-fill text-success fs-5"></i>
                        </div>
                        <div>
                            <h5 class="fw-bold mb-0" id="foodName">--</h5>
                            <small class="text-muted">Độ tin cậy: <span id="confidence" class="fw-semibold text-success">--</span></small>
                        </div>
                    </div>
                    <div class="text-center py-3 rounded-3 mb-3" style="background:rgba(255,255,255,.7)">
                        <small class="text-muted d-block">Tổng năng lượng</small>
                        <span class="fw-bold" style="font-size:2.5rem;color:#d97706;letter-spacing:-0.03em" id="totalCal">--</span>
                        <span class="text-muted fs-5"> kcal</span>
                    </div>
                    <div class="row g-2 text-center">
                        @foreach (var (id, label, color, bg) in new[] {
                            ("prot","Protein","#ef4444","rgba(239,68,68,.1)"),
                            ("carb","Carbohydrate","#f59e0b","rgba(245,158,11,.1)"),
                            ("fat","Chất béo","#0ea5e9","rgba(14,165,233,.1)")
                        })
                        {
                            <div class="col-4">
                                <div class="rounded-3 p-2" style="background:@bg">
                                    <div class="fw-bold" style="color:@color;font-size:1.1rem" id="@id">--</div>
                                    <small class="text-muted" style="font-size:.72rem">@label</small>
                                </div>
                            </div>
                        }
                    </div>
                </div>

                <!-- Add to meal plan -->
                <div class="card border-0 p-3" style="border-radius:16px !important">
                    <h6 class="fw-bold mb-3">
                        <i class="bi bi-calendar-plus me-2" style="color:#16a34a"></i>Thêm vào lịch ăn
                    </h6>
                    <div class="row g-2">
                        <div class="col-5">
                            <select id="addMealType" class="form-select">
                                <option value="Breakfast">🌅 Bữa sáng</option>
                                <option value="Lunch" selected>☀️ Bữa trưa</option>
                                <option value="Dinner">🌙 Bữa tối</option>
                                <option value="Snack">🍎 Snack</option>
                            </select>
                        </div>
                        <div class="col-4">
                            <input type="date" id="addDate" class="form-control"
                                   value="@DateTime.Today.ToString("yyyy-MM-dd")" />
                        </div>
                        <div class="col-3">
                            <button class="btn btn-eco btn-sm w-100 rounded-3 fw-semibold" onclick="addToMealPlan()">
                                <i class="bi bi-plus-lg"></i>
                            </button>
                        </div>
                    </div>
                    <div id="addMsg" class="mt-2 d-none small"></div>
                </div>

                <!-- AI Recipe Suggestions từ nguyên liệu -->
                <div id="aiPlanSection" class="card border-0 p-4 mt-3 d-none" style="border-radius:20px !important;border:1.5px solid #f59e0b !important;background:linear-gradient(135deg,#fffbeb,#fff)">
                    <div class="d-flex align-items-center mb-3">
                        <div class="rounded-3 d-flex align-items-center justify-content-center me-2"
                             style="width:32px;height:32px;background:rgba(245,158,11,.15)">
                            <i class="bi bi-lightbulb-fill" style="color:#d97706"></i>
                        </div>
                        <div>
                            <h6 class="fw-bold mb-0" style="color:#d97706">Gợi ý món ăn từ <span id="ingredientLabel"></span></h6>
                            <small class="text-muted">AI gợi ý 4 món Eat Clean từ nguyên liệu này</small>
                        </div>
                    </div>

                    <!-- Loading -->
                    <div id="planLoading" class="text-center py-3 d-none">
                        <div class="spinner-border spinner-border-sm text-warning me-2"></div>
                        <span class="text-muted small">AI đang gợi ý món ăn...</span>
                    </div>

                    <!-- Danh sách món -->
                    <div id="planResult"></div>
                </div>
            </div>

            <!-- Placeholder -->
            <div id="placeholder" class="card border-0 p-5 text-center" style="border-radius:20px !important">
                <div class="d-inline-flex align-items-center justify-content-center rounded-3 mb-3 mx-auto"
                     style="width:64px;height:64px;background:rgba(245,158,11,.08)">
                    <i class="bi bi-camera text-warning" style="font-size:2rem"></i>
                </div>
                <h5 class="fw-bold mb-2">Upload ảnh để bắt đầu</h5>
                <p class="text-muted small mb-0">AI sẽ nhận diện món ăn và tính calories, protein, carb, fat tự động</p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
let base64Data = null;
let currentResult = null;

function handleFile(input) {
    const file = input.files[0];
    if (!file) return;
    if (file.size > 5 * 1024 * 1024) { alert('File quá lớn! Tối đa 5MB'); return; }
    const reader = new FileReader();
    reader.onload = e => {
        const dataUrl = e.target.result;
        base64Data = dataUrl.split(',')[1];
        document.getElementById('preview').src = dataUrl;
        document.getElementById('preview').classList.remove('d-none');
        document.getElementById('analyzeBtn').classList.remove('d-none');
        document.getElementById('dropZone').style.display = 'none';
    };
    reader.readAsDataURL(file);
}

function handleDrop(e) {
    e.preventDefault();
    e.currentTarget.classList.remove('drag-over');
    const file = e.dataTransfer.files[0];
    if (file?.type.startsWith('image/')) {
        document.getElementById('fileInput').files = e.dataTransfer.files;
        handleFile(document.getElementById('fileInput'));
    }
}

async function analyzeImage() {
    if (!base64Data) return;
    document.getElementById('loadingCard').classList.remove('d-none');
    document.getElementById('resultCard').classList.add('d-none');
    document.getElementById('placeholder').classList.add('d-none');
    document.getElementById('analyzeBtn').disabled = true;

    try {
        const res = await fetch('/Premium/ScanSubmit', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(base64Data)
        });
        if (!res.ok) {
            const err = await res.json().catch(() => ({ error: `Lỗi server (${res.status})` }));
            throw new Error(err.error ?? `Lỗi server (${res.status})`);
        }
        const json = await res.json();
        const data = json.data ?? json;  // unwrap {data, newToken} nếu có
        currentResult = data;

        document.getElementById('foodName').textContent   = data.foodName ?? 'Không nhận diện được';
        document.getElementById('confidence').textContent = data.confidence ? Math.round(data.confidence * 100) + '%' : '--';
        document.getElementById('totalCal').textContent   = data.calories ?? '--';
        document.getElementById('prot').textContent       = data.protein ? data.protein.toFixed(1) + 'g' : '--';
        document.getElementById('carb').textContent       = data.carb    ? data.carb.toFixed(1) + 'g'    : '--';
        document.getElementById('fat').textContent        = data.fat     ? data.fat.toFixed(1) + 'g'     : '--';

        document.getElementById('loadingCard').classList.add('d-none');
        document.getElementById('resultCard').classList.remove('d-none');

        // Nếu nhận diện được thức ăn → tự động gợi ý món ăn
        const isFood = data.foodName && data.foodName !== 'Không nhận diện được' && (data.confidence ?? 0) >= 0.4;
        if (isFood) {
            document.getElementById('ingredientLabel').textContent = data.foodName;
            document.getElementById('aiPlanSection').classList.remove('d-none');
            loadRecipeSuggestions(data.foodName);
        }
    } catch (err) {
        alert('Lỗi phân tích: ' + err.message);
        document.getElementById('loadingCard').classList.add('d-none');
        document.getElementById('placeholder').classList.remove('d-none');
    }
    document.getElementById('analyzeBtn').disabled = false;
}

let planGenController = null;

async function loadRecipeSuggestions(ingredient) {
    if (planGenController) planGenController.abort();
    planGenController = new AbortController();

    const planLoading = document.getElementById('planLoading');
    const planResult  = document.getElementById('planResult');
    planLoading.classList.remove('d-none');
    planResult.innerHTML = '';

    try {
        const res = await fetch(`/Premium/RecipeSuggest?ingredient=${encodeURIComponent(ingredient)}`, {
            signal: planGenController.signal
        });
        if (!res.ok) {
            const err = await res.json().catch(() => ({ error: `Lỗi (${res.status})` }));
            throw new Error(err.error ?? `Lỗi (${res.status})`);
        }
        const json = await res.json();
        const dishes = json.data ?? json;  // unwrap {data, newToken} nếu có
        planLoading.classList.add('d-none');
        renderRecipeSuggestions(dishes, planResult);
    } catch (err) {
        if (err.name === 'AbortError') return;
        planLoading.classList.add('d-none');
        planResult.innerHTML = `<p class="text-danger small mb-0"><i class="bi bi-exclamation-circle me-1"></i>${err.message}</p>`;
    }
}

function renderRecipeSuggestions(dishes, container) {
    if (!dishes || dishes.length === 0) {
        container.innerHTML = '<p class="text-muted small">Không tìm được gợi ý phù hợp.</p>';
        return;
    }

    const diffColor = { 'Dễ': '#16a34a', 'Trung bình': '#d97706', 'Khó': '#ef4444' };

    let html = '<div class="row g-2">';
    dishes.forEach((dish, i) => {
        const steps = (dish.steps ?? []).map(s => `<li class="small text-muted">${escHtml(s)}</li>`).join('');
        html += `
        <div class="col-12">
            <div class="rounded-3 p-3" style="background:rgba(255,255,255,.8);border:1px solid rgba(245,158,11,.2)">
                <div class="d-flex justify-content-between align-items-start mb-1">
                    <div class="fw-bold" style="color:#92400e">${escHtml(dish.dishName)}</div>
                    <div class="d-flex gap-1 flex-shrink-0 ms-2">
                        <span class="badge rounded-pill" style="background:rgba(245,158,11,.15);color:#d97706;font-size:.7rem">
                            <i class="bi bi-fire me-1"></i>${dish.calories} kcal
                        </span>
                        <span class="badge rounded-pill" style="background:rgba(22,163,74,.1);color:${diffColor[dish.difficulty] ?? '#6b7280'};font-size:.7rem">
                            ${escHtml(dish.difficulty)}
                        </span>
                    </div>
                </div>
                <p class="text-muted small mb-2">${escHtml(dish.description)}</p>
                <div class="d-flex gap-3 mb-2">
                    <span class="small text-muted"><i class="bi bi-clock me-1"></i>${escHtml(dish.prepTime)}</span>
                    <span class="small" style="color:#ef4444">P: ${dish.protein}g</span>
                    <span class="small" style="color:#f59e0b">C: ${dish.carb}g</span>
                    <span class="small" style="color:#0ea5e9">F: ${dish.fat}g</span>
                </div>
                ${steps ? `<details class="mb-2">
                    <summary class="small fw-semibold" style="cursor:pointer;color:#d97706">Cách làm</summary>
                    <ol class="mt-1 ps-3 mb-0">${steps}</ol>
                </details>` : ''}
                <div class="d-flex gap-2 align-items-center">
                    <select class="form-select form-select-sm rounded-pill" style="width:auto;font-size:.78rem" id="mealType_${i}">
                        <option value="Breakfast">🌅 Sáng</option>
                        <option value="Lunch" selected>☀️ Trưa</option>
                        <option value="Dinner">🌙 Tối</option>
                        <option value="Snack">🍎 Snack</option>
                    </select>
                    <input type="date" class="form-control form-control-sm rounded-pill" style="width:auto;font-size:.78rem"
                           id="mealDate_${i}" value="@DateTime.Today.ToString("yyyy-MM-dd")" />
                    <button class="btn btn-sm fw-semibold rounded-pill px-3"
                            style="background:linear-gradient(135deg,#f59e0b,#d97706);color:white;font-size:.78rem"
                            onclick="addSuggestedDish(${i}, '${escHtml(dish.dishName).replace(/'/g,"\\'")}', ${dish.calories})">
                        <i class="bi bi-plus-lg me-1"></i>Thêm vào lịch
                    </button>
                    <span id="addMsg_${i}" class="small d-none"></span>
                </div>
            </div>
        </div>`;
    });
    html += '</div>';
    container.innerHTML = html;
}

async function addSuggestedDish(idx, dishName, calories) {
    const mealType = document.getElementById(`mealType_${idx}`).value;
    const planDate = document.getElementById(`mealDate_${idx}`).value;
    const msg      = document.getElementById(`addMsg_${idx}`);

    const res = await fetch('/MealPlan/Add', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: new URLSearchParams({ title: dishName, mealType, planDate, calories, notes: 'Gợi ý từ AI' })
    });

    msg.classList.remove('d-none');
    if (res.ok || res.redirected) {
        msg.innerHTML = '<span class="text-success"><i class="bi bi-check-circle me-1"></i>Đã thêm!</span>';
    } else {
        msg.innerHTML = '<span class="text-danger"><i class="bi bi-x-circle me-1"></i>Lỗi!</span>';
    }
    setTimeout(() => msg.classList.add('d-none'), 3000);
}

function escHtml(s) {
    return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

async function addToMealPlan() {
    if (!currentResult) return;
    const mealType = document.getElementById('addMealType').value;
    const planDate = document.getElementById('addDate').value;
    const msg = document.getElementById('addMsg');

    const res = await fetch('/MealPlan/Add', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: new URLSearchParams({
            title:    currentResult.foodName ?? 'Món từ ảnh',
            mealType, planDate,
            calories: currentResult.calories ?? 0,
            notes:    'Phân tích bởi AI'
        })
    });

    msg.classList.remove('d-none');
    if (res.ok || res.redirected) {
        msg.innerHTML = '<span class="text-success fw-semibold"><i class="bi bi-check-circle me-1"></i>Đã thêm vào lịch ăn!</span>';
    } else {
        msg.innerHTML = '<span class="text-danger fw-semibold"><i class="bi bi-x-circle me-1"></i>Lỗi, thử lại!</span>';
    }
    setTimeout(() => msg.classList.add('d-none'), 3000);
}
</script>
}
