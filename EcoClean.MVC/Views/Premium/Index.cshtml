@{
    ViewData["Title"] = "Tính năng AI";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var role       = Context.Request.Cookies["ecoclean_role"] ?? "";
    var isPremium  = role == "Premium" || role == "Admin";
    var isLoggedIn = Context.Request.Cookies.ContainsKey("ecoclean_token");

    int freeTrialUsed = 0; const int freeTrialLimit = 10;
    try {
        var token = Context.Request.Cookies["ecoclean_token"];
        if (!string.IsNullOrEmpty(token)) {
            var parts = token.Split('.');
            if (parts.Length == 3) {
                var pad = (4 - parts[1].Length % 4) % 4;
                var b64 = parts[1].Replace('-','+').Replace('_','/') + new string('=', pad);
                var json2 = System.Text.Encoding.UTF8.GetString(Convert.FromBase64String(b64));
                using var doc2 = System.Text.Json.JsonDocument.Parse(json2);
                if (doc2.RootElement.TryGetProperty("FreeTrialUsed", out var ft2)) freeTrialUsed = ft2.GetInt32();
            }
        }
    } catch { }

    var freeTrialLeft = Math.Max(0, freeTrialLimit - freeTrialUsed);
    var canUseFree    = !isPremium && freeTrialLeft > 0;
}

<style>
:root{--paper:#EDF3E6;--paper-warm:#DEE9D4;--ink:#22301E;--ink-soft:rgba(34,48,30,.62);--ink-faint:rgba(34,48,30,.38);--herb:#4B7A4E;--herb-deep:#33552F;--herb-light:#7CA05E;--herb-tint:#E7EEE0;--line:rgba(34,48,30,.14);--serif:'Fraunces',Georgia,serif;--sans:'Inter',system-ui,sans-serif;--mono:'JetBrains Mono',monospace}
.btn-herb{background:var(--herb);color:#fff;border:none}.btn-herb:hover{background:var(--herb-deep);color:#fff}
.btn-outline-ink{border:1.5px solid var(--ink);color:var(--ink);background:transparent}.btn-outline-ink:hover{background:var(--ink);color:var(--paper)}
.stub{background:#fff;border:1px solid var(--line);border-radius:2px;transition:transform .2s ease,box-shadow .2s ease}
.stub:hover{transform:translateY(-4px);box-shadow:0 18px 40px rgba(34,48,30,.1)}
.chip{display:inline-flex;align-items:center;gap:.4rem;font-family:var(--mono);font-size:.68rem;letter-spacing:.03em;padding:.35rem .75rem;border-radius:100px;border:1px solid var(--line)}
.eyebrow{display:inline-flex;align-items:center;gap:.5rem;font-family:var(--mono);font-size:.72rem;letter-spacing:.12em;text-transform:uppercase;font-weight:600}
.rule{height:1px;background:var(--line);border:none}
</style>

<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,600;9..144,700&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet">

<div style="font-family:var(--sans);background:var(--paper);color:var(--ink)">

    <!-- Header -->
    <section style="padding:4rem 0 3rem;background:var(--paper-warm);border-bottom:1px solid var(--line)">
        <div class="container">
            <div class="eyebrow mb-3" style="color:var(--herb-deep)">
                <span style="width:6px;height:6px;border-radius:50%;background:var(--herb);display:inline-block"></span>
                Tính năng AI
            </div>
            <h1 class="fw-normal mb-3" style="font-family:var(--serif);font-size:2.4rem;letter-spacing:-.02em">
                Công nghệ AI cho hành trình Eat Clean
            </h1>
            <p style="color:var(--ink-soft);max-width:520px;font-size:1.05rem;line-height:1.75">
                Ba tính năng AI được thiết kế để giải quyết đúng vấn đề của người muốn ăn sạch tại Việt Nam.
            </p>

            @if (!isPremium && isLoggedIn)
            {
                <!-- Free trial meter -->
                <div class="d-inline-flex align-items-center gap-3 mt-4 p-3" style="background:#fff;border:1px solid var(--line);border-radius:4px">
                    <div>
                        <div class="eyebrow mb-1" style="color:var(--herb-deep)">Lượt dùng thử miễn phí</div>
                        <div style="width:200px;height:6px;background:var(--line);border-radius:100px;overflow:hidden">
                            <div style="height:100%;width:@(freeTrialUsed * 100 / freeTrialLimit)%;background:var(--herb);border-radius:100px;transition:width .4s ease"></div>
                        </div>
                    </div>
                    <div>
                        <span style="font-family:var(--serif);font-size:1.5rem;color:var(--herb-deep)">@freeTrialLeft</span>
                        <span style="font-family:var(--mono);font-size:.72rem;color:var(--ink-faint)"> / @freeTrialLimit còn lại</span>
                    </div>
                    @if (freeTrialLeft == 0)
                    {
                        <a asp-action="Payment" class="btn btn-herb rounded-1 fw-semibold px-3 py-2" style="font-size:.85rem">Nâng cấp</a>
                    }
                </div>
            }
            else if (!isLoggedIn)
            {
                <div class="mt-4 d-flex gap-3 align-items-center">
                    <a asp-controller="Account" asp-action="Register" class="btn btn-herb rounded-1 fw-semibold px-4 py-2">
                        Đăng ký — nhận 10 lượt miễn phí
                    </a>
                    <a asp-controller="Account" asp-action="Login" class="btn btn-outline-ink rounded-1 fw-semibold px-4 py-2">
                        Đăng nhập
                    </a>
                </div>
            }
        </div>
    </section>

    <!-- 3 Feature cards -->
    <section style="padding:4rem 0;background:var(--paper)">
        <div class="container">
            <div class="row g-4">

                @{
                    var features = new[]{
                        ("bi-camera-fill",    "Quét ảnh món ăn",       "Chụp ảnh bất kỳ món ăn — AI nhận diện và tính toán đầy đủ calories, protein, carb, fat ngay lập tức.",       new[]{"Nhận diện 1000+ món Việt & quốc tế","Phân tích 4 macro dinh dưỡng đầy đủ","Thêm vào lịch ăn 1 chạm"},       "Scan",   "Quét ảnh ngay"),
                        ("bi-chat-dots-fill", "Chatbot Dinh Dưỡng",    "Chuyên gia AI tư vấn Eat Clean 24/7, giải đáp mọi câu hỏi về dinh dưỡng và gợi ý thực đơn theo mục tiêu.", new[]{"Tư vấn chế độ ăn cá nhân hóa","Gợi ý món ăn theo sở thích","Lưu lịch sử hội thoại"},              "Chat",   "Chat ngay"),
                        ("bi-robot",          "Thực đơn AI cá nhân hóa","AI tạo thực đơn Eat Clean 7-14 ngày hoàn chỉnh, cá nhân hóa theo BMI, TDEE và mục tiêu của bạn.",           new[]{"Thực đơn 3-14 ngày tuỳ chọn","Tối ưu theo mục tiêu giảm/tăng cân","Món Việt dễ nấu"},         "AIPlan", "Tạo thực đơn"),
                    };
                }

                @foreach (var (icon, title, desc, features2, action, btnText) in features)
                {
                    <div class="col-md-4">
                        <div class="stub p-4 h-100 d-flex flex-column">
                            <div class="d-flex align-items-start justify-content-between mb-4">
                                <i class="bi @icon" style="font-size:1.6rem;color:var(--herb)"></i>
                                <span class="chip" style="border-color:rgba(75,122,78,.3);color:var(--herb-deep)">AI</span>
                            </div>
                            <h5 class="fw-semibold mb-2" style="font-family:var(--sans)">@title</h5>
                            <p style="color:var(--ink-soft);font-size:.9rem;line-height:1.7;flex:1">@desc</p>
                            <ul class="list-unstyled mt-3 mb-4">
                                @foreach (var f in features2)
                                {
                                    <li class="d-flex align-items-center gap-2 mb-1" style="font-size:.85rem">
                                        <i class="bi bi-check2" style="color:var(--herb)"></i>
                                        <span style="color:var(--ink-soft)">@f</span>
                                    </li>
                                }
                            </ul>
                            @if (isPremium)
                            {
                                <a asp-action="@action" class="btn btn-herb rounded-1 fw-semibold w-100 py-2">@btnText</a>
                            }
                            else if (canUseFree)
                            {
                                <a asp-action="@action" class="btn btn-herb rounded-1 fw-semibold w-100 py-2">
                                    <i class="bi bi-gift me-1"></i>Dùng thử (@freeTrialLeft lượt còn lại)
                                </a>
                            }
                            else if (!isLoggedIn)
                            {
                                <a asp-controller="Account" asp-action="Register" class="btn btn-outline-ink rounded-1 fw-semibold w-100 py-2" style="font-size:.88rem">
                                    Đăng ký để dùng thử →
                                </a>
                            }
                            else
                            {
                                <a asp-action="Payment" class="btn btn-herb rounded-1 fw-semibold w-100 py-2" style="font-size:.88rem">
                                    Nâng cấp để mở khoá →
                                </a>
                            }
                        </div>
                    </div>
                }
            </div>

            @if (!isPremium && isLoggedIn)
            {
                <div class="text-center mt-5 pt-4" style="border-top:1px solid var(--line)">
                    <p style="color:var(--ink-faint);font-family:var(--mono);font-size:.78rem;margin-bottom:1rem">Dùng hết lượt miễn phí — nâng cấp để dùng không giới hạn</p>
                    <a asp-action="Payment" class="btn btn-herb btn-lg rounded-1 fw-semibold px-5 py-3">
                        Nâng cấp Premium — từ 49.000đ/tháng
                    </a>
                </div>
            }
        </div>
    </section>
</div>
