@{
    ViewData["Title"] = "Chatbot Dinh Dưỡng";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5 text-center">
    <div class="d-inline-flex align-items-center justify-content-center rounded-3 mb-4"
         style="width:72px;height:72px;background:linear-gradient(135deg,#3b82f6,#2563eb);box-shadow:0 8px 24px rgba(59,130,246,.4)">
        <i class="bi bi-chat-dots-fill text-white" style="font-size:2rem"></i>
    </div>
    <h2 class="fw-bold mb-2">Chatbot Dinh Dưỡng AI</h2>
    <p class="text-muted mb-4">Nhấn vào nút chat ở góc phải màn hình để bắt đầu trò chuyện</p>
    <div class="d-flex justify-content-center gap-2 align-items-center">
        <div class="rounded-circle bg-success" style="width:8px;height:8px"></div>
        <span class="text-muted small">EcoClean AI đang trực tuyến</span>
    </div>
</div>

@section Scripts {
<script>
    // Tự động mở widget khi vào trang chat
    document.addEventListener('DOMContentLoaded', () => {
        setTimeout(() => {
            const btn = document.getElementById('chatWidgetToggle');
            if (btn && !document.getElementById('chatWidget').classList.contains('open')) {
                btn.click();
            }
        }, 400);
    });
</script>
}
