@{
    ViewData["Title"] = "Chatbot Dinh Dưỡng";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-4">
    <div class="d-flex align-items-center mb-4">
        <i class="bi bi-chat-dots-fill text-primary fs-2 me-3"></i>
        <div>
            <h2 class="fw-bold mb-0">Chatbot Dinh Dưỡng <span class="badge bg-warning text-dark ms-2">Premium</span></h2>
            <p class="text-muted mb-0">Chuyên gia AI tư vấn Eat Clean 24/7</p>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden" style="height:600px;display:flex;flex-direction:column">
                <!-- Chat header -->
                <div class="d-flex align-items-center gap-3 p-3 border-bottom"
                     style="background:linear-gradient(90deg,#3b82f6,#2563eb)">
                    <div class="rounded-circle bg-white d-flex align-items-center justify-content-center"
                         style="width:40px;height:40px">
                        <i class="bi bi-robot text-primary fs-5"></i>
                    </div>
                    <div class="text-white">
                        <div class="fw-bold">EcoClean AI</div>
                        <small class="opacity-75"><i class="bi bi-circle-fill text-success me-1" style="font-size:8px"></i>Trực tuyến</small>
                    </div>
                    <button class="btn btn-sm btn-outline-light ms-auto rounded-pill" onclick="clearChat()">
                        <i class="bi bi-arrow-repeat me-1"></i>Cuộc trò chuyện mới
                    </button>
                </div>

                <!-- Messages -->
                <div id="chatMessages" class="flex-grow-1 p-3 overflow-auto" style="background:#f8fafc">
                    <div class="d-flex gap-2 mb-3">
                        <div class="rounded-circle bg-primary d-flex align-items-center justify-content-center flex-shrink-0"
                             style="width:34px;height:34px">
                            <i class="bi bi-robot text-white small"></i>
                        </div>
                        <div class="bg-white shadow-sm rounded-4 rounded-start-1 p-3" style="max-width:80%">
                            <p class="mb-1">Xin chào! Tôi là EcoClean AI, chuyên gia dinh dưỡng của bạn. 🥗</p>
                            <p class="mb-0">Tôi có thể giúp bạn về:</p>
                            <ul class="mb-0 mt-1">
                                <li>Tư vấn chế độ ăn Eat Clean</li>
                                <li>Tính toán calories và dinh dưỡng</li>
                                <li>Gợi ý thực đơn theo mục tiêu</li>
                                <li>Giải đáp câu hỏi về sức khỏe</li>
                            </ul>
                        </div>
                    </div>
                </div>

                <!-- Suggestions -->
                <div id="suggestions" class="px-3 py-2 border-top bg-white d-flex gap-2 overflow-auto">
                    @foreach (var s in new[] {
                        "Thực đơn giảm cân 1 tuần?",
                        "1500 kcal/ngày nên ăn gì?",
                        "Salad tốt cho giảm cân không?",
                        "Protein nạp bao nhiêu là đủ?"
                    })
                    {
                        <button class="btn btn-sm btn-outline-primary rounded-pill text-nowrap px-3"
                                onclick="sendSuggestion('@s')">@s</button>
                    }
                </div>

                <!-- Input -->
                <div class="p-3 border-top bg-white">
                    <div class="input-group">
                        <input type="text" id="chatInput" class="form-control rounded-start-4 border-end-0"
                               placeholder="Nhập câu hỏi dinh dưỡng..."
                               onkeydown="if(event.key==='Enter')sendMessage()" />
                        <button class="btn btn-primary rounded-end-4 px-4" onclick="sendMessage()" id="sendBtn">
                            <i class="bi bi-send-fill"></i>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
let sessionId = null;

function sendSuggestion(text) {
    document.getElementById('chatInput').value = text;
    document.getElementById('suggestions').style.display = 'none';
    sendMessage();
}

async function sendMessage() {
    const input = document.getElementById('chatInput');
    const msg   = input.value.trim();
    if (!msg) return;

    addMessage(msg, 'user');
    input.value = '';
    document.getElementById('sendBtn').disabled = true;

    const typingId = addTyping();

    try {
        const res = await fetch('/Premium/ChatSend', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: new URLSearchParams({ message: msg, sessionId: sessionId ?? '' })
        });
        const data = await res.json();
        sessionId = data.sessionId;
        removeTyping(typingId);
        addMessage(data.reply, 'assistant');
    } catch (err) {
        removeTyping(typingId);
        addMessage('Xin lỗi, đã có lỗi xảy ra. Vui lòng thử lại.', 'assistant', true);
    }
    document.getElementById('sendBtn').disabled = false;
}

function addMessage(text, role, isError = false) {
    const wrap = document.getElementById('chatMessages');
    const isUser = role === 'user';
    const html = isUser
        ? `<div class="d-flex justify-content-end mb-3">
            <div class="bg-primary text-white rounded-4 rounded-end-1 p-3 shadow-sm" style="max-width:80%">${escHtml(text)}</div>
           </div>`
        : `<div class="d-flex gap-2 mb-3">
            <div class="rounded-circle ${isError ? 'bg-danger' : 'bg-primary'} d-flex align-items-center justify-content-center flex-shrink-0" style="width:34px;height:34px">
              <i class="bi bi-robot text-white small"></i>
            </div>
            <div class="bg-white shadow-sm rounded-4 rounded-start-1 p-3" style="max-width:80%">${text.replace(/\n/g,'<br>')}</div>
           </div>`;
    wrap.insertAdjacentHTML('beforeend', html);
    wrap.scrollTop = wrap.scrollHeight;
}

function addTyping() {
    const id  = 'typing_' + Date.now();
    const html = `<div id="${id}" class="d-flex gap-2 mb-3">
        <div class="rounded-circle bg-primary d-flex align-items-center justify-content-center flex-shrink-0" style="width:34px;height:34px">
          <i class="bi bi-robot text-white small"></i>
        </div>
        <div class="bg-white shadow-sm rounded-4 rounded-start-1 p-3">
          <div class="d-flex gap-1 align-items-center py-1">
            <span class="typing-dot"></span><span class="typing-dot"></span><span class="typing-dot"></span>
          </div>
        </div>
    </div>`;
    const wrap = document.getElementById('chatMessages');
    wrap.insertAdjacentHTML('beforeend', html);
    wrap.scrollTop = wrap.scrollHeight;
    return id;
}

function removeTyping(id) { document.getElementById(id)?.remove(); }

function clearChat() {
    sessionId = null;
    document.getElementById('chatMessages').innerHTML = '';
    document.getElementById('suggestions').style.display = 'flex';
    addMessage('Cuộc trò chuyện mới đã bắt đầu. Tôi có thể giúp gì cho bạn?', 'assistant');
}

function escHtml(s) {
    return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}
</script>
    <style>
        .typing-dot {
            width: 8px;
            height: 8px;
            background: #94a3b8;
            border-radius: 50%;
            animation: bounce .8s infinite;
        }

            .typing-dot:nth-child(2) {
                animation-delay: .15s
            }

            .typing-dot:nth-child(3) {
                animation-delay: .3s
            }

        @@keyframes bounce {
            0%, 60%, 100% {
                transform: translateY(0)
            }

            30% {
                transform: translateY(-8px)
            }
        }
    </style>
}
