@{
    ViewData["Title"] = "Thực đơn AI";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,600;9..144,700&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet">
<style>
:root{--paper:#EDF3E6;--paper-warm:#DEE9D4;--ink:#22301E;--ink-soft:rgba(34,48,30,.62);--ink-faint:rgba(34,48,30,.38);--herb:#4B7A4E;--herb-deep:#33552F;--herb-tint:#E7EEE0;--line:rgba(34,48,30,.14);--serif:'Fraunces',Georgia,serif;--mono:'JetBrains Mono',monospace}
.btn-herb{background:var(--herb)!important;color:#fff!important;border:none!important}.btn-herb:hover{background:var(--herb-deep)!important}
</style>

<div class="container py-4" style="font-family:'Inter',system-ui,sans-serif;color:var(--ink)">
    <div style="border-bottom:1px solid var(--line);padding-bottom:1.5rem;margin-bottom:1.75rem">
        <div style="font-family:var(--mono);font-size:.72rem;letter-spacing:.1em;text-transform:uppercase;color:var(--ink-faint);margin-bottom:.5rem">Tính năng AI</div>
        <h1 style="font-family:var(--serif);font-weight:600;font-size:1.9rem;letter-spacing:-.02em;margin:0">Thực đơn AI</h1>
        <p style="color:var(--ink-soft);font-size:.95rem;margin-top:.35rem;margin-bottom:0">AI tạo thực đơn Eat Clean cá nhân hóa theo mục tiêu của bạn</p>
    </div>

    <div class="row g-4">
        <!-- Config Form -->
        <div class="col-md-4">
            <div class="card border-0 p-4" style="border-radius:20px !important">
                <h5 class="fw-bold mb-4">
                    <i class="bi bi-sliders me-2" style="color:#f59e0b"></i>Thiết lập thực đơn
                </h5>

                <div class="mb-4">
                    <label class="form-label">Mục tiêu</label>
                    <div class="d-flex flex-column gap-2">
                        @foreach (var (val, lbl, icon, color, bg) in new[] {
                            ("LoseWeight","Giảm cân",  "bi-arrow-down-circle","#22c55e","rgba(34,197,94,.08)"),
                            ("Maintain",  "Giữ dáng",  "bi-dash-circle",      "#3b82f6","rgba(59,130,246,.08)"),
                            ("GainWeight","Tăng cân",  "bi-arrow-up-circle",  "#ef4444","rgba(239,68,68,.08)")
                        })
                        {
                            <label class="d-flex align-items-center gap-3 p-3 rounded-3 goal-opt"
                                   style="cursor:pointer;border:1.5px solid #e2e8f0;transition:all .15s"
                                   onmouseover="this.style.borderColor='@color'"
                                   onmouseout="if(!this.querySelector('input').checked)this.style.borderColor='#e2e8f0'">
                                <input type="radio" name="goal" value="@val" class="form-check-input"
                                       @(val == "LoseWeight" ? "checked" : "")
                                       onchange="highlightGoal(this)" />
                                <div class="rounded-2 d-flex align-items-center justify-content-center"
                                     style="width:34px;height:34px;background:@bg;color:@color;flex-shrink:0">
                                    <i class="bi @icon"></i>
                                </div>
                                <span class="fw-semibold">@lbl</span>
                            </label>
                        }
                    </div>
                </div>

                <div class="mb-4">
                    <label class="form-label">Số ngày</label>
                    <div class="d-flex gap-2">
                        @foreach (var d in new[] { 3, 5, 7, 14 })
                        {
                            <button type="button"
                                    class="btn btn-sm rounded-pill flex-fill fw-semibold day-btn @(d == 7 ? "active" : "")"
                                    style="border:1.5px solid #e2e8f0;@(d == 7 ? "background:linear-gradient(135deg,#f59e0b,#d97706);color:white;border-color:transparent" : "background:transparent;color:#64748b")"
                                    onclick="selectDays(@d, this)">@d ngày</button>
                        }
                    </div>
                </div>

                <button id="generateBtn" class="btn btn-herb w-100 py-2 fw-semibold rounded-1"
                        onclick="generatePlan()">
                    Tạo thực đơn với AI
                </button>
            </div>
        </div>

        <!-- Result -->
        <div class="col-md-8">
            <!-- Placeholder -->
            <div id="planPlaceholder" class="card border-0 p-5 text-center" style="border-radius:20px !important">
                <div class="d-inline-flex align-items-center justify-content-center rounded-3 mb-3 mx-auto"
                     style="width:64px;height:64px;background:rgba(245,158,11,.08)">
                    <i class="bi bi-calendar-week text-warning" style="font-size:2rem"></i>
                </div>
                <h5 class="fw-bold mb-2">Chọn mục tiêu và nhấn tạo thực đơn</h5>
                <p class="text-muted small mb-0">AI sẽ tạo thực đơn Eat Clean phù hợp với chỉ số BMI và TDEE của bạn</p>
            </div>

            <!-- Loading -->
            <div id="planLoading" class="card border-0 p-5 text-center d-none" style="border-radius:20px !important">
                <div class="d-inline-flex align-items-center justify-content-center rounded-circle mb-3 mx-auto"
                     style="width:64px;height:64px;background:rgba(245,158,11,.1)">
                    <div class="spinner-border text-warning" style="width:2rem;height:2rem"></div>
                </div>
                <h5 class="fw-bold">AI đang tạo thực đơn...</h5>
                <p class="text-muted small">Đang tính toán dinh dưỡng cá nhân hóa cho bạn</p>
                <div class="progress rounded-pill mt-3" style="height:6px">
                    <div id="genProgress" class="progress-bar progress-bar-striped progress-bar-animated"
                         style="width:0%;background:linear-gradient(135deg,#f59e0b,#d97706)"></div>
                </div>
            </div>

            <!-- Plan display -->
            <div id="planResult" class="d-none">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="fw-bold mb-0" id="planTitle"></h5>
                    <button class="btn btn-outline-herb btn-sm rounded-1 fw-semibold"
                            style="border:1.5px solid var(--herb);color:var(--herb);background:transparent"
                            onclick="generatePlan()">
                        <i class="bi bi-arrow-repeat me-1"></i>Tạo lại
                    </button>
                </div>
                <div id="planDays" class="accordion rounded-4 overflow-hidden shadow-sm"></div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
let selectedDays = 7;

function selectDays(d, btn) {
    selectedDays = d;
    document.querySelectorAll('.day-btn').forEach(b => {
        b.style.background = 'transparent';
        b.style.color = '#64748b';
        b.style.borderColor = '#e2e8f0';
    });
    btn.style.background = 'linear-gradient(135deg,#f59e0b,#d97706)';
    btn.style.color = 'white';
    btn.style.borderColor = 'transparent';
}

function highlightGoal(input) {
    document.querySelectorAll('.goal-opt').forEach(l => {
        l.style.borderColor = '#e2e8f0';
        l.style.background = 'transparent';
    });
    const label = input.closest('.goal-opt');
    label.style.borderColor = '#f59e0b';
    label.style.background = 'rgba(245,158,11,.04)';
}

// Highlight default
document.querySelector('input[name="goal"]:checked')?.dispatchEvent(new Event('change'));

async function generatePlan() {
    const goal = document.querySelector('input[name="goal"]:checked')?.value ?? 'LoseWeight';
    document.getElementById('planPlaceholder').classList.add('d-none');
    document.getElementById('planResult').classList.add('d-none');
    document.getElementById('planLoading').classList.remove('d-none');
    document.getElementById('generateBtn').disabled = true;

    const prog = document.getElementById('genProgress');
    let pct = 0;
    const interval = setInterval(() => { pct = Math.min(pct + 8, 90); prog.style.width = pct + '%'; }, 400);

    try {
        const res  = await fetch('/Premium/AIPlanGenerate', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: new URLSearchParams({ goal, durationDays: selectedDays })
        });
        if (!res.ok) {
            const err = await res.json().catch(() => ({ error: `Lỗi server (${res.status})` }));
            throw new Error(err.error ?? `Lỗi server (${res.status})`);
        }
        const json  = await res.json();
        const data  = json.data ?? json;  // unwrap {data, newToken} nếu có
        clearInterval(interval);
        prog.style.width = '100%';

        document.getElementById('planTitle').textContent = data.title ?? `Thực đơn ${selectedDays} ngày`;
        renderPlan(data);

        setTimeout(() => {
            document.getElementById('planLoading').classList.add('d-none');
            document.getElementById('planResult').classList.remove('d-none');
        }, 500);
    } catch (e) {
        clearInterval(interval);
        alert('Lỗi tạo thực đơn: ' + e.message);
        document.getElementById('planLoading').classList.add('d-none');
        document.getElementById('planPlaceholder').classList.remove('d-none');
    }
    document.getElementById('generateBtn').disabled = false;
}

function renderPlan(data) {
    let planObj;
    try {
        const raw = typeof data.planJson === 'string' ? data.planJson : JSON.stringify(data.planJson);
        const clean = raw.replace(/^```json\s*/,'').replace(/\s*```$/,'').trim();
        planObj = JSON.parse(clean);
    } catch { planObj = null; }

    const container = document.getElementById('planDays');
    container.innerHTML = '';

    if (!planObj?.days) {
        container.innerHTML = `<div class="alert alert-info rounded-4">
            <pre class="mb-0 small">${escHtml(data.planJson ?? '')}</pre></div>`;
        return;
    }

    const mealColors = { breakfast:'#f59e0b', lunch:'#22c55e', dinner:'#8b5cf6', snack:'#0ea5e9' };
    const mealBgs    = { breakfast:'rgba(245,158,11,.1)', lunch:'rgba(34,197,94,.1)', dinner:'rgba(139,92,246,.1)', snack:'rgba(14,165,233,.1)' };
    const mealNames  = { breakfast:'Bữa sáng', lunch:'Bữa trưa', dinner:'Bữa tối', snack:'Snack' };

    planObj.days.forEach((day, i) => {
        const id = `day${i}`;
        const meals = ['breakfast','lunch','dinner','snack'];
        const mealHtml = meals.map(m => {
            const md = day[m];
            if (!md) return '';
            return `<div class="d-flex justify-content-between align-items-center py-2 px-4"
                         style="border-bottom:1px solid rgba(226,232,240,.5)">
                <div class="d-flex align-items-center gap-2">
                    <span class="badge rounded-pill px-2" style="background:${mealBgs[m]};color:${mealColors[m]};font-size:.72rem">${mealNames[m]}</span>
                    <span class="fw-semibold small">${escHtml(md.name ?? '')}</span>
                </div>
                <div class="text-end small text-muted">
                    <span class="fw-bold" style="color:#16a34a">${md.calories ?? '--'}kcal</span>
                    <span class="ms-2">P:${md.protein ?? '-'}g C:${md.carb ?? '-'}g F:${md.fat ?? '-'}g</span>
                </div>
            </div>`;
        }).join('');

        container.insertAdjacentHTML('beforeend', `
            <div class="accordion-item border-0" style="border-bottom:1px solid #f1f5f9">
                <h2 class="accordion-header">
                    <button class="accordion-button ${i > 0 ? 'collapsed' : ''} fw-bold" type="button"
                            data-bs-toggle="collapse" data-bs-target="#${id}"
                            style="font-size:.9rem">
                        <i class="bi bi-calendar-day me-2" style="color:#f59e0b"></i>
                        Ngày ${day.day}
                        <span class="ms-auto me-3 badge rounded-pill px-2"
                              style="background:rgba(245,158,11,.1);color:#d97706;font-size:.75rem">
                            ${day.totalCalories ?? '--'} kcal
                        </span>
                    </button>
                </h2>
                <div id="${id}" class="accordion-collapse collapse ${i === 0 ? 'show' : ''}">
                    <div class="accordion-body p-0">${mealHtml}</div>
                </div>
            </div>`);
    });
}

function escHtml(s) {
    return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}
</script>
}
