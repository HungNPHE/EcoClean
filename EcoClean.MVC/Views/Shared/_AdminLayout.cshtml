<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — EcoClean Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <style>
        :root {
            --sidebar-w: 260px;
            --sidebar-bg: #0f172a;
            --sidebar-border: rgba(255,255,255,.06);
            --sidebar-hover: rgba(255,255,255,.07);
            --sidebar-active: rgba(22,163,74,.18);
            --sidebar-active-text: #4ade80;
            --topbar-h: 64px;
            --eco-green: #16a34a;
            --eco-green-light: #22c55e;
        }

        * { box-sizing: border-box; }

        body {
            font-family: 'Inter', system-ui, sans-serif;
            background: #f1f5f9;
            color: #0f172a;
            -webkit-font-smoothing: antialiased;
        }

        /* ── Sidebar ─────────────────────────────────────────── */
        .sidebar {
            width: var(--sidebar-w);
            min-height: 100vh;
            background: var(--sidebar-bg);
            position: fixed;
            top: 0; left: 0;
            z-index: 200;
            display: flex;
            flex-direction: column;
            border-right: 1px solid var(--sidebar-border);
        }

        .sidebar-brand {
            padding: 1.25rem 1.5rem;
            border-bottom: 1px solid var(--sidebar-border);
            display: flex;
            align-items: center;
            gap: .75rem;
        }

        .sidebar-brand .brand-logo {
            width: 38px;
            height: 38px;
            background: linear-gradient(135deg, #16a34a, #22c55e);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 1.1rem;
            box-shadow: 0 2px 10px rgba(22,163,74,.4);
            flex-shrink: 0;
        }

        .sidebar-brand .brand-text {
            font-size: 1.1rem;
            font-weight: 800;
            color: white;
            letter-spacing: -0.03em;
            line-height: 1.2;
        }

        .sidebar-brand .brand-sub {
            font-size: .65rem;
            font-weight: 600;
            color: #ef4444;
            background: rgba(239,68,68,.15);
            padding: .1rem .45rem;
            border-radius: 4px;
            letter-spacing: .05em;
            text-transform: uppercase;
        }

        .sidebar-section {
            padding: .5rem 1rem .25rem;
            font-size: .65rem;
            font-weight: 700;
            color: #475569;
            text-transform: uppercase;
            letter-spacing: .1em;
            margin-top: .5rem;
        }

        .sidebar nav { padding: .75rem .75rem 0; flex: 1; }

        .sidebar .nav-link {
            color: #94a3b8;
            padding: .65rem .9rem;
            border-radius: 10px;
            font-size: .875rem;
            font-weight: 500;
            display: flex;
            align-items: center;
            gap: .65rem;
            transition: all .15s ease;
            margin-bottom: 2px;
        }

        .sidebar .nav-link i {
            font-size: 1rem;
            width: 20px;
            text-align: center;
            flex-shrink: 0;
        }

        .sidebar .nav-link:hover {
            color: #e2e8f0;
            background: var(--sidebar-hover);
        }

        .sidebar .nav-link.active {
            color: var(--sidebar-active-text);
            background: var(--sidebar-active);
            font-weight: 600;
        }

        .sidebar .nav-link.active i { color: var(--eco-green-light); }

        .sidebar-divider {
            border-color: var(--sidebar-border);
            margin: .75rem 1rem;
        }

        .sidebar-footer {
            padding: 1rem 1.25rem;
            border-top: 1px solid var(--sidebar-border);
        }

        .sidebar-user {
            display: flex;
            align-items: center;
            gap: .65rem;
        }

        .sidebar-user .avatar {
            width: 34px;
            height: 34px;
            background: linear-gradient(135deg, #334155, #475569);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #94a3b8;
            font-size: .9rem;
            flex-shrink: 0;
        }

        .sidebar-user .user-info { min-width: 0; }
        .sidebar-user .user-name {
            font-size: .8rem;
            font-weight: 600;
            color: #e2e8f0;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }
        .sidebar-user .user-role {
            font-size: .7rem;
            color: #64748b;
        }

        /* ── Topbar ──────────────────────────────────────────── */
        .topbar {
            height: var(--topbar-h);
            background: white;
            border-bottom: 1px solid #e2e8f0;
            position: fixed;
            top: 0;
            left: var(--sidebar-w);
            right: 0;
            z-index: 100;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 2rem;
            box-shadow: 0 1px 3px rgba(0,0,0,.04);
        }

        .topbar-title {
            font-size: 1rem;
            font-weight: 700;
            color: #0f172a;
            letter-spacing: -0.01em;
        }

        .topbar-actions { display: flex; align-items: center; gap: .75rem; }

        /* ── Main content ────────────────────────────────────── */
        .main-wrap {
            margin-left: var(--sidebar-w);
            padding-top: var(--topbar-h);
            min-height: 100vh;
        }

        .main-content {
            padding: 2rem;
            max-width: 1400px;
        }

        /* ── Stat cards ──────────────────────────────────────── */
        .stat-card {
            background: white;
            border: 1px solid #e2e8f0;
            border-radius: 14px;
            padding: 1.25rem;
            transition: all .2s ease;
            box-shadow: 0 1px 3px rgba(0,0,0,.04);
        }

        .stat-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(0,0,0,.08);
        }

        .stat-icon {
            width: 46px;
            height: 46px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.2rem;
        }

        /* ── Tables ──────────────────────────────────────────── */
        .table-card {
            background: white;
            border: 1px solid #e2e8f0;
            border-radius: 14px;
            overflow: hidden;
            box-shadow: 0 1px 3px rgba(0,0,0,.04);
        }

        .table thead th {
            background: #f8fafc;
            font-size: .75rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .07em;
            color: #94a3b8;
            border-bottom: 1px solid #e2e8f0;
            padding: .9rem 1.1rem;
        }

        .table tbody td {
            padding: .85rem 1.1rem;
            border-bottom: 1px solid rgba(226,232,240,.5);
            font-size: .875rem;
            vertical-align: middle;
        }

        .table-hover tbody tr:hover td { background: rgba(22,163,74,.025); }

        /* ── Cards ───────────────────────────────────────────── */
        .content-card {
            background: white;
            border: 1px solid #e2e8f0;
            border-radius: 14px;
            box-shadow: 0 1px 3px rgba(0,0,0,.04);
        }

        /* ── Badges ──────────────────────────────────────────── */
        .badge { font-weight: 600; letter-spacing: .02em; }

        /* ── Forms ───────────────────────────────────────────── */
        .form-control, .form-select {
            border: 1.5px solid #e2e8f0;
            border-radius: 8px;
            font-size: .875rem;
            transition: all .15s;
        }

        .form-control:focus, .form-select:focus {
            border-color: var(--eco-green);
            box-shadow: 0 0 0 3px rgba(22,163,74,.1);
        }

        .form-label {
            font-size: .8rem;
            font-weight: 600;
            color: #64748b;
            margin-bottom: .35rem;
        }

        /* ── Buttons ─────────────────────────────────────────── */
        .btn { font-weight: 600; font-size: .875rem; transition: all .15s; }

        /* ── Alerts ──────────────────────────────────────────── */
        .alert { border: none; border-radius: 10px; font-size: .875rem; }

        /* ── Pagination ──────────────────────────────────────── */
        .page-link {
            border-radius: 8px !important;
            margin: 0 2px;
            font-size: .875rem;
            font-weight: 500;
            border-color: #e2e8f0;
            color: #64748b;
        }

        .page-item.active .page-link {
            background: var(--eco-green);
            border-color: var(--eco-green);
        }

        /* ── Modal ───────────────────────────────────────────── */
        .modal-content {
            border: none;
            border-radius: 16px;
            box-shadow: 0 20px 60px rgba(0,0,0,.2);
        }

        /* ── Scrollbar ───────────────────────────────────────── */
        ::-webkit-scrollbar { width: 5px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 3px; }

        /* ── Animations ──────────────────────────────────────── */
        .main-content { animation: fadeUp .25s ease; }
        @@keyframes fadeUp {
            from { opacity: 0; transform: translateY(6px); }
            to   { opacity: 1; transform: translateY(0); }
        }
    </style>
</head>
<body>

<!-- ── Sidebar ─────────────────────────────────────────────── -->
<aside class="sidebar">
    <div class="sidebar-brand">
        <div class="brand-logo"><i class="bi bi-leaf-fill"></i></div>
        <div>
            <div class="brand-text">EcoClean</div>
            <div class="brand-sub">Admin</div>
        </div>
    </div>

    <nav class="nav flex-column">
        <div class="sidebar-section">Tổng quan</div>
        <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString()=="Index"?"active":"")"
           asp-controller="Admin" asp-action="Index">
            <i class="bi bi-speedometer2"></i>Dashboard
        </a>

        <div class="sidebar-section">Quản lý</div>
        <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() is "Users" or "UserDetail" ?"active":"")"
           asp-controller="Admin" asp-action="Users">
            <i class="bi bi-people"></i>Người dùng
        </a>
        <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString()=="Recipes"?"active":"")"
           asp-controller="Admin" asp-action="Recipes">
            <i class="bi bi-journal-richtext"></i>Công thức
        </a>
        <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString()=="Subscriptions"?"active":"")"
           asp-controller="Admin" asp-action="Subscriptions">
            <i class="bi bi-credit-card"></i>Thanh toán
        </a>

        <hr class="sidebar-divider" />
        <a class="nav-link" asp-controller="Home" asp-action="Index">
            <i class="bi bi-arrow-left"></i>Về trang chủ
        </a>
    </nav>

    <div class="sidebar-footer">
        <div class="sidebar-user">
            <div class="avatar"><i class="bi bi-person-fill"></i></div>
            <div class="user-info">
                <div class="user-name">@Context.Request.Cookies["ecoclean_name"]</div>
                <div class="user-role">Administrator</div>
            </div>
        </div>
    </div>
</aside>

<!-- ── Topbar ───────────────────────────────────────────────── -->
<div class="topbar">
    <div class="topbar-title">
        <i class="bi bi-grid-3x3-gap me-2 text-secondary" style="font-size:.9rem"></i>
        @ViewData["Title"]
    </div>
    <div class="topbar-actions">
        <a asp-controller="Account" asp-action="Logout"
           class="btn btn-sm btn-outline-danger rounded-pill px-3">
            <i class="bi bi-box-arrow-right me-1"></i>Đăng xuất
        </a>
    </div>
</div>

<!-- ── Main ─────────────────────────────────────────────────── -->
<div class="main-wrap">
    <div class="main-content">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success d-flex align-items-center gap-2 mb-4 shadow-sm">
                <i class="bi bi-check-circle-fill fs-5"></i>
                <span>@TempData["Success"]</span>
                <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger d-flex align-items-center gap-2 mb-4 shadow-sm">
                <i class="bi bi-exclamation-triangle-fill fs-5"></i>
                <span>@TempData["Error"]</span>
                <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
            </div>
        }
        @RenderBody()
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
