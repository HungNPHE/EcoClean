<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — EcoClean</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

@{
    // Decode free trial từ JWT cookie
    int layoutFreeTrialUsed = 0;
    const int layoutFreeTrialLimit = 10;
    var layoutRole = Context.Request.Cookies["ecoclean_role"] ?? "";
    var layoutIsPremium = layoutRole == "Premium" || layoutRole == "Admin";
    try {
        var tok = Context.Request.Cookies["ecoclean_token"];
        if (!string.IsNullOrEmpty(tok)) {
            var parts = tok.Split('.');
            if (parts.Length == 3) {
                var pad = (4 - parts[1].Length % 4) % 4;
                var b64 = parts[1].Replace('-','+').Replace('_','/') + new string('=', pad);
                var json2 = System.Text.Encoding.UTF8.GetString(Convert.FromBase64String(b64));
                using var doc2 = System.Text.Json.JsonDocument.Parse(json2);
                if (doc2.RootElement.TryGetProperty("FreeTrialUsed", out var ft2))
                    layoutFreeTrialUsed = ft2.GetInt32();
            }
        }
    } catch { }
    var layoutFreeLeft = Math.Max(0, layoutFreeTrialLimit - layoutFreeTrialUsed);
    var layoutCanUseFree = !layoutIsPremium && layoutFreeLeft > 0 && Context.Request.Cookies.ContainsKey("ecoclean_token");
}

<!-- ── Free trial banner (chỉ hiện khi đã login, chưa premium, còn lượt) -->
@if (layoutCanUseFree && layoutFreeLeft <= 5)
{
    <div class="text-center py-2 px-3" style="background:linear-gradient(90deg,#92400e,#d97706,#92400e);font-size:.82rem;color:white;font-weight:600;letter-spacing:.01em">
        <i class="bi bi-gift-fill me-1"></i>
        Bạn còn <strong>@layoutFreeLeft / @layoutFreeTrialLimit lượt dùng thử</strong> tính năng AI miễn phí —
        <a href="/Premium/Payment" style="color:white;text-decoration:underline">Nâng cấp Premium</a> để dùng không giới hạn
    </div>
}

<!-- ── Navbar ──────────────────────────────────────────────── -->
<nav class="navbar navbar-expand-lg navbar-eco">
    <div class="container">
        <a class="navbar-brand d-flex align-items-center gap-2" href="/">
            <img src="/images/logo.png" alt="EcoClean" style="height:36px;width:auto;object-fit:contain;mix-blend-mode:darken;background:transparent">
            EcoClean
        </a>

        <button class="navbar-toggler border-0 shadow-none" type="button"
                data-bs-toggle="collapse" data-bs-target="#navMenu">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navMenu">
            <ul class="navbar-nav me-auto gap-1 ms-2" style="font-size:.875rem">
                <li class="nav-item">
                    <a class="nav-link px-2" asp-controller="Home" asp-action="Index">
                        <i class="bi bi-house me-1"></i><span class="d-none d-xl-inline">Trang chủ</span><span class="d-xl-none">Home</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link px-2" asp-controller="Recipe" asp-action="Index">
                        <i class="bi bi-journal-richtext me-1"></i>Công thức
                    </a>
                </li>
                @if (Context.Request.Cookies.ContainsKey("ecoclean_token"))
                {
                    <li class="nav-item">
                        <a class="nav-link px-2" asp-controller="Dashboard" asp-action="Index">
                            <i class="bi bi-speedometer2 me-1"></i>Dashboard
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link px-2" asp-controller="MealPlan" asp-action="Index">
                            <i class="bi bi-calendar3 me-1"></i>Lịch ăn
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link px-2" asp-controller="Weight" asp-action="Index">
                            <i class="bi bi-graph-up me-1"></i>Cân nặng
                        </a>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link px-2 dropdown-toggle" href="#" data-bs-toggle="dropdown">
                            <i class="bi bi-stars me-1" style="color:#f59e0b"></i>AI
                            @if (layoutCanUseFree)
                            {
                                <span class="badge rounded-pill ms-1"
                                      style="background:@(layoutFreeLeft <= 3 ? "#ef4444" : "#f59e0b");color:white;font-size:.62rem;padding:.2em .45em">
                                    @layoutFreeLeft
                                </span>
                            }
                        </a>
                        <ul class="dropdown-menu" style="min-width:240px">
                            <li>
                                <a class="dropdown-item d-flex align-items-center gap-2" asp-controller="Premium" asp-action="Scan">
                                    <div class="rounded-2 d-flex align-items-center justify-content-center flex-shrink-0"
                                         style="width:28px;height:28px;background:rgba(245,158,11,.12)">
                                        <i class="bi bi-camera-fill" style="color:#d97706;font-size:.8rem"></i>
                                    </div>
                                    <div>
                                        <div class="fw-semibold" style="font-size:.85rem">Quét ảnh món ăn</div>
                                        <div class="text-muted" style="font-size:.72rem">AI nhận diện dinh dưỡng</div>
                                    </div>
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item d-flex align-items-center gap-2" asp-controller="Premium" asp-action="Chat">
                                    <div class="rounded-2 d-flex align-items-center justify-content-center flex-shrink-0"
                                         style="width:28px;height:28px;background:rgba(59,130,246,.1)">
                                        <i class="bi bi-chat-dots-fill" style="color:#3b82f6;font-size:.8rem"></i>
                                    </div>
                                    <div>
                                        <div class="fw-semibold" style="font-size:.85rem">Chatbot dinh dưỡng</div>
                                        <div class="text-muted" style="font-size:.72rem">Tư vấn Eat Clean 24/7</div>
                                    </div>
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item d-flex align-items-center gap-2" asp-controller="Premium" asp-action="AIPlan">
                                    <div class="rounded-2 d-flex align-items-center justify-content-center flex-shrink-0"
                                         style="width:28px;height:28px;background:rgba(22,163,74,.1)">
                                        <i class="bi bi-robot" style="color:#16a34a;font-size:.8rem"></i>
                                    </div>
                                    <div>
                                        <div class="fw-semibold" style="font-size:.85rem">Thực đơn AI</div>
                                        <div class="text-muted" style="font-size:.72rem">Cá nhân hóa 7-14 ngày</div>
                                    </div>
                                </a>
                            </li>
                            <li><hr class="dropdown-divider my-1"></li>
                            @if (layoutCanUseFree)
                            {
                                <li>
                                    <div class="px-3 py-2">
                                        <div class="d-flex justify-content-between align-items-center mb-1">
                                            <span style="font-size:.76rem;color:#64748b;font-weight:600">Lượt dùng thử miễn phí</span>
                                            <span style="font-size:.76rem;font-weight:700;color:@(layoutFreeLeft <= 3 ? "#ef4444" : "#d97706")">@layoutFreeLeft / @layoutFreeTrialLimit</span>
                                        </div>
                                        <div class="rounded-pill overflow-hidden" style="height:5px;background:#e2e8f0">
                                            <div class="rounded-pill" style="height:100%;width:@(layoutFreeTrialUsed * 100 / layoutFreeTrialLimit)%;background:@(layoutFreeLeft <= 3 ? "linear-gradient(90deg,#ef4444,#f87171)" : "linear-gradient(90deg,#22c55e,#f59e0b)")"></div>
                                        </div>
                                    </div>
                                </li>
                                <li>
                                    <a class="dropdown-item text-center rounded-2 mx-2 mb-1 fw-semibold"
                                       asp-controller="Premium" asp-action="Payment"
                                       style="background:linear-gradient(135deg,#f59e0b,#d97706);color:white;font-size:.8rem">
                                        <i class="bi bi-stars me-1"></i>Nâng cấp Premium — không giới hạn
                                    </a>
                                </li>
                            }
                            else if (!layoutIsPremium)
                            {
                                <li>
                                    <a class="dropdown-item text-center rounded-2 mx-2 mb-1 fw-semibold"
                                       asp-controller="Premium" asp-action="Payment"
                                       style="background:linear-gradient(135deg,#f59e0b,#d97706);color:white;font-size:.8rem">
                                        <i class="bi bi-stars me-1"></i>Nâng cấp Premium
                                    </a>
                                </li>
                            }
                        </ul>
                    </li>
                }
            </ul>

            <ul class="navbar-nav align-items-center gap-2">
                @if (Context.Request.Cookies.ContainsKey("ecoclean_token"))
                {
                    <li class="nav-item">
                        <div class="user-chip">
                            @{
                                var navName = Context.Request.Cookies["ecoclean_name"] ?? "";
                                var initials = navName.Length > 0
                                    ? string.Concat(navName.Split(' ', System.StringSplitOptions.RemoveEmptyEntries)
                                        .Take(2).Select(w => w[0].ToString().ToUpper()))
                                    : "U";
                                var avatarColors = new[] { "#16a34a","#3b82f6","#8b5cf6","#ef4444","#f59e0b","#0ea5e9","#ec4899" };
                                var avatarColor  = avatarColors[Math.Abs(navName.GetHashCode()) % avatarColors.Length];
                            }
                            <span class="d-inline-flex align-items-center justify-content-center rounded-circle fw-bold"
                                  style="width:26px;height:26px;background:@avatarColor;color:white;font-size:.7rem;flex-shrink:0">@initials</span>
                            <span class="d-none d-xl-inline">@navName</span>
                            @if (layoutIsPremium && layoutRole != "Admin")
                            {
                                <span class="badge-premium">PRO</span>
                            }
                            @if (layoutRole == "Admin")
                            {
                                <span class="badge-admin">ADMIN</span>
                            }
                        </div>
                    </li>
                    @if (layoutRole == "Admin")
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Admin" asp-action="Index"
                               style="color:#ef4444 !important;font-weight:600">
                                <i class="bi bi-shield-lock-fill me-1"></i>Admin
                            </a>
                        </li>
                    }
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Account" asp-action="Logout"
                           style="color:var(--text-muted)">
                            <i class="bi bi-box-arrow-right me-1"></i>Đăng xuất
                        </a>
                    </li>
                }
                else
                {
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Account" asp-action="Login">Đăng nhập</a>
                    </li>
                    <li class="nav-item">
                        <a class="btn-nav-login nav-link" asp-controller="Account" asp-action="Register">
                            <i class="bi bi-person-plus me-1"></i>Đăng ký miễn phí
                        </a>
                    </li>
                }
            </ul>
        </div>
    </div>
</nav>

<main>
    @RenderBody()
</main>

<!-- ── Footer ──────────────────────────────────────────────── -->
<footer class="footer-eco">
    <div class="container">
        <div class="row g-4 mb-4">
            <div class="col-md-4">
                <div class="footer-brand mb-2 d-flex align-items-center gap-2">
                    <img src="/images/logo.png" alt="EcoClean" style="mix-blend-mode:multiply;height:28px;width:auto;border-radius:6px;object-fit:contain">
                    EcoClean
                </div>
                <p class="small mb-0" style="color:#64748b">
                    Hệ thống quản lý chế độ ăn Eat Clean thông minh,<br>
                    cá nhân hóa bởi AI.
                </p>
            </div>
            <div class="col-md-4">
                <div class="fw-semibold text-white mb-2 small">Tính năng</div>
                <ul class="list-unstyled small" style="color:#64748b">
                    <li class="mb-1"><a href="/Recipe" class="text-decoration-none" style="color:inherit">Thư viện công thức</a></li>
                    <li class="mb-1"><a href="/MealPlan" class="text-decoration-none" style="color:inherit">Lịch ăn uống</a></li>
                    <li class="mb-1"><a href="/Weight" class="text-decoration-none" style="color:inherit">Theo dõi cân nặng</a></li>
                    <li class="mb-1"><a href="/Premium" class="text-decoration-none" style="color:inherit">Tính năng Premium AI</a></li>
                </ul>
            </div>
            <div class="col-md-4">
                <div class="fw-semibold text-white mb-2 small">Tài khoản</div>
                <ul class="list-unstyled small" style="color:#64748b">
                    <li class="mb-1"><a href="/Account/Login" class="text-decoration-none" style="color:inherit">Đăng nhập</a></li>
                    <li class="mb-1"><a href="/Account/Register" class="text-decoration-none" style="color:inherit">Đăng ký miễn phí</a></li>
                    <li class="mb-1"><a href="/Premium/Payment" class="text-decoration-none" style="color:inherit">Nâng cấp Premium</a></li>
                </ul>
            </div>
        </div>
        <hr style="border-color:#1e293b;margin:0 0 1rem">
        <div class="text-center small" style="color:#475569">
            <img src="/images/logo.png" alt="EcoClean" style="mix-blend-mode:multiply;height:18px;width:auto;border-radius:4px;vertical-align:middle;margin-right:4px">
            EcoClean &copy; @DateTime.Now.Year — Healthy Eat Clean Management
        </div>
    </div>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)

@if (Context.Request.Cookies.ContainsKey("ecoclean_token"))
{
    @* ── Chatbot Widget ── *@
    var widgetUserName = Context.Request.Cookies["ecoclean_name"] ?? "bạn";
    <style>
    #chatWidget {
        position:fixed; bottom:24px; right:24px; z-index:9999;
        display:flex; flex-direction:column; align-items:flex-end; gap:12px;
    }
    #chatWidgetBox {
        width:360px; height:520px;
        background:white; border-radius:20px;
        box-shadow:0 20px 60px rgba(0,0,0,.18);
        display:flex; flex-direction:column; overflow:hidden;
        transform:scale(.92) translateY(20px);
        opacity:0; pointer-events:none;
        transition:transform .25s cubic-bezier(.34,1.56,.64,1), opacity .2s ease;
        transform-origin: bottom right;
    }
    #chatWidget.open #chatWidgetBox {
        transform:scale(1) translateY(0);
        opacity:1; pointer-events:all;
    }
    #chatWidgetToggle {
        width:56px; height:56px; border-radius:50%; border:none; cursor:pointer;
        background:linear-gradient(135deg,#3b82f6,#2563eb);
        color:white; font-size:1.4rem;
        box-shadow:0 8px 24px rgba(59,130,246,.5);
        display:flex; align-items:center; justify-content:center;
        transition:transform .2s ease, box-shadow .2s ease;
        flex-shrink:0;
    }
    #chatWidgetToggle:hover { transform:scale(1.08); box-shadow:0 12px 32px rgba(59,130,246,.6); }
    #chatWidget.open #chatWidgetToggle { background:linear-gradient(135deg,#64748b,#475569); }
    .w-msg { max-width:78%; }
    .w-bubble-ai {
        background:#f1f5f9; color:#1e293b;
        border-radius:4px 16px 16px 16px;
        padding:.6rem .85rem; font-size:.85rem; line-height:1.55;
    }
    .w-bubble-user {
        background:linear-gradient(135deg,#3b82f6,#2563eb); color:white;
        border-radius:16px 4px 16px 16px;
        padding:.6rem .85rem; font-size:.85rem; line-height:1.55;
        text-align:right;
    }
    .w-avatar {
        width:28px; height:28px; border-radius:50%; flex-shrink:0;
        background:linear-gradient(135deg,#3b82f6,#2563eb);
        display:flex; align-items:center; justify-content:center;
    }
    .w-typing span {
        display:inline-block; width:6px; height:6px; border-radius:50%;
        background:#94a3b8; margin:0 2px;
        animation:wTyping 1.2s infinite;
    }
    .w-typing span:nth-child(2){animation-delay:.2s}
    .w-typing span:nth-child(3){animation-delay:.4s}
    @@keyframes wTyping { 0%,60%,100%{transform:translateY(0)} 30%{transform:translateY(-5px)} }
    #chatWidgetBadge {
        position:absolute; top:-4px; right:-4px;
        width:18px; height:18px; border-radius:50%;
        background:#ef4444; color:white; font-size:.65rem; font-weight:700;
        display:flex; align-items:center; justify-content:center;
        border:2px solid white; display:none;
    }
    @@media(max-width:480px){
        #chatWidgetBox { width:calc(100vw - 32px); height:70vh; }
        #chatWidget { bottom:16px; right:16px; }
    }
    </style>

    <div id="chatWidget">
        <div id="chatWidgetBox">
            <!-- Header -->
            <div style="background:linear-gradient(135deg,#1d4ed8,#3b82f6);padding:14px 16px;display:flex;align-items:center;gap:10px;flex-shrink:0">
                <div class="w-avatar">
                    <i class="bi bi-robot text-white" style="font-size:.85rem"></i>
                </div>
                <div style="flex:1">
                    <div style="color:white;font-weight:700;font-size:.9rem">EcoClean AI</div>
                    <div style="color:rgba(255,255,255,.7);font-size:.72rem;display:flex;align-items:center;gap:5px">
                        <span style="width:6px;height:6px;border-radius:50%;background:#4ade80;display:inline-block"></span>
                        Trực tuyến
                    </div>
                </div>
                <button onclick="wClearChat()" title="Chat mới"
                        style="background:rgba(255,255,255,.15);border:1px solid rgba(255,255,255,.25);color:white;border-radius:20px;padding:4px 10px;font-size:.75rem;cursor:pointer;font-weight:600">
                    <i class="bi bi-arrow-repeat"></i>
                </button>
                <button onclick="document.getElementById('chatWidgetToggle').click()"
                        style="background:rgba(255,255,255,.15);border:none;color:white;border-radius:50%;width:28px;height:28px;display:flex;align-items:center;justify-content:center;cursor:pointer">
                    <i class="bi bi-x-lg" style="font-size:.8rem"></i>
                </button>
            </div>

            <!-- Messages -->
            <div id="wMessages" style="flex:1;overflow-y:auto;padding:14px;background:#f8fafc;display:flex;flex-direction:column;gap:10px">
                <div style="display:flex;gap:8px;align-items:flex-end">
                    <div class="w-avatar"><i class="bi bi-robot text-white" style="font-size:.75rem"></i></div>
                    <div class="w-bubble-ai w-msg">
                        Xin chào <strong>@widgetUserName</strong>! 👋<br>
                        Tôi có thể tư vấn chế độ ăn Eat Clean, gợi ý thực đơn và giải đáp câu hỏi dinh dưỡng cho bạn.
                    </div>
                </div>
            </div>

            <!-- Quick suggestions -->
            <div id="wSuggestions" style="padding:8px 12px;background:white;border-top:1px solid #f1f5f9;display:flex;gap:6px;overflow-x:auto;flex-shrink:0">
                @foreach (var s in new[] { "Thực đơn giảm cân?", "1500 kcal ăn gì?", "Protein bao nhiêu là đủ?" })
                {
                    <button onclick="wSendSuggestion('@s')" style="background:rgba(59,130,246,.07);color:#3b82f6;border:1px solid rgba(59,130,246,.2);border-radius:20px;padding:4px 12px;font-size:.75rem;cursor:pointer;white-space:nowrap;font-weight:600">@s</button>
                }
            </div>

            <!-- Input -->
            <div style="padding:12px;background:white;border-top:1px solid #f1f5f9;display:flex;gap:8px;flex-shrink:0">
                <input id="wInput" type="text" placeholder="Nhập câu hỏi..."
                       style="flex:1;border:1.5px solid #e2e8f0;border-radius:24px;padding:8px 16px;font-size:.875rem;outline:none;transition:border-color .2s"
                       onfocus="this.style.borderColor='#3b82f6'" onblur="this.style.borderColor='#e2e8f0'"
                       onkeydown="if(event.key==='Enter')wSend()" />
                <button id="wSendBtn" onclick="wSend()"
                        style="width:40px;height:40px;border-radius:50%;border:none;background:linear-gradient(135deg,#3b82f6,#2563eb);color:white;display:flex;align-items:center;justify-content:center;cursor:pointer;flex-shrink:0;box-shadow:0 4px 12px rgba(59,130,246,.35)">
                    <i class="bi bi-send-fill" style="font-size:.85rem"></i>
                </button>
            </div>
        </div>

        <!-- Toggle button -->
        <div style="position:relative">
            <button id="chatWidgetToggle" onclick="toggleWidget()">
                <i class="bi bi-chat-dots-fill" id="wToggleIcon"></i>
            </button>
            <span id="chatWidgetBadge">1</span>
        </div>
    </div>

    <script>
    let wSessionId = null;
    let wUnread = 0;

    function toggleWidget() {
        const w = document.getElementById('chatWidget');
        w.classList.toggle('open');
        document.getElementById('wToggleIcon').className = w.classList.contains('open')
            ? 'bi bi-x-lg' : 'bi bi-chat-dots-fill';
        if (w.classList.contains('open')) {
            wUnread = 0;
            document.getElementById('chatWidgetBadge').style.display = 'none';
            document.getElementById('wInput').focus();
            const msgs = document.getElementById('wMessages');
            msgs.scrollTop = msgs.scrollHeight;
        }
    }

    function wSendSuggestion(text) {
        document.getElementById('wInput').value = text;
        document.getElementById('wSuggestions').style.display = 'none';
        wSend();
    }

    async function wSend() {
        const input = document.getElementById('wInput');
        const msg = input.value.trim();
        if (!msg) return;

        wAddMessage(msg, 'user');
        input.value = '';
        document.getElementById('wSendBtn').disabled = true;

        const typingId = wAddTyping();

        try {
            const res = await fetch('/Premium/ChatSend', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: new URLSearchParams({ message: msg, sessionId: wSessionId ?? '' })
            });

            if (res.status === 401 || res.redirected) {
                wRemoveTyping(typingId);
                wAddMessage('Vui lòng <a href="/Account/Login" style="color:#3b82f6">đăng nhập</a> để tiếp tục.', 'ai');
                document.getElementById('wSendBtn').disabled = false;
                return;
            }
            if (res.status === 403) {
                wRemoveTyping(typingId);
                wAddMessage('Bạn đã hết lượt miễn phí. <a href="/Premium/Payment" style="color:#f59e0b">Nâng cấp Premium</a> để dùng không giới hạn.', 'ai');
                document.getElementById('wSendBtn').disabled = false;
                return;
            }

            const json = await res.json();
            const data = json.data ?? json;
            wSessionId = data.sessionId;
            wRemoveTyping(typingId);
            wAddMessage(data.reply ?? 'Xin lỗi, có lỗi xảy ra.', 'ai');

            // Nếu widget đang đóng thì hiện badge
            if (!document.getElementById('chatWidget').classList.contains('open')) {
                wUnread++;
                const badge = document.getElementById('chatWidgetBadge');
                badge.textContent = wUnread;
                badge.style.display = 'flex';
            }
        } catch (err) {
            wRemoveTyping(typingId);
            wAddMessage('Lỗi kết nối: ' + err.message, 'ai', true);
        }
        document.getElementById('wSendBtn').disabled = false;
    }

    function wAddMessage(text, role, isError = false) {
        const msgs = document.getElementById('wMessages');
        const isUser = role === 'user';
        const html = isUser
            ? `<div style="display:flex;justify-content:flex-end">
                 <div class="w-bubble-user w-msg">${wEsc(text)}</div>
               </div>`
            : `<div style="display:flex;gap:8px;align-items:flex-end">
                 <div class="w-avatar" style="${isError ? 'background:linear-gradient(135deg,#ef4444,#dc2626)' : ''}">
                   <i class="bi bi-robot text-white" style="font-size:.75rem"></i>
                 </div>
                 <div class="w-bubble-ai w-msg" style="${isError ? 'background:#fef2f2;color:#ef4444' : ''}">${text.replace(/\n/g,'<br>')}</div>
               </div>`;
        msgs.insertAdjacentHTML('beforeend', html);
        msgs.scrollTop = msgs.scrollHeight;
    }

    function wAddTyping() {
        const id = 'wt_' + Date.now();
        document.getElementById('wMessages').insertAdjacentHTML('beforeend',
            `<div id="${id}" style="display:flex;gap:8px;align-items:flex-end">
               <div class="w-avatar"><i class="bi bi-robot text-white" style="font-size:.75rem"></i></div>
               <div class="w-bubble-ai"><div class="w-typing"><span></span><span></span><span></span></div></div>
             </div>`);
        document.getElementById('wMessages').scrollTop = 99999;
        return id;
    }

    function wRemoveTyping(id) { document.getElementById(id)?.remove(); }

    function wClearChat() {
        wSessionId = null;
        document.getElementById('wMessages').innerHTML =
            `<div style="display:flex;gap:8px;align-items:flex-end">
               <div class="w-avatar"><i class="bi bi-robot text-white" style="font-size:.75rem"></i></div>
               <div class="w-bubble-ai w-msg">Chat mới bắt đầu. Tôi có thể giúp gì cho bạn? 😊</div>
             </div>`;
        document.getElementById('wSuggestions').style.display = 'flex';
    }

    function wEsc(s) {
        return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
    }
    </script>
}
</body>
</html>
