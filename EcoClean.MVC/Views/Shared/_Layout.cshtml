<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EcoClean</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-success">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/">
                <i class="bi bi-leaf-fill me-2"></i>EcoClean
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navMenu">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index">Trang chủ</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Recipe" asp-action="Index">Công thức</a></li>
                    @if (Context.Request.Cookies.ContainsKey("ecoclean_token"))
                    {
                        <li class="nav-item"><a class="nav-link" asp-controller="Dashboard" asp-action="Index">Dashboard</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="MealPlan" asp-action="Index">Lịch ăn</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Weight" asp-action="Index">Cân nặng</a></li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle text-warning" href="#" data-bs-toggle="dropdown">
                                <i class="bi bi-stars me-1"></i>Premium
                            </a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" asp-controller="Premium" asp-action="Scan"><i class="bi bi-camera me-2"></i>Quét ảnh món ăn</a></li>
                                <li><a class="dropdown-item" asp-controller="Premium" asp-action="Chat"><i class="bi bi-chat-dots me-2"></i>Chatbot dinh dưỡng</a></li>
                                <li><a class="dropdown-item" asp-controller="Premium" asp-action="AIPlan"><i class="bi bi-robot me-2"></i>Thực đơn AI</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item" asp-controller="Premium" asp-action="Payment"><i class="bi bi-credit-card me-2"></i>Nâng cấp Premium</a></li>
                            </ul>
                        </li>
                    }
                </ul>
                <ul class="navbar-nav">
                    @if (Context.Request.Cookies.ContainsKey("ecoclean_token"))
                    {
                        <li class="nav-item">
                            <span class="nav-link text-white-50">
                                <i class="bi bi-person-circle me-1"></i>@Context.Request.Cookies["ecoclean_name"]
                                @if (Context.Request.Cookies["ecoclean_role"] == "Premium")
                                {
                                    <span class="badge bg-warning text-dark ms-1">PRO</span>
                                }
                                @if (Context.Request.Cookies["ecoclean_role"] == "Admin")
                                {
                                    <span class="badge bg-danger ms-1">ADMIN</span>
                                }
                            </span>
                        </li>
                        @if (Context.Request.Cookies["ecoclean_role"] == "Admin")
                        {
                            <li class="nav-item">
                                <a class="nav-link text-danger fw-semibold" asp-controller="Admin" asp-action="Index">
                                    <i class="bi bi-shield-lock-fill me-1"></i>Admin
                                </a>
                            </li>
                        }
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Account" asp-action="Logout">Đăng xuất</a>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item"><a class="nav-link" asp-controller="Account" asp-action="Login">Đăng nhập</a></li>
                        <li class="nav-item"><a class="btn btn-outline-light btn-sm ms-2 mt-1" asp-controller="Account" asp-action="Register">Đăng ký</a></li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <main>
        @RenderBody()
    </main>

    <footer class="bg-dark text-light py-4 mt-5">
        <div class="container text-center">
            <p class="mb-0"><i class="bi bi-leaf-fill text-success me-2"></i>EcoClean &copy; @DateTime.Now.Year — Healthy Eat Clean Management</p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
