@using System.Text.Json
@{
    ViewData["Title"] = "Công thức Eat Clean";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var recipes = ViewBag.Recipes is JsonElement re && re.ValueKind == JsonValueKind.Array
                  ? re.EnumerateArray().ToList() : new();
    var categories = new[] { "Breakfast", "Lunch", "Dinner", "Snack", "Drink" };
    var catVi = new Dictionary<string,string> {
        ["Breakfast"]="Bữa sáng",["Lunch"]="Bữa trưa",
        ["Dinner"]="Bữa tối",["Snack"]="Snack",["Drink"]="Đồ uống"
    };
    var catIcon = new Dictionary<string,string> {
        ["Breakfast"]="bi-sun",["Lunch"]="bi-brightness-high",
        ["Dinner"]="bi-moon-stars",["Snack"]="bi-apple",["Drink"]="bi-cup-straw"
    };
    var catColor = new Dictionary<string,string> {
        ["Breakfast"]="#f59e0b",["Lunch"]="#22c55e",
        ["Dinner"]="#8b5cf6",["Snack"]="#ef4444",["Drink"]="#0ea5e9"
    };
}

<!-- Hero banner -->
<div style="background:linear-gradient(135deg,#064e3b,#065f46);padding:3rem 0">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-md-7">
                <h1 class="fw-bold text-white mb-2" style="letter-spacing:-0.03em">
                    Thư viện Eat Clean
                </h1>
                <p class="text-white mb-0" style="opacity:.75">
                    @recipes.Count món ăn lành mạnh, đầy đủ dinh dưỡng
                </p>
            </div>
            <div class="col-md-5">
                <form method="get" class="d-flex gap-2">
                    <input type="text" name="tag" class="form-control rounded-pill"
                           placeholder="Tìm theo tag: low-carb, high-protein..."
                           style="background:rgba(255,255,255,.15);border:1px solid rgba(255,255,255,.3);color:white"
                           value="@(Context.Request.Query["tag"])" />
                    <button type="submit" class="btn rounded-pill fw-semibold flex-shrink-0"
                            style="background:white;color:#16a34a">
                        <i class="bi bi-search"></i>
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="container py-4">
    <!-- Filters -->
    <div class="card border-0 p-3 mb-4" style="border-radius:16px !important">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-3">
                <label class="form-label">Loại bữa ăn</label>
                <select name="category" class="form-select" onchange="this.form.submit()">
                    <option value="">Tất cả</option>
                    @foreach (var c in categories)
                    {
                        <option value="@c" selected="@(ViewBag.Category?.ToString() == c ? "selected" : null)">
                            @catVi.GetValueOrDefault(c, c)
                        </option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label">Calo tối đa</label>
                <input type="number" name="maxCalories" class="form-control"
                       placeholder="500" min="50" max="2000"
                       value="@(Context.Request.Query["maxCalories"])" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Tag</label>
                <input type="text" name="tag" class="form-control"
                       placeholder="high-protein, low-carb..."
                       value="@(Context.Request.Query["tag"])" />
            </div>
            <div class="col-md-3">
                <button type="submit" class="btn btn-eco w-100 rounded-pill">
                    <i class="bi bi-search me-1"></i>Tìm kiếm
                </button>
            </div>
        </form>
    </div>

    <!-- Category pills -->
    <div class="d-flex gap-2 mb-4 flex-nowrap overflow-auto pb-1">
        <a class="btn btn-sm rounded-pill fw-semibold flex-shrink-0 @(ViewBag.Category == null ? "btn-eco" : "btn-outline-secondary")"
           asp-action="Index">
            <i class="bi bi-grid me-1"></i>Tất cả
        </a>
        @foreach (var c in categories)
        {
            var isActive = ViewBag.Category?.ToString() == c;
            <a class="btn btn-sm rounded-pill fw-semibold flex-shrink-0"
               asp-action="Index" asp-route-category="@c"
               style="background:@(isActive ? catColor.GetValueOrDefault(c,"#16a34a") : "transparent");color:@(isActive ? "white" : catColor.GetValueOrDefault(c,"#64748b"));border:1.5px solid @catColor.GetValueOrDefault(c,"#e2e8f0")">
                <i class="bi @catIcon.GetValueOrDefault(c,"bi-circle") me-1"></i>@catVi.GetValueOrDefault(c,c)
            </a>
        }
    </div>

    <!-- Recipe Grid -->
    @if (!recipes.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-search display-4 text-muted d-block mb-3 opacity-25"></i>
            <p class="text-muted">Không tìm thấy công thức phù hợp</p>
            <a asp-action="Index" class="btn btn-eco-outline rounded-pill px-4">Xem tất cả</a>
        </div>
    }

    <div class="row g-4">
        @foreach (var r in recipes)
        {
            var name     = r.TryGetProperty("name",     out var n)  ? n.GetString() : "Unknown";
            var cal      = r.TryGetProperty("calories", out var c)  ? c.GetInt32()  : 0;
            var protein  = r.TryGetProperty("protein",  out var pr) ? pr.GetDouble() : 0;
            var carb     = r.TryGetProperty("carb",     out var cb) ? cb.GetDouble() : 0;
            var fat      = r.TryGetProperty("fat",      out var ft) ? ft.GetDouble() : 0;
            var cat      = r.TryGetProperty("category", out var ct) ? ct.GetString() : "";
            var id       = r.TryGetProperty("id",       out var id_) ? id_.GetInt32() : 0;
            var desc     = r.TryGetProperty("description", out var d) ? d.GetString() : "";
            var prepTime = r.TryGetProperty("prepTimeMin", out var pt) && pt.ValueKind != JsonValueKind.Null ? (int?)pt.GetInt32() : null;
            var imgUrl   = r.TryGetProperty("imageUrl", out var iu) && iu.ValueKind != JsonValueKind.Null ? iu.GetString() : null;
            var cc       = catColor.GetValueOrDefault(cat ?? "", "#16a34a");

            <div class="col-md-4 col-lg-3">
                <div class="recipe-card card h-100">
                    <!-- Thumb -->
                    <div class="recipe-thumb position-relative overflow-hidden"
                         style="background:linear-gradient(135deg,@(cc)18,@(cc)08);height:180px">
                        @if (!string.IsNullOrEmpty(imgUrl))
                        {
                            <img src="@imgUrl" alt="@name"
                                 style="width:100%;height:180px;object-fit:cover;display:block"
                                 onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
                            <div style="display:none;align-items:center;justify-content:center;height:180px">
                                <i class="bi @catIcon.GetValueOrDefault(cat??"","bi-bowl-hot")"
                                   style="color:@cc;opacity:.4;font-size:4rem"></i>
                            </div>
                        }
                        else
                        {
                            <div style="display:flex;align-items:center;justify-content:center;height:180px">
                                <i class="bi @catIcon.GetValueOrDefault(cat??"","bi-bowl-hot")"
                                   style="color:@cc;opacity:.4;font-size:4rem"></i>
                            </div>
                        }
                    </div>
                    <div class="card-body p-3">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <span class="badge rounded-pill px-2" style="background:@cc+'18';color:@cc;font-size:.72rem">
                                @catVi.GetValueOrDefault(cat??"",cat??"")
                            </span>
                            @if (prepTime.HasValue)
                            {
                                <span class="text-muted" style="font-size:.75rem">
                                    <i class="bi bi-clock me-1"></i>@prepTime min
                                </span>
                            }
                        </div>
                        <h6 class="fw-bold mb-1" style="font-size:.9rem">@name</h6>
                        @if (!string.IsNullOrEmpty(desc))
                        {
                            <p class="text-muted text-truncate-2 mb-2" style="font-size:.8rem">@desc</p>
                        }
                        <!-- Calories -->
                        <div class="text-center py-2 rounded-3 mb-2" style="background:rgba(22,163,74,.06)">
                            <span class="fw-bold" style="font-size:1.3rem;color:#16a34a">@cal</span>
                            <small class="text-muted"> kcal</small>
                        </div>
                        <!-- Macros -->
                        <div class="row g-1 text-center">
                            <div class="col-4">
                                <div class="macro-pill" style="background:rgba(239,68,68,.08)">
                                    <div class="fw-bold small" style="color:#ef4444">@protein.ToString("0")g</div>
                                    <div style="font-size:.65rem;color:#94a3b8">Protein</div>
                                </div>
                            </div>
                            <div class="col-4">
                                <div class="macro-pill" style="background:rgba(245,158,11,.08)">
                                    <div class="fw-bold small" style="color:#f59e0b">@carb.ToString("0")g</div>
                                    <div style="font-size:.65rem;color:#94a3b8">Carb</div>
                                </div>
                            </div>
                            <div class="col-4">
                                <div class="macro-pill" style="background:rgba(14,165,233,.08)">
                                    <div class="fw-bold small" style="color:#0ea5e9">@fat.ToString("0")g</div>
                                    <div style="font-size:.65rem;color:#94a3b8">Fat</div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="card-footer bg-transparent border-0 pt-0 pb-3 px-3">
                        <a asp-controller="Recipe" asp-action="Detail" asp-route-id="@id"
                           class="btn btn-sm w-100 rounded-pill fw-semibold"
                           style="background:rgba(22,163,74,.1);color:#16a34a;border:1px solid rgba(22,163,74,.2)">
                            <i class="bi bi-eye me-1"></i>Xem chi tiết
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
