@using System.Text.Json
@{
    ViewData["Title"] = "Công thức Eat Clean";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var recipes = ViewBag.Recipes is JsonElement re && re.ValueKind == JsonValueKind.Array
                  ? re.EnumerateArray().ToList() : new();
    var categories = new[] { "Breakfast", "Lunch", "Dinner", "Snack", "Drink" };
    var catVi = new Dictionary<string,string> {
        ["Breakfast"]="Bữa sáng",["Lunch"]="Bữa trưa",
        ["Dinner"]="Bữa tối",["Snack"]="Snack",["Drink"]="Đồ uống"
    };
    var catIcon = new Dictionary<string,string> {
        ["Breakfast"]="bi-sun",["Lunch"]="bi-brightness-high",
        ["Dinner"]="bi-moon-stars",["Snack"]="bi-apple",["Drink"]="bi-cup-straw"
    };
}

<div class="container py-4">
    <div class="d-flex align-items-center mb-4">
        <i class="bi bi-journal-richtext text-success fs-2 me-3"></i>
        <div>
            <h2 class="fw-bold mb-0">Thư viện Eat Clean</h2>
            <p class="text-muted mb-0">@recipes.Count món ăn lành mạnh</p>
        </div>
    </div>

    <!-- Filters -->
    <div class="card border-0 shadow-sm rounded-4 p-3 mb-4">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-3">
                <label class="form-label small fw-semibold">Loại bữa ăn</label>
                <select name="category" class="form-select form-select-sm rounded-3" onchange="this.form.submit()">
                    <option value="">Tất cả</option>
                    @foreach (var c in categories)
                    {
                        <option value="@c" selected="@(ViewBag.Category?.ToString() == c ? "selected" : null)">
                            @catVi.GetValueOrDefault(c, c)
                        </option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label small fw-semibold">Calo tối đa</label>
                <input type="number" name="maxCalories" class="form-control form-control-sm rounded-3"
                       placeholder="500" min="50" max="2000" />
            </div>
            <div class="col-md-3">
                <label class="form-label small fw-semibold">Tag</label>
                <input type="text" name="tag" class="form-control form-control-sm rounded-3"
                       placeholder="high-protein, low-carb..." />
            </div>
            <div class="col-md-3">
                <button type="submit" class="btn btn-success btn-sm w-100 rounded-3">
                    <i class="bi bi-search me-1"></i>Tìm kiếm
                </button>
            </div>
        </form>
    </div>

    <!-- Category tabs -->
    <ul class="nav nav-pills mb-4 flex-nowrap overflow-auto pb-1">
        <li class="nav-item me-2">
            <a class="nav-link @(ViewBag.Category == null ? "active" : "")"
               asp-action="Index">Tất cả</a>
        </li>
        @foreach (var c in categories)
        {
            <li class="nav-item me-2">
                <a class="nav-link @(ViewBag.Category?.ToString() == c ? "active" : "")"
                   asp-action="Index" asp-route-category="@c">
                    <i class="bi @catIcon.GetValueOrDefault(c,"bi-circle") me-1"></i>@catVi.GetValueOrDefault(c,c)
                </a>
            </li>
        }
    </ul>

    <!-- Recipe Grid -->
    @if (!recipes.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-search display-4 text-muted d-block mb-3"></i>
            <p class="text-muted">Không tìm thấy công thức phù hợp</p>
            <a asp-action="Index" class="btn btn-outline-success rounded-pill">Xem tất cả</a>
        </div>
    }

    <div class="row g-4">
        @foreach (var r in recipes)
        {
            var name     = r.TryGetProperty("name",     out var n)  ? n.GetString() : "Unknown";
            var cal      = r.TryGetProperty("calories", out var c)  ? c.GetInt32()  : 0;
            var protein  = r.TryGetProperty("protein",  out var pr) ? pr.GetDouble() : 0;
            var carb     = r.TryGetProperty("carb",     out var cb) ? cb.GetDouble() : 0;
            var fat      = r.TryGetProperty("fat",      out var ft) ? ft.GetDouble() : 0;
            var cat      = r.TryGetProperty("category", out var ct) ? ct.GetString() : "";
            var id       = r.TryGetProperty("id",       out var id_) ? id_.GetInt32() : 0;
            var desc     = r.TryGetProperty("description", out var d) ? d.GetString() : "";
            var prepTime = r.TryGetProperty("prepTimeMin", out var pt) && pt.ValueKind != JsonValueKind.Null ? (int?)pt.GetInt32() : null;
            <div class="col-md-4 col-lg-3">
                <div class="card border-0 shadow-sm rounded-4 h-100 recipe-card">
                    <div class="card-body p-3">
                        <!-- Category badge + icon -->
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <span class="badge bg-success-subtle text-success rounded-pill px-2">
                                <i class="bi @catIcon.GetValueOrDefault(cat??"","bi-circle") me-1"></i>@catVi.GetValueOrDefault(cat??"",cat??"")
                            </span>
                            @if (prepTime.HasValue)
                            {
                                <span class="text-muted small"><i class="bi bi-clock me-1"></i>@prepTime min</span>
                            }
                        </div>
                        <h6 class="fw-bold mb-1">@name</h6>
                        @if (!string.IsNullOrEmpty(desc))
                        {
                            <p class="text-muted small mb-2 text-truncate-2">@desc</p>
                        }
                        <!-- Calories big -->
                        <div class="text-center py-2 bg-light rounded-3 mb-2">
                            <span class="fs-4 fw-bold text-success">@cal</span>
                            <small class="text-muted"> kcal</small>
                        </div>
                        <!-- Macros -->
                        <div class="row g-1 text-center small">
                            <div class="col-4">
                                <div class="bg-danger-subtle rounded-2 p-1">
                                    <div class="fw-bold text-danger">@protein.ToString("0")g</div>
                                    <div class="text-muted" style="font-size:0.65rem">Protein</div>
                                </div>
                            </div>
                            <div class="col-4">
                                <div class="bg-warning-subtle rounded-2 p-1">
                                    <div class="fw-bold text-warning">@carb.ToString("0")g</div>
                                    <div class="text-muted" style="font-size:0.65rem">Carb</div>
                                </div>
                            </div>
                            <div class="col-4">
                                <div class="bg-info-subtle rounded-2 p-1">
                                    <div class="fw-bold text-info">@fat.ToString("0")g</div>
                                    <div class="text-muted" style="font-size:0.65rem">Fat</div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="card-footer bg-transparent border-0 pt-0 pb-3 px-3">
                        <a asp-controller="Recipe" asp-action="Detail" asp-route-id="@id"
                           class="btn btn-outline-success btn-sm w-100 rounded-3">
                            <i class="bi bi-eye me-1"></i>Xem chi tiết
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<style>
.text-truncate-2 { display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
.recipe-card { transition: transform .2s, box-shadow .2s; }
.recipe-card:hover { transform: translateY(-4px); box-shadow: 0 8px 24px rgba(0,0,0,.12) !important; }
</style>
