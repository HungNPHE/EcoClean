@using System.Text.Json
@model JsonElement
@{
    ViewData["Title"] = Model.TryGetProperty("name", out var n) ? n.GetString() : "Chi tiết";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var name    = Model.TryGetProperty("name",        out var nm)  ? nm.GetString()  : "";
    var desc    = Model.TryGetProperty("description", out var d)   ? d.GetString()   : "";
    var cal     = Model.TryGetProperty("calories",    out var c)   ? c.GetInt32()    : 0;
    var protein = Model.TryGetProperty("protein",     out var pr)  ? pr.GetDouble()  : 0;
    var carb    = Model.TryGetProperty("carb",        out var cb)  ? cb.GetDouble()  : 0;
    var fat     = Model.TryGetProperty("fat",         out var ft)  ? ft.GetDouble()  : 0;
    var fiber   = Model.TryGetProperty("fiber",       out var fb)  ? fb.GetDouble()  : 0;
    var cat     = Model.TryGetProperty("category",    out var ct)  ? ct.GetString()  : "";
    var prep    = Model.TryGetProperty("prepTimeMin", out var pt) && pt.ValueKind != JsonValueKind.Null ? (int?)pt.GetInt32() : null;
    var id      = Model.TryGetProperty("id",          out var i)   ? i.GetInt32()    : 0;
}

<div class="container py-4">
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Recipe" asp-action="Index" class="text-success">Công thức</a></li>
            <li class="breadcrumb-item active">@name</li>
        </ol>
    </nav>

    <div class="row g-4">
        <div class="col-md-5">
            <div class="card border-0 rounded-4 shadow-sm overflow-hidden" style="min-height:300px;background:linear-gradient(135deg,#f0fdf4,#bbf7d0)">
                <div class="d-flex align-items-center justify-content-center h-100 py-5">
                    <i class="bi bi-bowl-hot text-success" style="font-size:8rem;opacity:.4"></i>
                </div>
                <div class="position-absolute top-0 start-0 m-3">
                    <span class="badge bg-success px-3 py-2 rounded-pill fs-6">@cat</span>
                </div>
                @if (prep.HasValue)
                {
                    <div class="position-absolute top-0 end-0 m-3">
                        <span class="badge bg-white text-dark px-3 py-2 rounded-pill">
                            <i class="bi bi-clock me-1"></i>@prep phút
                        </span>
                    </div>
                }
            </div>
        </div>

        <div class="col-md-7">
            <h2 class="fw-bold mb-2">@name</h2>
            @if (!string.IsNullOrEmpty(desc))
            {
                <p class="text-muted mb-4">@desc</p>
            }

            <!-- Calories -->
            <div class="card border-0 rounded-4 mb-4 text-center p-3"
                 style="background:linear-gradient(135deg,#ecfdf5,#d1fae5)">
                <small class="text-muted">Tổng năng lượng</small>
                <div class="display-5 fw-bold text-success">@cal <small class="fs-5">kcal</small></div>
            </div>

            <!-- Macros -->
            <h5 class="fw-bold mb-3">Giá trị dinh dưỡng</h5>
            <div class="row g-3 mb-4">
                @foreach (var (label, val, unit, color, icon) in new[] {
                    ("Protein", protein, "g", "danger",  "bi-droplet-fill"),
                    ("Carbohydrate", carb, "g","warning", "bi-grid-fill"),
                    ("Chất béo", fat, "g",    "info",    "bi-water"),
                    ("Chất xơ",  fiber,"g",   "success", "bi-flower1")
                })
                {
                    var pct = cal > 0 ? (int)Math.Min(100, val * (label == "Chất béo" ? 9 : 4) * 100 / cal) : 0;
                    <div class="col-6">
                        <div class="card border-0 bg-@color-subtle rounded-4 p-3 h-100">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <small class="text-muted"><i class="bi @icon me-1"></i>@label</small>
                                <span class="fw-bold text-@color">@val.ToString("0.0")@unit</span>
                            </div>
                            <div class="progress rounded-pill" style="height:6px">
                                <div class="progress-bar bg-@color rounded-pill" style="width:@pct%"></div>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <!-- Add to Meal Plan -->
            @if (Context.Request.Cookies.ContainsKey("ecoclean_token"))
            {
                <div class="card border-0 shadow-sm rounded-4 p-3">
                    <h6 class="fw-bold mb-3"><i class="bi bi-calendar-plus me-2 text-success"></i>Thêm vào lịch ăn</h6>
                    <form method="post" asp-controller="MealPlan" asp-action="Add">
                        <input type="hidden" name="title"    value="@name" />
                        <input type="hidden" name="recipeId" value="@id" />
                        <input type="hidden" name="calories" value="@cal" />
                        <div class="row g-2">
                            <div class="col-5">
                                <select name="mealType" class="form-select form-select-sm rounded-3">
                                    <option value="Breakfast">🌅 Bữa sáng</option>
                                    <option value="Lunch" selected>☀️ Bữa trưa</option>
                                    <option value="Dinner">🌙 Bữa tối</option>
                                    <option value="Snack">🍎 Snack</option>
                                </select>
                            </div>
                            <div class="col-4">
                                <input type="date" name="planDate" class="form-control form-control-sm rounded-3"
                                       value="@DateTime.Today.ToString("yyyy-MM-dd")" />
                            </div>
                            <div class="col-3">
                                <button type="submit" class="btn btn-success btn-sm w-100 rounded-3">
                                    <i class="bi bi-plus-lg"></i> Thêm
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            }
        </div>
    </div>
</div>
