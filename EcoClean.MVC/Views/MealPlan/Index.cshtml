@using System.Text.Json
@{
    ViewData["Title"] = "Lịch ăn uống";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var meals   = ViewBag.Meals is JsonElement me && me.ValueKind == JsonValueKind.Array
                  ? me.EnumerateArray().ToList() : new();
    var date    = ViewBag.Date is DateOnly d ? d : DateOnly.FromDateTime(DateTime.Today);
    var totalCal = meals.Sum(m => m.TryGetProperty("calories", out var c) ? c.GetInt32() : 0);
    var mealOrder = new[] { "Breakfast", "Lunch", "Dinner", "Snack" };
    var mealInfo  = new Dictionary<string,(string vi, string icon, string color, string bg)> {
        ["Breakfast"] = ("Bữa sáng",  "bi-sun",             "#f59e0b", "rgba(245,158,11,.08)"),
        ["Lunch"]     = ("Bữa trưa",  "bi-brightness-high", "#22c55e", "rgba(34,197,94,.08)"),
        ["Dinner"]    = ("Bữa tối",   "bi-moon-stars",      "#8b5cf6", "rgba(139,92,246,.08)"),
        ["Snack"]     = ("Snack",     "bi-apple",           "#0ea5e9", "rgba(14,165,233,.08)"),
    };
}

<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,600;9..144,700&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet">
<style>
:root{--paper:#EDF3E6;--paper-warm:#DEE9D4;--ink:#22301E;--ink-soft:rgba(34,48,30,.62);--herb:#4B7A4E;--herb-deep:#33552F;--herb-tint:#E7EEE0;--line:rgba(34,48,30,.14);--serif:'Fraunces',Georgia,serif;--mono:'JetBrains Mono',monospace}
.btn-herb{background:var(--herb);color:#fff;border:none}.btn-herb:hover{background:var(--herb-deep);color:#fff}
</style>

<div class="container py-4" style="font-family:'Inter',system-ui,sans-serif;color:var(--ink)">
    <!-- Header -->
    <div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-3">
        <div>
            <h2 class="fw-bold mb-1" style="font-family:var(--serif);letter-spacing:-.02em">Lịch ăn uống</h2>
            <p class="text-muted mb-0">
                Tổng hôm nay: <strong style="color:#16a34a">@totalCal.ToString("N0") kcal</strong>
            </p>
        </div>
        <!-- Date navigator -->
        <div class="d-flex align-items-center gap-2">
            <a asp-action="Index" asp-route-date="@date.AddDays(-1).ToString("yyyy-MM-dd")"
               class="btn btn-sm rounded-circle border" style="width:34px;height:34px;padding:0;display:flex;align-items:center;justify-content:center">
                <i class="bi bi-chevron-left" style="font-size:.8rem"></i>
            </a>
            <input type="date" id="dateNav" value="@date.ToString("yyyy-MM-dd")"
                   class="form-control form-control-sm rounded-pill" style="width:150px"
                   onchange="window.location='/MealPlan?date='+this.value" />
            <a asp-action="Index" asp-route-date="@date.AddDays(1).ToString("yyyy-MM-dd")"
               class="btn btn-sm rounded-circle border" style="width:34px;height:34px;padding:0;display:flex;align-items:center;justify-content:center">
                <i class="bi bi-chevron-right" style="font-size:.8rem"></i>
            </a>
            <a asp-action="Index" asp-route-date="@DateOnly.FromDateTime(DateTime.Today).ToString("yyyy-MM-dd")"
               class="btn btn-sm rounded-pill fw-semibold"
               style="background:rgba(22,163,74,.1);color:#16a34a;border:1px solid rgba(22,163,74,.2)">
                Hôm nay
            </a>
        </div>
    </div>

    <div class="row g-4">
        <!-- Meal Sections -->
        <div class="col-md-8">
            @foreach (var type in mealOrder)
            {
                var info     = mealInfo[type];
                var group    = meals.Where(m => m.TryGetProperty("mealType", out var mt) && mt.GetString() == type).ToList();
                var groupCal = group.Sum(m => m.TryGetProperty("calories", out var c) ? c.GetInt32() : 0);

                <div class="card border-0 mb-3" style="border-radius:16px !important">
                    <div class="d-flex justify-content-between align-items-center px-4 py-3"
                         style="background:@info.bg;border-radius:16px 16px 0 0">
                        <span class="fw-bold d-flex align-items-center gap-2">
                            <i class="bi @info.icon" style="color:@info.color"></i>
                            @info.vi
                        </span>
                        <span class="badge rounded-pill px-2 py-1 fw-semibold"
                              style="background:@info.color;color:white;font-size:.78rem">
                            @groupCal.ToString("N0") kcal
                        </span>
                    </div>
                    <div class="card-body p-3">
                        @if (!group.Any())
                        {
                            <p class="text-muted text-center py-2 mb-0 small">Chưa có món ăn</p>
                        }
                        @foreach (var meal in group)
                        {
                            var title = meal.TryGetProperty("title",    out var t)  ? t.GetString()  : "";
                            var cal   = meal.TryGetProperty("calories", out var c)  ? c.GetInt32()   : 0;
                            var mid   = meal.TryGetProperty("id",       out var mi) ? mi.GetInt32()  : 0;
                            var notes = meal.TryGetProperty("notes",    out var no) && no.ValueKind != JsonValueKind.Null ? no.GetString() : null;
                            <div class="d-flex justify-content-between align-items-center py-2"
                                 style="border-bottom:1px solid rgba(226,232,240,.5)">
                                <div>
                                    <span class="fw-semibold small">@title</span>
                                    @if (!string.IsNullOrEmpty(notes))
                                    {
                                        <small class="text-muted d-block" style="font-size:.78rem">@notes</small>
                                    }
                                </div>
                                <div class="d-flex align-items-center gap-3">
                                    <span class="fw-bold small" style="color:#16a34a">@cal.ToString("N0") kcal</span>
                                    <form method="post" asp-action="Delete" class="mb-0">
                                        <input type="hidden" name="id"   value="@mid" />
                                        <input type="hidden" name="date" value="@date.ToString("yyyy-MM-dd")" />
                                        <button type="submit"
                                                class="btn btn-sm rounded-circle d-flex align-items-center justify-content-center"
                                                style="width:28px;height:28px;padding:0;background:rgba(239,68,68,.08);color:#ef4444;border:none"
                                                onclick="return confirm('Xoá món này?')">
                                            <i class="bi bi-trash3" style="font-size:.7rem"></i>
                                        </button>
                                    </form>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>

        <!-- Add Form + Summary -->
        <div class="col-md-4">
            <div class="card border-0 p-4 mb-3" style="border-radius:16px !important">
                <div class="d-flex align-items-center gap-2 mb-3">
                    <div class="rounded-2 d-flex align-items-center justify-content-center"
                         style="width:32px;height:32px;background:rgba(22,163,74,.1);color:#16a34a">
                        <i class="bi bi-plus-lg"></i>
                    </div>
                    <h6 class="fw-bold mb-0">Thêm bữa ăn</h6>
                </div>
                <form method="post" asp-action="Add">
                    <input type="hidden" name="planDate" value="@date.ToString("yyyy-MM-dd")" />
                    <div class="mb-2">
                        <input type="text" name="title" class="form-control"
                               placeholder="Tên món ăn..." required />
                    </div>
                    <div class="mb-2">
                        <select name="mealType" class="form-select">
                            @foreach (var t in mealOrder)
                            {
                                <option value="@t">@mealInfo[t].vi</option>
                            }
                        </select>
                    </div>
                    <div class="mb-2">
                        <div class="input-group">
                            <input type="number" name="calories" class="form-control"
                                   placeholder="Calories" min="0" max="5000" required />
                            <span class="input-group-text">kcal</span>
                        </div>
                    </div>
                    <div class="mb-3">
                        <input type="text" name="notes" class="form-control"
                               placeholder="Ghi chú (tuỳ chọn)" />
                    </div>
                    <button type="submit" class="btn btn-herb btn-sm w-100 rounded-1 fw-semibold">
                        <i class="bi bi-plus-lg me-1"></i>Thêm
                    </button>
                </form>
            </div>

            <!-- Donut chart -->
            <div class="card border-0 p-4 text-center" style="border-radius:16px !important">
                <h6 class="fw-bold mb-3">Phân bổ calo</h6>
                <canvas id="mealDonut" height="160"></canvas>
                <div class="mt-3">
                    @foreach (var type in mealOrder)
                    {
                        var info     = mealInfo[type];
                        var groupCal = meals.Where(m => m.TryGetProperty("mealType", out var mt) && mt.GetString() == type)
                                           .Sum(m => m.TryGetProperty("calories", out var c) ? c.GetInt32() : 0);
                        <div class="d-flex justify-content-between small py-1">
                            <span class="d-flex align-items-center gap-1">
                                <span class="rounded-circle d-inline-block" style="width:8px;height:8px;background:@info.color"></span>
                                @info.vi
                            </span>
                            <span class="fw-semibold">@groupCal.ToString("N0") kcal</span>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
const mealData = {
    Breakfast: @meals.Where(m => m.TryGetProperty("mealType",out var mt) && mt.GetString()=="Breakfast").Sum(m=>m.TryGetProperty("calories",out var c)?c.GetInt32():0),
    Lunch:     @meals.Where(m => m.TryGetProperty("mealType",out var mt2) && mt2.GetString()=="Lunch").Sum(m=>m.TryGetProperty("calories",out var c2)?c2.GetInt32():0),
    Dinner:    @meals.Where(m => m.TryGetProperty("mealType",out var mt3) && mt3.GetString()=="Dinner").Sum(m=>m.TryGetProperty("calories",out var c3)?c3.GetInt32():0),
    Snack:     @meals.Where(m => m.TryGetProperty("mealType",out var mt4) && mt4.GetString()=="Snack").Sum(m=>m.TryGetProperty("calories",out var c4)?c4.GetInt32():0)
};
const total = Object.values(mealData).reduce((a,b)=>a+b,0);
new Chart(document.getElementById('mealDonut'), {
    type: 'doughnut',
    data: {
        labels: ['Sáng','Trưa','Tối','Snack'],
        datasets: [{ data: Object.values(mealData), backgroundColor: ['#f59e0b','#22c55e','#8b5cf6','#0ea5e9'], borderWidth: 0 }]
    },
    options: {
        plugins: {
            legend: { display: false },
            tooltip: { callbacks: { label: ctx => ` ${ctx.parsed} kcal` } }
        },
        cutout: '72%'
    },
    plugins: [{
        id: 'center',
        beforeDraw(chart) {
            const {ctx, chartArea:{width,height}} = chart;
            ctx.save();
            ctx.font = 'bold 16px Inter, sans-serif';
            ctx.fillStyle = '#0f172a';
            ctx.textAlign = 'center';
            ctx.textBaseline = 'middle';
            ctx.fillText(total.toLocaleString('vi-VN') + ' kcal', width/2, height/2);
            ctx.restore();
        }
    }]
});
</script>
}
