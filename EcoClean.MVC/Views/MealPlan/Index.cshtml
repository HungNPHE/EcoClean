@using System.Text.Json
@{
    ViewData["Title"] = "Lịch ăn uống";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var meals   = ViewBag.Meals is JsonElement me && me.ValueKind == JsonValueKind.Array
                  ? me.EnumerateArray().ToList() : new();
    var date    = ViewBag.Date is DateOnly d ? d : DateOnly.FromDateTime(DateTime.Today);
    var totalCal = meals.Sum(m => m.TryGetProperty("calories", out var c) ? c.GetInt32() : 0);
    var mealOrder = new[] { "Breakfast", "Lunch", "Dinner", "Snack" };
    var mealInfo  = new Dictionary<string,(string vi, string icon, string color)> {
        ["Breakfast"] = ("Bữa sáng",  "bi-sun",             "warning"),
        ["Lunch"]     = ("Bữa trưa",  "bi-brightness-high", "success"),
        ["Dinner"]    = ("Bữa tối",   "bi-moon-stars",      "primary"),
        ["Snack"]     = ("Snack",     "bi-apple",           "info")
    };
}

<div class="container py-4">
    <div class="d-flex align-items-center mb-4">
        <i class="bi bi-calendar3 text-success fs-2 me-3"></i>
        <div class="flex-grow-1">
            <h2 class="fw-bold mb-0">Lịch ăn uống</h2>
            <p class="text-muted mb-0">Tổng hôm nay: <strong class="text-success">@totalCal kcal</strong></p>
        </div>
        <!-- Date navigator -->
        <div class="d-flex align-items-center gap-2">
            <a asp-action="Index" asp-route-date="@date.AddDays(-1).ToString("yyyy-MM-dd")"
               class="btn btn-outline-secondary btn-sm rounded-circle"><i class="bi bi-chevron-left"></i></a>
            <input type="date" id="dateNav" value="@date.ToString("yyyy-MM-dd")"
                   class="form-control form-control-sm rounded-3" style="width:150px"
                   onchange="window.location='/MealPlan?date='+this.value" />
            <a asp-action="Index" asp-route-date="@date.AddDays(1).ToString("yyyy-MM-dd")"
               class="btn btn-outline-secondary btn-sm rounded-circle"><i class="bi bi-chevron-right"></i></a>
            <a asp-action="Index" asp-route-date="@DateOnly.FromDateTime(DateTime.Today).ToString("yyyy-MM-dd")"
               class="btn btn-outline-success btn-sm rounded-pill">Hôm nay</a>
        </div>
    </div>

    <div class="row g-4">
        <!-- Meal Sections -->
        <div class="col-md-8">
            @foreach (var type in mealOrder)
            {
                var info  = mealInfo[type];
                var group = meals.Where(m => m.TryGetProperty("mealType", out var mt) && mt.GetString() == type).ToList();
                var groupCal = group.Sum(m => m.TryGetProperty("calories", out var c) ? c.GetInt32() : 0);
                <div class="card border-0 shadow-sm rounded-4 mb-3">
                    <div class="card-header bg-@info.color bg-opacity-10 border-0 rounded-top-4 py-3 px-4 d-flex justify-content-between align-items-center">
                        <span class="fw-bold"><i class="bi @info.icon text-@info.color me-2"></i>@info.vi</span>
                        <span class="badge bg-@info.color rounded-pill">@groupCal kcal</span>
                    </div>
                    <div class="card-body p-3">
                        @if (!group.Any())
                        {
                            <p class="text-muted text-center py-2 mb-0 small">Chưa có món ăn</p>
                        }
                        @foreach (var meal in group)
                        {
                            var title = meal.TryGetProperty("title",    out var t) ? t.GetString() : "";
                            var cal   = meal.TryGetProperty("calories", out var c) ? c.GetInt32()  : 0;
                            var mid   = meal.TryGetProperty("id",       out var mi) ? mi.GetInt32() : 0;
                            var notes = meal.TryGetProperty("notes",    out var no) && no.ValueKind != JsonValueKind.Null ? no.GetString() : null;
                            <div class="d-flex justify-content-between align-items-center py-2 border-bottom">
                                <div>
                                    <span class="fw-semibold">@title</span>
                                    @if (!string.IsNullOrEmpty(notes))
                                    { <small class="text-muted d-block">@notes</small> }
                                </div>
                                <div class="d-flex align-items-center gap-3">
                                    <span class="text-success fw-bold">@cal kcal</span>
                                    <form method="post" asp-action="Delete" class="mb-0">
                                        <input type="hidden" name="id"   value="@mid" />
                                        <input type="hidden" name="date" value="@date.ToString("yyyy-MM-dd")" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger rounded-circle p-1 lh-1"
                                                onclick="return confirm('Xoá món này?')">
                                            <i class="bi bi-trash3" style="font-size:.75rem"></i>
                                        </button>
                                    </form>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>

        <!-- Add Form + Summary -->
        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4 p-4 mb-3">
                <h6 class="fw-bold mb-3"><i class="bi bi-plus-circle text-success me-2"></i>Thêm bữa ăn</h6>
                <form method="post" asp-action="Add">
                    <input type="hidden" name="planDate" value="@date.ToString("yyyy-MM-dd")" />
                    <div class="mb-2">
                        <input type="text" name="title" class="form-control form-control-sm rounded-3"
                               placeholder="Tên món ăn..." required />
                    </div>
                    <div class="mb-2">
                        <select name="mealType" class="form-select form-select-sm rounded-3">
                            @foreach (var t in mealOrder)
                            {
                                <option value="@t">@mealInfo[t].vi</option>
                            }
                        </select>
                    </div>
                    <div class="mb-2">
                        <div class="input-group input-group-sm">
                            <input type="number" name="calories" class="form-control rounded-start-3"
                                   placeholder="Calories" min="0" max="5000" required />
                            <span class="input-group-text">kcal</span>
                        </div>
                    </div>
                    <div class="mb-3">
                        <input type="text" name="notes" class="form-control form-control-sm rounded-3"
                               placeholder="Ghi chú (tuỳ chọn)" />
                    </div>
                    <button type="submit" class="btn btn-success btn-sm w-100 rounded-3">
                        <i class="bi bi-plus-lg me-1"></i>Thêm
                    </button>
                </form>
            </div>

            <!-- Daily Summary Donut -->
            <div class="card border-0 shadow-sm rounded-4 p-4 text-center">
                <h6 class="fw-bold mb-3">Phân bổ calo</h6>
                <canvas id="mealDonut" height="160"></canvas>
                <div class="mt-3">
                    @foreach (var type in mealOrder)
                    {
                        var info  = mealInfo[type];
                        var groupCal = meals.Where(m => m.TryGetProperty("mealType", out var mt) && mt.GetString() == type)
                                           .Sum(m => m.TryGetProperty("calories", out var c) ? c.GetInt32() : 0);
                        <div class="d-flex justify-content-between small py-1">
                            <span><i class="bi bi-circle-fill text-@info.color me-1"></i>@info.vi</span>
                            <span class="fw-semibold">@groupCal kcal</span>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
const mealData = {
    Breakfast: @meals.Where(m => m.TryGetProperty("mealType",out var mt) && mt.GetString()=="Breakfast").Sum(m=>m.TryGetProperty("calories",out var c)?c.GetInt32():0),
    Lunch:     @meals.Where(m => m.TryGetProperty("mealType",out var mt2) && mt2.GetString()=="Lunch").Sum(m=>m.TryGetProperty("calories",out var c2)?c2.GetInt32():0),
    Dinner:    @meals.Where(m => m.TryGetProperty("mealType",out var mt3) && mt3.GetString()=="Dinner").Sum(m=>m.TryGetProperty("calories",out var c3)?c3.GetInt32():0),
    Snack:     @meals.Where(m => m.TryGetProperty("mealType",out var mt4) && mt4.GetString()=="Snack").Sum(m=>m.TryGetProperty("calories",out var c4)?c4.GetInt32():0)
};
const total = Object.values(mealData).reduce((a,b)=>a+b,0);
new Chart(document.getElementById('mealDonut'), {
    type: 'doughnut',
    data: {
        labels: ['Sáng','Trưa','Tối','Snack'],
        datasets: [{ data: Object.values(mealData), backgroundColor: ['#f59e0b','#22c55e','#3b82f6','#06b6d4'], borderWidth: 0 }]
    },
    options: {
        plugins: { legend: { display: false },
            tooltip: { callbacks: { label: ctx => ` ${ctx.parsed} kcal` } }
        },
        cutout: '70%'
    },
    plugins: [{
        id: 'center', beforeDraw(chart) {
            const {ctx,chartArea:{width,height}} = chart;
            ctx.save();
            ctx.font = 'bold 18px sans-serif'; ctx.fillStyle = '#1f2937';
            ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
            ctx.fillText(total + ' kcal', width/2, height/2);
            ctx.restore();
        }
    }]
});
</script>
}
