@using System.Text.Json
@{
    ViewData["Title"] = "Chi tiết người dùng";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var u    = ViewBag.User is JsonElement ue && ue.ValueKind != JsonValueKind.Null ? (JsonElement?)ue : null;
    if (u == null) { <p class="text-danger">Không tìm thấy người dùng.</p> return; }

    var uid    = u.Value.TryGetProperty("id",       out var i)  ? i.GetInt32()   : 0;
    var email  = u.Value.TryGetProperty("email",    out var e)  ? e.GetString()  : "";
    var name   = u.Value.TryGetProperty("fullName", out var fn) ? fn.GetString() : "";
    var role   = u.Value.TryGetProperty("role",     out var r)  ? r.GetString()  : "User";
    var isPrem = u.Value.TryGetProperty("isPremium",out var ip) && ip.GetBoolean();
    var expiry = u.Value.TryGetProperty("premiumExpiry", out var pe) && pe.ValueKind != JsonValueKind.Null
                 ? pe.GetDateTime().ToString("dd/MM/yyyy HH:mm") : "—";
    var created = u.Value.TryGetProperty("createdAt", out var ca) ? ca.GetDateTime().ToString("dd/MM/yyyy") : "";

    var hasPro = u.Value.TryGetProperty("profile", out var profEl) && profEl.ValueKind != JsonValueKind.Null;
    var prof   = hasPro ? (JsonElement?)profEl : null;

    var mealCnt  = u.Value.TryGetProperty("mealPlanCount",  out var mc) ? mc.GetInt32() : 0;
    var wCnt     = u.Value.TryGetProperty("weightLogCount", out var wc) ? wc.GetInt32() : 0;
    var scanCnt  = u.Value.TryGetProperty("scanCount",      out var sc) ? sc.GetInt32() : 0;
    var chatCnt  = u.Value.TryGetProperty("chatCount",      out var cc) ? cc.GetInt32() : 0;

    var subs = u.Value.TryGetProperty("subscriptions", out var subsEl) && subsEl.ValueKind == JsonValueKind.Array
               ? subsEl.EnumerateArray().ToList() : new();
}

<div class="mb-3">
    <a asp-action="Users" class="btn btn-sm btn-outline-secondary rounded-pill">
        <i class="bi bi-arrow-left me-1"></i>Quay lại
    </a>
</div>

<div class="row g-4">
    <!-- User info -->
    <div class="col-md-4">
        <div class="card border-0 shadow-sm rounded-3 p-4">
            <div class="text-center mb-3">
                <div class="rounded-circle bg-primary bg-opacity-10 d-inline-flex align-items-center justify-content-center mb-2"
                     style="width:64px;height:64px">
                    <i class="bi bi-person-fill text-primary fs-2"></i>
                </div>
                <h5 class="fw-bold mb-0">@name</h5>
                <div class="text-muted small">@email</div>
                <div class="mt-2">
                    @if (role == "Admin")   { <span class="badge bg-danger">Admin</span> }
                    else if (role == "Premium") { <span class="badge bg-warning text-dark">Premium</span> }
                    else { <span class="badge bg-secondary">User</span> }
                </div>
            </div>
            <hr />
            <div class="small">
                <div class="d-flex justify-content-between py-1">
                    <span class="text-muted">ID</span><span>#@uid</span>
                </div>
                <div class="d-flex justify-content-between py-1">
                    <span class="text-muted">Ngày tạo</span><span>@created</span>
                </div>
                <div class="d-flex justify-content-between py-1">
                    <span class="text-muted">Premium đến</span>
                    <span class="@(isPrem ? "text-success fw-semibold" : "text-muted")">@expiry</span>
                </div>
            </div>
            <hr />
            <!-- Activity counts -->
            <div class="row g-2 text-center small">
                @foreach (var (lbl, val, color) in new[] {
                    ("Bữa ăn",   mealCnt, "success"),
                    ("Cân nặng", wCnt,    "info"),
                    ("Quét ảnh", scanCnt, "warning"),
                    ("Chat",     chatCnt, "primary"),
                })
                {
                    <div class="col-6">
                        <div class="bg-@color bg-opacity-10 rounded-3 py-2">
                            <div class="fw-bold text-@color fs-5">@val</div>
                            <div class="text-muted">@lbl</div>
                        </div>
                    </div>
                }
            </div>
            @if (role != "Admin")
            {
                <hr />
                <div class="d-flex gap-2">
                    @if (!isPrem)
                    {
                        <form method="post" asp-action="GrantPremium" class="flex-grow-1">
                            <input type="hidden" name="id" value="@uid" />
                            <input type="hidden" name="months" value="1" />
                            <button class="btn btn-warning btn-sm w-100 rounded-3">
                                <i class="bi bi-stars me-1"></i>Cấp Premium
                            </button>
                        </form>
                    }
                    else
                    {
                        <form method="post" asp-action="RevokePremium" class="flex-grow-1">
                            <input type="hidden" name="id" value="@uid" />
                            <button class="btn btn-outline-warning btn-sm w-100 rounded-3">
                                <i class="bi bi-x-circle me-1"></i>Thu hồi
                            </button>
                        </form>
                    }
                    <form method="post" asp-action="DeleteUser"
                          onsubmit="return confirm('Xóa vĩnh viễn tài khoản @email? Không thể hoàn tác!')">
                        <input type="hidden" name="id" value="@uid" />
                        <button class="btn btn-outline-danger btn-sm rounded-3">
                            <i class="bi bi-trash3"></i>
                        </button>
                    </form>
                </div>
            }
        </div>
    </div>

    <!-- Profile + Subscriptions -->
    <div class="col-md-8">
        <!-- Health Profile -->
        <div class="card border-0 shadow-sm rounded-3 p-4 mb-4">
            <h6 class="fw-bold mb-3"><i class="bi bi-heart-pulse text-danger me-2"></i>Hồ sơ sức khỏe</h6>
            @if (!hasPro)
            {
                <p class="text-muted mb-0"><i class="bi bi-info-circle me-1"></i>Người dùng chưa cập nhật hồ sơ.</p>
            }
            else
            {
                double GetD(string key) => prof!.Value.TryGetProperty(key, out var v) ? v.GetDouble() : 0;
                int    GetI(string key) => prof!.Value.TryGetProperty(key, out var v) ? v.GetInt32()  : 0;
                string GetS(string key) => prof!.Value.TryGetProperty(key, out var v) ? v.GetString() ?? "" : "";

                <div class="row g-3">
                    @foreach (var (lbl, val, unit, color) in new[] {
                        ("Chiều cao", GetD("height").ToString("0.0"), "cm",   "primary"),
                        ("Cân nặng",  GetD("weight").ToString("0.0"), "kg",   "success"),
                        ("BMI",       GetD("bmi").ToString("0.0"),    "",     GetD("bmi") < 18.5 ? "info" : GetD("bmi") < 25 ? "success" : GetD("bmi") < 30 ? "warning" : "danger"),
                        ("TDEE",      GetD("tdee").ToString("N0"),    "kcal", "orange"),
                        ("Mục tiêu calo", GetI("dailyCalorieGoal").ToString("N0"), "kcal", "purple"),
                        ("Tuổi",      GetI("age").ToString(),         "tuổi", "secondary"),
                    })
                    {
                        <div class="col-6 col-md-4">
                            <div class="bg-light rounded-3 p-3 text-center">
                                <div class="fw-bold fs-5" style="color:var(--bs-@color,#6c757d)">@val <small class="fs-6 fw-normal text-muted">@unit</small></div>
                                <div class="text-muted small">@lbl</div>
                            </div>
                        </div>
                    }
                </div>
                <div class="mt-3 d-flex gap-3 small text-muted">
                    <span><i class="bi bi-gender-ambiguous me-1"></i>@GetS("gender")</span>
                    <span><i class="bi bi-activity me-1"></i>@GetS("activityLevel")</span>
                    <span><i class="bi bi-bullseye me-1"></i>@GetS("goal")</span>
                    <span><i class="bi bi-tag me-1"></i>@GetS("bmiCategory")</span>
                </div>
            }
        </div>

        <!-- Subscriptions -->
        <div class="card border-0 shadow-sm rounded-3 p-4">
            <h6 class="fw-bold mb-3"><i class="bi bi-credit-card text-success me-2"></i>Lịch sử đăng ký</h6>
            @if (!subs.Any())
            {
                <p class="text-muted mb-0">Chưa có giao dịch nào.</p>
            }
            else
            {
                <table class="table table-sm align-middle mb-0 small">
                    <thead class="table-light">
                        <tr><th>Gói</th><th>Số tiền</th><th>Trạng thái</th><th>Thanh toán</th><th>Hết hạn</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var sub in subs)
                        {
                            var plan   = sub.TryGetProperty("plan",   out var pl) ? pl.GetString() : "";
                            var amount = sub.TryGetProperty("amount", out var am) ? am.GetDecimal() : 0m;
                            var st     = sub.TryGetProperty("status", out var s2) ? s2.GetString() : "";
                            var paid   = sub.TryGetProperty("paidAt", out var pa) && pa.ValueKind != JsonValueKind.Null
                                         ? pa.GetDateTime().ToString("dd/MM/yy") : "—";
                            var exp    = sub.TryGetProperty("expiresAt", out var ex) && ex.ValueKind != JsonValueKind.Null
                                         ? ex.GetDateTime().ToString("dd/MM/yyyy") : "—";
                            var bc     = st switch { "Paid" => "success", "Pending" => "warning", _ => "secondary" };
                            <tr>
                                <td>@plan</td>
                                <td>@amount.ToString("N0")₫</td>
                                <td><span class="badge bg-@bc-subtle text-@bc">@st</span></td>
                                <td>@paid</td>
                                <td>@exp</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
</div>
