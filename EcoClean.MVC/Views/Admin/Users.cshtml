@using System.Text.Json
@{
    ViewData["Title"] = "Quản lý người dùng";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var data  = ViewBag.Data is JsonElement d && d.ValueKind != JsonValueKind.Null ? (JsonElement?)d : null;
    var users = data?.TryGetProperty("users", out var usersEl) == true && usersEl.ValueKind == JsonValueKind.Array
                ? usersEl.EnumerateArray().ToList() : new();
    var total = data?.TryGetProperty("total", out var t) == true ? t.GetInt32() : 0;
    var page  = (int)ViewBag.Page;
    var pages = (int)Math.Ceiling(total / 20.0);
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div><span class="text-muted">Tổng: </span><strong>@total</strong> người dùng</div>
</div>

<div class="card border-0 shadow-sm rounded-3">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>ID</th>
                    <th>Email</th>
                    <th>Họ tên</th>
                    <th>Role</th>
                    <th>Premium đến</th>
                    <th>Ngày tạo</th>
                    <th class="text-end">Hành động</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var u in users)
                {
                    var uid      = u.TryGetProperty("id",           out var i)  ? i.GetInt32()    : 0;
                    var email    = u.TryGetProperty("email",        out var e)  ? e.GetString()   : "";
                    var name     = u.TryGetProperty("fullName",     out var fn) ? fn.GetString()  : "";
                    var role     = u.TryGetProperty("role",         out var r)  ? r.GetString()   : "User";
                    var isPrem   = u.TryGetProperty("isPremium",    out var ip) && ip.GetBoolean();
                    var expiry   = u.TryGetProperty("premiumExpiry",out var pe) && pe.ValueKind != JsonValueKind.Null
                                   ? pe.GetDateTime().ToString("dd/MM/yyyy") : "—";
                    var created  = u.TryGetProperty("createdAt",   out var ca) ? ca.GetDateTime().ToString("dd/MM/yyyy") : "";
                    <tr>
                        <td class="text-muted small">@uid</td>
                        <td>@email</td>
                        <td>@name</td>
                        <td>
                            @if (role == "Admin")
                            { <span class="badge bg-danger">Admin</span> }
                            else if (role == "Premium")
                            { <span class="badge bg-warning text-dark">Premium</span> }
                            else
                            { <span class="badge bg-secondary">User</span> }
                        </td>
                        <td class="small">@expiry</td>
                        <td class="small text-muted">@created</td>
                        <td class="text-end">
                            <a asp-action="UserDetail" asp-route-id="@uid"
                               class="btn btn-sm btn-outline-primary rounded-pill me-1">
                                <i class="bi bi-eye"></i>
                            </a>
                            @if (role != "Admin")
                            {
                                if (!isPrem)
                                {
                                    <form method="post" asp-action="GrantPremium" class="d-inline">
                                        <input type="hidden" name="id" value="@uid" />
                                        <input type="hidden" name="months" value="1" />
                                        <button class="btn btn-sm btn-outline-warning rounded-pill">
                                            <i class="bi bi-stars me-1"></i>+1 tháng
                                        </button>
                                    </form>
                                    <form method="post" asp-action="GrantPremium" class="d-inline ms-1">
                                        <input type="hidden" name="id" value="@uid" />
                                        <input type="hidden" name="months" value="12" />
                                        <button class="btn btn-sm btn-warning rounded-pill">
                                            <i class="bi bi-stars me-1"></i>+1 năm
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <form method="post" asp-action="RevokePremium" class="d-inline"
                                          onsubmit="return confirm('Thu hồi Premium của @email?')">
                                        <input type="hidden" name="id" value="@uid" />
                                        <button class="btn btn-sm btn-outline-danger rounded-pill">
                                            <i class="bi bi-x-circle me-1"></i>Thu hồi
                                        </button>
                                    </form>
                                }
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@if (pages > 1)
{
    <nav class="mt-3">
        <ul class="pagination pagination-sm justify-content-center">
            @for (int p = 1; p <= pages; p++)
            {
                <li class="page-item @(p == page ? "active" : "")">
                    <a class="page-link" asp-action="Users" asp-route-page="@p">@p</a>
                </li>
            }
        </ul>
    </nav>
}
