@using System.Text.Json
@{
    ViewData["Title"] = "Quản lý người dùng";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var data  = ViewBag.Data is JsonElement d && d.ValueKind != JsonValueKind.Null ? (JsonElement?)d : null;
    var users = data?.TryGetProperty("users", out var usersEl) == true && usersEl.ValueKind == JsonValueKind.Array
                ? usersEl.EnumerateArray().ToList() : new();
    var total = data?.TryGetProperty("total", out var t) == true ? t.GetInt32() : 0;
    var page  = (int)ViewBag.Page;
    var pages = (int)Math.Ceiling(total / 20.0);
}

<!-- Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <div class="text-muted small mb-1">Tổng cộng</div>
        <div class="fw-bold" style="font-size:1.5rem;letter-spacing:-0.02em">
            @total <span class="text-muted fw-normal" style="font-size:1rem">người dùng</span>
        </div>
    </div>
</div>

<!-- Table -->
<div class="table-card">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Người dùng</th>
                    <th>Role</th>
                    <th>Premium đến</th>
                    <th>Ngày tạo</th>
                    <th class="text-end">Hành động</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var u in users)
                {
                    var uid     = u.TryGetProperty("id",           out var i)  ? i.GetInt32()    : 0;
                    var email   = u.TryGetProperty("email",        out var e)  ? e.GetString()   : "";
                    var name    = u.TryGetProperty("fullName",     out var fn) ? fn.GetString()  : "";
                    var role    = u.TryGetProperty("role",         out var r)  ? r.GetString()   : "User";
                    var isPrem  = u.TryGetProperty("isPremium",    out var ip) && ip.GetBoolean();
                    var expiry  = u.TryGetProperty("premiumExpiry",out var pe) && pe.ValueKind != JsonValueKind.Null
                                  ? pe.GetDateTime().ToString("dd/MM/yyyy") : "—";
                    var created = u.TryGetProperty("createdAt",   out var ca) ? ca.GetDateTime().ToString("dd/MM/yyyy") : "";

                    var (roleBg, roleColor, roleLabel) = role switch {
                        "Admin"   => ("rgba(239,68,68,.1)",   "#dc2626", "Admin"),
                        "Premium" => ("rgba(245,158,11,.1)",  "#d97706", "Premium"),
                        _         => ("rgba(100,116,139,.1)", "#64748b", "User")
                    };

                    <tr>
                        <td class="text-muted" style="font-size:.8rem">#@uid</td>
                        <td>
                            <div class="d-flex align-items-center gap-2">
                                <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0"
                                     style="width:34px;height:34px;background:rgba(22,163,74,.1);color:#16a34a;font-size:.85rem;font-weight:700">
                                    @(name?.Length > 0 ? name[0].ToString().ToUpper() : "?")
                                </div>
                                <div>
                                    <div class="fw-semibold" style="font-size:.875rem">@name</div>
                                    <div class="text-muted" style="font-size:.775rem">@email</div>
                                </div>
                            </div>
                        </td>
                        <td>
                            <span class="badge rounded-pill px-2 py-1"
                                  style="background:@roleBg;color:@roleColor;font-size:.75rem">
                                @roleLabel
                            </span>
                        </td>
                        <td>
                            @if (isPrem)
                            {
                                <span class="text-success fw-semibold small">@expiry</span>
                            }
                            else
                            {
                                <span class="text-muted small">—</span>
                            }
                        </td>
                        <td class="text-muted small">@created</td>
                        <td class="text-end">
                            <div class="d-flex justify-content-end gap-1">
                                <a asp-action="UserDetail" asp-route-id="@uid"
                                   class="btn btn-sm rounded-2 fw-semibold"
                                   style="background:rgba(59,130,246,.1);color:#3b82f6;font-size:.775rem;padding:.3rem .65rem">
                                    <i class="bi bi-eye me-1"></i>Chi tiết
                                </a>
                                @if (role != "Admin")
                                {
                                    if (!isPrem)
                                    {
                                        <form method="post" asp-action="GrantPremium" class="d-inline">
                                            <input type="hidden" name="id" value="@uid" />
                                            <input type="hidden" name="months" value="1" />
                                            <button class="btn btn-sm rounded-2 fw-semibold"
                                                    style="background:rgba(245,158,11,.1);color:#d97706;font-size:.775rem;padding:.3rem .65rem">
                                                <i class="bi bi-stars me-1"></i>+1T
                                            </button>
                                        </form>
                                        <form method="post" asp-action="GrantPremium" class="d-inline">
                                            <input type="hidden" name="id" value="@uid" />
                                            <input type="hidden" name="months" value="12" />
                                            <button class="btn btn-sm rounded-2 fw-semibold"
                                                    style="background:rgba(245,158,11,.15);color:#d97706;font-size:.775rem;padding:.3rem .65rem">
                                                <i class="bi bi-stars me-1"></i>+1N
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <form method="post" asp-action="RevokePremium" class="d-inline"
                                              onsubmit="return confirm('Thu hồi Premium của @email?')">
                                            <input type="hidden" name="id" value="@uid" />
                                            <button class="btn btn-sm rounded-2 fw-semibold"
                                                    style="background:rgba(239,68,68,.1);color:#dc2626;font-size:.775rem;padding:.3rem .65rem">
                                                <i class="bi bi-x-circle me-1"></i>Thu hồi
                                            </button>
                                        </form>
                                    }
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@if (pages > 1)
{
    <nav class="mt-4">
        <ul class="pagination pagination-sm justify-content-center gap-1">
            @for (int p = 1; p <= pages; p++)
            {
                <li class="page-item @(p == page ? "active" : "")">
                    <a class="page-link" asp-action="Users" asp-route-page="@p">@p</a>
                </li>
            }
        </ul>
    </nav>
}
