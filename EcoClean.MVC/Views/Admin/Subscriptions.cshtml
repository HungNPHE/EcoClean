@using System.Text.Json
@{
    ViewData["Title"] = "Quản lý thanh toán";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var subs   = ViewBag.Subs is JsonElement s && s.ValueKind == JsonValueKind.Array
                 ? s.EnumerateArray().ToList() : new();
    var status = ViewBag.Status as string;
}

<!-- Filter tabs -->
<div class="d-flex gap-2 mb-4 flex-wrap">
    @foreach (var (lbl, val, color, bg) in new[] {
        ("Tất cả",       "",         "#64748b", "rgba(100,116,139,.1)"),
        ("Chờ duyệt",    "Pending",  "#d97706", "rgba(245,158,11,.1)"),
        ("Đã thanh toán","Paid",     "#16a34a", "rgba(22,163,74,.1)"),
        ("Thất bại",     "Failed",   "#dc2626", "rgba(239,68,68,.1)"),
    })
    {
        var isActive = status == val || (val == "" && status == null);
        <a asp-action="Subscriptions" asp-route-status="@val"
           class="btn btn-sm rounded-pill fw-semibold px-3"
           style="background:@(isActive ? bg : "transparent");color:@color;border:1.5px solid @(isActive ? color : "#e2e8f0");transition:all .15s">
            @lbl
        </a>
    }
</div>

<!-- Table -->
<div class="table-card">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Người dùng</th>
                    <th>Gói</th>
                    <th class="text-end">Số tiền</th>
                    <th class="text-center">Trạng thái</th>
                    <th>Mã GD</th>
                    <th>Ngày tạo</th>
                    <th>Hết hạn</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var sub in subs)
                {
                    var sid    = sub.TryGetProperty("id",             out var i)   ? i.GetInt32()    : 0;
                    var plan   = sub.TryGetProperty("plan",           out var pl)  ? pl.GetString()  : "";
                    var amount = sub.TryGetProperty("amount",         out var am)  ? am.GetDecimal() : 0m;
                    var st     = sub.TryGetProperty("status",         out var s2)  ? s2.GetString()  : "";
                    var txRef  = sub.TryGetProperty("transactionRef", out var tx)  ? tx.GetString()  : "";
                    var paidAt = sub.TryGetProperty("paidAt",         out var pa) && pa.ValueKind != JsonValueKind.Null
                                 ? pa.GetDateTime().ToString("dd/MM/yy HH:mm") : "—";
                    var expiry = sub.TryGetProperty("expiresAt",      out var ex) && ex.ValueKind != JsonValueKind.Null
                                 ? ex.GetDateTime().ToString("dd/MM/yyyy") : "—";

                    var userEl  = sub.TryGetProperty("user", out var u) ? (JsonElement?)u : null;
                    var uEmail  = userEl?.TryGetProperty("email",    out var ue) == true ? ue.GetString() : "";
                    var uName   = userEl?.TryGetProperty("fullName", out var un) == true ? un.GetString() : "";

                    var (stBg, stColor) = st switch {
                        "Paid"    => ("rgba(34,197,94,.1)",   "#16a34a"),
                        "Pending" => ("rgba(245,158,11,.1)",  "#d97706"),
                        "Failed"  => ("rgba(239,68,68,.1)",   "#dc2626"),
                        _         => ("rgba(100,116,139,.1)", "#64748b")
                    };

                    <tr>
                        <td class="text-muted small">#@sid</td>
                        <td>
                            <div class="fw-semibold small">@uName</div>
                            <div class="text-muted" style="font-size:.775rem">@uEmail</div>
                        </td>
                        <td>
                            <span class="badge rounded-pill px-2"
                                  style="background:rgba(59,130,246,.1);color:#3b82f6;font-size:.75rem">@plan</span>
                        </td>
                        <td class="text-end fw-bold small">@amount.ToString("N0")₫</td>
                        <td class="text-center">
                            <span class="badge rounded-pill px-2"
                                  style="background:@stBg;color:@stColor;font-size:.75rem">@st</span>
                        </td>
                        <td class="text-muted" style="font-size:.75rem;max-width:120px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">
                            @txRef
                        </td>
                        <td class="text-muted small">@paidAt</td>
                        <td class="text-muted small">@expiry</td>
                        <td>
                            @if (st == "Pending")
                            {
                                <form method="post" asp-action="ConfirmSubscription" class="d-inline"
                                      onsubmit="return confirm('Xác nhận thanh toán #@sid?')">
                                    <input type="hidden" name="id" value="@sid" />
                                    <button class="btn btn-sm rounded-2 fw-semibold"
                                            style="background:rgba(22,163,74,.1);color:#16a34a;border:1px solid rgba(22,163,74,.2);font-size:.775rem;padding:.3rem .65rem">
                                        <i class="bi bi-check-lg me-1"></i>Duyệt
                                    </button>
                                </form>
                            }
                        </td>
                    </tr>
                }
                @if (!subs.Any())
                {
                    <tr>
                        <td colspan="9" class="text-center py-5 text-muted">
                            <i class="bi bi-inbox display-5 d-block mb-2 opacity-25"></i>
                            Không có dữ liệu
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
