@using System.Text.Json
@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var s = ViewBag.Stats is JsonElement st && st.ValueKind != JsonValueKind.Null ? (JsonElement?)st : null;
    T Get<T>(string key, T def) {
        if (s == null || !s.Value.TryGetProperty(key, out var v)) return def;
        if (typeof(T) == typeof(int))     return (T)(object)v.GetInt32();
        if (typeof(T) == typeof(decimal)) return (T)(object)v.GetDecimal();
        return def;
    }
    var rev = s?.TryGetProperty("revenue", out var rv) == true ? rv.GetDecimal() : 0m;
}

<!-- Stat cards -->
<div class="row g-3 mb-4">
    @foreach (var (label, icon, color, bg, val) in new[] {
        ("Tổng người dùng",   "bi-people-fill",      "#3b82f6", "rgba(59,130,246,.1)",  Get("totalUsers",    0).ToString()),
        ("Premium",           "bi-stars",            "#f59e0b", "rgba(245,158,11,.1)",  Get("premiumUsers",  0).ToString()),
        ("Mới hôm nay",       "bi-person-plus-fill", "#22c55e", "rgba(34,197,94,.1)",   Get("newUsersToday", 0).ToString()),
        ("Gói hoạt động",     "bi-shield-check",     "#0ea5e9", "rgba(14,165,233,.1)",  Get("activePlans",   0).ToString()),
        ("Lượt quét ảnh",     "bi-camera-fill",      "#8b5cf6", "rgba(139,92,246,.1)",  Get("totalScans",    0).ToString()),
        ("Tin nhắn chat",     "bi-chat-dots-fill",   "#ec4899", "rgba(236,72,153,.1)",  Get("totalChats",    0).ToString()),
    })
    {
        <div class="col-6 col-md-4 col-xl-2">
            <div class="stat-card">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <div class="text-muted mb-1" style="font-size:.75rem;font-weight:600;text-transform:uppercase;letter-spacing:.05em">@label</div>
                        <div class="fw-bold" style="font-size:1.75rem;letter-spacing:-0.03em;color:#0f172a" data-count="@val">@val</div>
                    </div>
                    <div class="stat-icon" style="background:@bg;color:@color">
                        <i class="bi @icon"></i>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<!-- Revenue + Quick access -->
<div class="row g-4 mb-4">
    <div class="col-md-4">
        <div class="stat-card h-100" style="background:linear-gradient(135deg,#064e3b,#065f46)">
            <div class="text-white-50 small mb-1 fw-semibold">TỔNG DOANH THU</div>
            <div class="fw-bold text-white mb-1" style="font-size:2rem;letter-spacing:-0.03em">
                @rev.ToString("N0")<small class="fs-5 fw-normal ms-1" style="opacity:.6">₫</small>
            </div>
            <div class="small" style="color:rgba(255,255,255,.5)">Từ các gói đã thanh toán</div>
            <div class="mt-3 pt-3" style="border-top:1px solid rgba(255,255,255,.1)">
                <a asp-action="Subscriptions" asp-route-status="Pending"
                   class="btn btn-sm rounded-pill fw-semibold"
                   style="background:rgba(255,255,255,.15);color:white;border:1px solid rgba(255,255,255,.2)">
                    <i class="bi bi-clock me-1"></i>Xem chờ duyệt
                </a>
            </div>
        </div>
    </div>

    <div class="col-md-8">
        <div class="stat-card h-100">
            <div class="fw-bold mb-3" style="font-size:.9rem">Truy cập nhanh</div>
            <div class="row g-3">
                <div class="col-6">
                    <a asp-action="Users"
                       class="d-flex align-items-center gap-3 p-3 rounded-3 text-decoration-none"
                       style="background:rgba(59,130,246,.08);transition:all .15s"
                       onmouseover="this.style.transform='translateY(-2px)'"
                       onmouseout="this.style.transform=''">
                        <div class="rounded-2 d-flex align-items-center justify-content-center"
                             style="width:38px;height:38px;background:#3b82f6;color:white;font-size:1rem;flex-shrink:0">
                            <i class="bi bi-people"></i>
                        </div>
                        <span class="fw-semibold small" style="color:#0f172a">Quản lý Users</span>
                    </a>
                </div>
                <div class="col-6">
                    <a asp-action="Recipes"
                       class="d-flex align-items-center gap-3 p-3 rounded-3 text-decoration-none"
                       style="background:rgba(34,197,94,.08);transition:all .15s"
                       onmouseover="this.style.transform='translateY(-2px)'"
                       onmouseout="this.style.transform=''">
                        <div class="rounded-2 d-flex align-items-center justify-content-center"
                             style="width:38px;height:38px;background:#22c55e;color:white;font-size:1rem;flex-shrink:0">
                            <i class="bi bi-journal-richtext"></i>
                        </div>
                        <span class="fw-semibold small" style="color:#0f172a">Quản lý Recipes</span>
                    </a>
                </div>
                <div class="col-6">
                    <a asp-action="Subscriptions"
                       class="d-flex align-items-center gap-3 p-3 rounded-3 text-decoration-none"
                       style="background:rgba(245,158,11,.08);transition:all .15s"
                       onmouseover="this.style.transform='translateY(-2px)'"
                       onmouseout="this.style.transform=''">
                        <div class="rounded-2 d-flex align-items-center justify-content-center"
                             style="width:38px;height:38px;background:#f59e0b;color:white;font-size:1rem;flex-shrink:0">
                            <i class="bi bi-credit-card"></i>
                        </div>
                        <span class="fw-semibold small" style="color:#0f172a">Thanh toán</span>
                    </a>
                </div>
                <div class="col-6">
                    <a asp-action="Subscriptions" asp-route-status="Pending"
                       class="d-flex align-items-center gap-3 p-3 rounded-3 text-decoration-none"
                       style="background:rgba(239,68,68,.08);transition:all .15s"
                       onmouseover="this.style.transform='translateY(-2px)'"
                       onmouseout="this.style.transform=''">
                        <div class="rounded-2 d-flex align-items-center justify-content-center"
                             style="width:38px;height:38px;background:#ef4444;color:white;font-size:1rem;flex-shrink:0">
                            <i class="bi bi-clock-history"></i>
                        </div>
                        <span class="fw-semibold small" style="color:#0f172a">Chờ xác nhận</span>
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
